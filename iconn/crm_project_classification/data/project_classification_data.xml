    </record>
    <record id="crm_project_status_design_qualified" model="crm.project.status">
        <field name="name">Qualified</field>
        <field name="category_id" ref="crm_project_category_design" />
        <field name="sequence">20</field>
    </record>
    <record id="crm_project_status_design_sponsorship" model="crm.project.status">
