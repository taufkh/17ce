    </record>
    <record id="crm_project_status_design_order_win" model="crm.project.status">
        <field name="name">Order win</field>
        <field name="category_id" ref="crm_project_category_design" />
        <field name="sequence">70</field>
        <field name="is_closed">1</field>
    </record>
    <record id="crm_project_status_design_order_lost" model="crm.project.status">
        <field name="name">Order lost</field>
        <field name="category_id" ref="crm_project_category_design" />
        <field name="sequence">80</field>
        <field name="is_closed">1</field>
    </record>

    <record id="crm_project_status_trading_trading" model="crm.project.status">
        <field name="name">Trading</field>
        <field name="category_id" ref="crm_project_category_trading" />
        <field name="sequence">10</field>
    </record>
    <record id="crm_project_status_trading_order_win" model="crm.project.status">
        <field name="name">Order win</field>
