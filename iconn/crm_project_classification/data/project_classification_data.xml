        <field name="name">Inclusion</field>
        <field name="category_id" ref="crm_project_category_design" />
        <field name="sequence">40</field>
    </record>
    <record id="crm_project_status_design_validation" model="crm.project.status">
        <field name="name">Validation</field>
        <field name="category_id" ref="crm_project_category_design" />
