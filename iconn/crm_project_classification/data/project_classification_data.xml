<odoo>
    <record id="crm_project_category_bidding" model="crm.project.category">
        <field name="name">Bidding</field>
    </record>
    <record id="crm_project_category_design" model="crm.project.category">
        <field name="name">Design</field>
    </record>
    <record id="crm_project_category_trading" model="crm.project.category">
        <field name="name">Trading</field>
    </record>
    <record id="crm_project_category_technical_enquiries" model="crm.project.category">
        <field name="name">Technical enquiries</field>
    </record>

    <record id="crm_project_status_bidding_bidding" model="crm.project.status">
        <field name="name">Bidding</field>
        <field name="category_id" ref="crm_project_category_bidding" />
        <field name="sequence">10</field>
    </record>
    <record id="crm_project_status_bidding_l1" model="crm.project.status">
        <field name="name">L1</field>
        <field name="category_id" ref="crm_project_category_bidding" />
        <field name="sequence">20</field>
    </record>
    <record id="crm_project_status_bidding_order_win" model="crm.project.status">
        <field name="name">Order win</field>
        <field name="category_id" ref="crm_project_category_bidding" />
        <field name="sequence">30</field>
        <field name="is_closed">1</field>
    </record>
    <record id="crm_project_status_bidding_order_lost" model="crm.project.status">
        <field name="name">Order lost</field>
        <field name="category_id" ref="crm_project_category_bidding" />
        <field name="sequence">40</field>
        <field name="is_closed">1</field>
    </record>

    <record id="crm_project_status_design_prospect" model="crm.project.status">
