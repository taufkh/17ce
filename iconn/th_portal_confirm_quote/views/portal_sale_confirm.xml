<odoo>
    <template id="sale_order_portal_template_confirm_btn" inherit_id="sale.sale_order_portal_template">
        <xpath expr="//div[@id='sale_order_sidebar_button']" position="inside">
            <t t-if="sale_order.state in ('draft', 'sent') and not sale_order.is_expired">
                <form t-att-action="sale_order.get_portal_url(suffix='/confirm')" method="post" class="mb8">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="access_token" t-att-value="sale_order.access_token"/>
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fa fa-check"/> Confirm
                    </button>
                </form>
            </t>
        </xpath>
    </template>
</odoo>
