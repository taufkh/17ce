<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_holidays.hr_leave_report_calendar_rule_multi_company" model="ir.rule">
        <field name="groups" eval="[(4, ref('hr_holidays.group_hr_holidays_manager'))]"/>
    </record>

    <record id="hr_leave_report_calendar_rule_multi_company_user" model="ir.rule">
        <field name="name">Time Off Report Calendar: only your department</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_report_calendar"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <!-- <field name="domain_force">[('company_id', 'in', company_ids + [False]), '|', ('employee_id.leave_manager_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field> -->
        <field name="domain_force">[('company_id', 'in', company_ids + [False]), '|', ('employee_id.department_id', '=', user.employee_id.department_id.id), ('employee_id.user_id', '=', user.id)]</field>
    </record>

    <record id="hr_holidays.action_hr_holidays_dashboard" model="ir.actions.act_window">
        <field name="context">{'hide_employee_name': 1}</field>
    </record>

</odoo>
