<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_credit_note_approver" model="res.groups">
            <field name="name">Accounting / Approver</field>
        </record>

        <record id="credit_note_tier_definition" model="tier.definition">
            <field name="name">CN Approval</field>
            <field name="model_id" ref="account.model_account_move" />
