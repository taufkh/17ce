<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_state_import_wizard_form" model="ir.ui.view">
        <field name="name">crm.state.import.wizard.form</field>
        <field name="model">crm.state.import.wizard</field>
        <field name="arch" type="xml">
            <form string="State Import">
                <group>
                    <field name="country_id" required="1"/>
                </group>
                <footer>
                    <button string="Import" type="object" name="action_import" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_state_import_wizard" model="ir.actions.act_window">
        <field name="name">State Import</field>
        <field name="res_model">crm.state.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_state_import" name="State Import" parent="contacts.res_partner_menu_config"
              action="action_state_import_wizard" sequence="29"/>
</odoo>
