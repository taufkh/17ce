<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_city_domain" model="ir.ui.view">
        <field name="name">res.partner.city.domain.state</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_address_extended.address_street_extended_city_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='city_id']" position="attributes">
                <attribute name="domain">[('state_id', '=', state_id)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
