<odoo>
    <record id="view_crm_quotation_manufacturer_tree" model="ir.ui.view">
        <field name="name">crm.quotation.manufacturer.tree</field>
        <field name="model">crm.quotation.manufacturer</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_crm_quotation_manufacturer_form" model="ir.ui.view">
        <field name="name">crm.quotation.manufacturer.form</field>
        <field name="model">crm.quotation.manufacturer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_quotation_manufacturer" model="ir.actions.act_window">
        <field name="name">Manufacturers</field>
        <field name="res_model">crm.quotation.manufacturer</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_crm_quotation_manufacturer" name="Manufacturers"
        parent="crm.crm_menu_config" action="action_crm_quotation_manufacturer" sequence="95"/>
</odoo>
