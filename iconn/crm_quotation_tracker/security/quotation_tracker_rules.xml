<odoo>
    <record id="rule_crm_quotation_line_salesman_own_leads" model="ir.rule">
        <field name="name">Quotation Lines: Salesperson own leads</field>
        <field name="model_id" ref="model_crm_quotation_line"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="domain_force">[('lead_id.user_id', '=', user.id)]</field>
    </record>

    <record id="rule_crm_quotation_line_manager_all" model="ir.rule">
        <field name="name">Quotation Lines: Sales manager all</field>
        <field name="model_id" ref="model_crm_quotation_line"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
