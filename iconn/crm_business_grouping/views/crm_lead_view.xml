<odoo>
    <record id="view_crm_lead_form_business_grouping" model="ir.ui.view">
        <field name="name">crm.lead.form.business.grouping</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="business_grouping_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_crm_lead_quick_create_business_grouping" model="ir.ui.view">
        <field name="name">crm.lead.quick.create.business.grouping</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="business_grouping_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_crm_lead_tree_business_grouping" model="ir.ui.view">
        <field name="name">crm.lead.tree.business.grouping</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="business_grouping_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_crm_lead_search_business_grouping" model="ir.ui.view">
        <field name="name">crm.lead.search.business.grouping</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter name="business_grouping" string="Business Grouping" domain="[]"
                    context="{'group_by': 'business_grouping_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
