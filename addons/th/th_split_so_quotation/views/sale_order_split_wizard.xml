<odoo>
    <record id="view_sale_order_split_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.split.wizard.form</field>
        <field name="model">sale.order.split.wizard</field>
        <field name="arch" type="xml">
            <form string="Split Quote">
                <sheet>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="mode" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Split Lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="order_line_id" invisible="1"/>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button string="Split" type="object" name="action_confirm"
                        class="btn-primary" attrs="{'invisible': [('mode', '!=', 'split')]}"/>
                    <button string="Extract" type="object" name="action_confirm"
                        class="btn-primary" attrs="{'invisible': [('mode', '!=', 'extract')]}"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
