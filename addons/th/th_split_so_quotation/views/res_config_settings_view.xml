<odoo>
    <record id="view_res_config_settings_split" model="ir.ui.view">
        <field name="name">res.config.settings.split.quotation</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@data-key='sale_management']" position="inside">
                <h2 class="mt32">Split Configurations</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="split_remove_qty"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="split_remove_qty"/>
                            <div class="text-muted">Remove split quantity from SO / Quotation.</div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
