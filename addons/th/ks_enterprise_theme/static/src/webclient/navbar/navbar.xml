<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="ks_enterprise_theme.EnterpriseNavBar" t-inherit="web.NavBar" t-inherit-mode="primary">
    <!-- Add t-ref="nav" to the root <nav> element for JS class manipulation -->
    <xpath expr="//nav" position="attributes">
        <attribute name="t-ref">nav</attribute>
    </xpath>

    <!-- Replace the community AppsMenu call with the Enterprise 9-dots toggle -->
    <xpath expr="//t[@t-call='web.NavBar.AppsMenu']" position="replace">
        <a
            t-if="!isScopedApp"
            href="/odoo"
            class="o_menu_toggle border-0"
            t-att-class="{'hasImage': currentApp?.webIconData}"
            accesskey="h"
            t-ref="menuApps"
            t-on-click.prevent="() => { env.isSmall ? this._openAppMenuSidebar() : this.hm.toggle() }"
        >
            <svg class="o_menu_toggle_icon pe-none" width="14px" height="14px" viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
                <g t-foreach="[0, 5, 10]" t-as="Y" t-att-id="'o_menu_toggle_row_' + Y_index" fill="currentColor" t-key="'o_menu_toggle_row_' + Y_index">
                    <rect t-foreach="[0, 5, 10]" t-as="X" width="3" height="3" t-att-x="X" t-att-y="Y" t-key="'o_menu_toggle_cell_' + X_index"/>
                </g>
            </svg>
            <svg class="o_menu_toggle_back_icon pe-none" width="18px" height="18px" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10.75 2.75 5.5 8l5.25 5.25" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"/>
            </svg>
            <t t-if="!env.isSmall and currentApp">
                <img
                    t-if="currentApp.webIconData"
                    t-att-src="getAppIconSrc(currentApp)"
                    class="o_menu_brand_icon d-inline position-absolute start-0"
                    t-att-alt="currentApp.name"
                    t-ref="appIcon"
                />
                <span t-esc="currentApp.name" class="o_menu_brand d-flex pe-0"/>
            </t>
        </a>
        <!-- Scoped app mode (PWA) -->
        <a t-else="" t-att-href="pwa.startUrl" class="o_menu_toggle" t-ref="menuApps">
            <img
                t-if="currentApp and currentApp.webIconData"
                t-att-src="getAppIconSrc(currentApp)"
                class="o_menu_brand_icon d-none d-lg-inline position-absolute start-0"
                t-att-alt="currentApp.name"
                t-ref="appIcon"
            />
            <span
                t-if="currentApp"
                t-esc="currentApp.name"
                class="o_menu_brand d-none d-md-flex pe-0"
            />
        </a>
    </xpath>

    <!-- Remove the standalone app name DropdownItem (shown in community, not needed here) -->
    <xpath expr="//DropdownItem[@t-esc='currentApp.name']" position="replace"/>
</t>

<!-- Sections menu: fw-normal xpath disabled (//Dropdown/button no longer matches in Odoo 17) -->
