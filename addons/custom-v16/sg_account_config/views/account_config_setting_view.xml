<odoo>

    <record id="view_account_config_settings_inherited_view" model="ir.ui.view">
        <field name="name">view.account.config.settings.inherited.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='bank_cash']" position="inside">
                <setting id="sg_bank_reconcile_setting"
                    string="Bank Reconcile"
                    help="Manage bank reconciliation and bank statements">
                    <field name="module_sg_bank_reconcile"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
