<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ce_view_move_form_inherit_invoicenow" model="ir.ui.view">
        <field name="name">ce.account.move.form.inherit.invoicenow</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='button_cancel']" position="after">
                <button name="action_ce_generate_xml"
                        type="object"
                        string="Generate CE XML"
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_refund')"
                        class="btn-secondary"/>
                <button name="action_ce_invoice_now_sent"
                        type="object"
                        string="CE InvoiceNow"
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_refund') or not ce_applicable_invoicenow"
                        class="oe_highlight"/>
            </xpath>

            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="ce_applicable_invoicenow" readonly="1"/>
            </xpath>

            <xpath expr="//page[@name='other_info']" position="after">
                <page string="CE InvoiceNow Status" name="ce_invoicenow_status">
                    <group string="CE XML">
                        <field name="ce_xml_generation_state" readonly="1"/>
                        <field name="ce_xml_attachment_id" readonly="1"/>
                        <field name="ce_xml_generated_at" readonly="1"/>
                        <field name="ce_xml_hash" readonly="1"/>
                        <field name="ce_xml_error_message" readonly="1"/>
                    </group>
                    <group string="Send Invoice Document">
                        <field name="ce_client_ref" readonly="1"/>
                        <field name="ce_send_invoice_req_status" readonly="1"/>
                        <field name="ce_send_invoice_content" readonly="1"/>
                        <field name="ce_send_invoice_status" readonly="1"/>
                    </group>
                    <group string="Check Invoice Status">
                        <field name="ce_invoice_status_content" readonly="1"/>
                        <field name="ce_invoice_status" readonly="1"/>
                        <field name="ce_is_completed" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
