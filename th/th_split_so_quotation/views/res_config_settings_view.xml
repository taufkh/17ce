<odoo>
    <record id="view_res_config_settings_split" model="ir.ui.view">
        <field name="name">res.config.settings.split.quotation</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <setting id="order_default_values" position="after">
                <setting id="th_split_remove_qty"
                    string="Split Quotation Quantity Handling"
                    help="Remove split quantity from the original quotation">
                    <field name="split_remove_qty"/>
                </setting>
            </setting>
        </field>
    </record>
</odoo>
