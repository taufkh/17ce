<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="report_odes_commercial_invoice_document">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.html_container">
          <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)" />
            <div class="page">
              <div class="row mt32 mb32">
                <t t-if="o.company_id.name in ['iConnexion Asia Pte Ltd']">
                  <div class="col-auto">
                    <img style="width : 100%; max-height:45mm; max-width:45mm;"
                      src="/iconnexion_custom/static/src/img/icon.png" />
                  </div>
                </t>
                <t t-if="o.company_id.name in ['McCoy Pte Ltd']">
                  <div class="col-auto">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                      style="max-height: 65px;" alt="Logo" />
                  </div>
                </t>
                <div class="col-auto" style="min-width: 500px">
                  <h2 style="text-align: right;">COMMERCIAL INVOICE</h2>
                </div>
              </div>
              <br />

              <div class="row mt32 mb32">
                <div class="col-auto">
                  <div><span style="font-size : 15px; text-decoration: underline; font-weight: bold;"
                      t-field="o.company_id.name" /></div>
                  <div style="font-size : 12px;"><span t-field="o.company_id.street" /> </div>
                  <div style="font-size : 12px;"> <span t-field="o.company_id.country_id" /> <span
                      t-field="o.company_id.zip" /> </div>
                  <div style="font-size : 12px;">Tel : <span t-field="o.company_id.partner_id.phone" /></div>
                  <div style="font-size : 12px;">Fax : <span t-field="o.company_id.fax" /></div>
                </div>
                <div style="font-size : 12px;" class="col-auto">
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      Company Reg No :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-field="o.company_id.vat" />
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      GST Reg No :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-field="o.company_id.company_registry" />
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      DATE :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-esc="o.date.strftime('%d.%m.%Y')" />
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      TAX INVOICE NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-field="o.name" />
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      CUSTOMER PO NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.ref" />
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      QUOTATION NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-esc="o.get_quotation_no()" />
                    </div>

                  </div>

                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      PAYMENT TERMS :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.partner_id.property_payment_term_id" />
                    </div>
                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      FREIGHT TERMS :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.freight_terms" />
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      ORDERED BY :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.partner_id.name" />
                    </div>
                  </div>


                </div>
              </div>
              <br />
              <table style=" font-size : 14px; width:80%; border:1px solid #000;">
                <tr>
                  <th style="border-right: 1px solid #000 !important;">
                    <div style="width:340px;height:130px;">
                      <br />
                      <div class="col-auto" t-if="o.partner_id">
                        <div class="row mt32 mb32">
                          <table style="margin-top:-20px;padding : 15px; width: 100%;">
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Bill To</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id.name" />
                                <span t-else="" t-field="o.partner_id.name" />
                                <span t-field="o.partner_id"
                                  t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}" />
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">C. Person</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <t t-if="o.contact_id">
                                  <span t-field="o.contact_id.name" />
                                </t>
                                <t t-else="">
                                  <span t-field="o.partner_id.name" />
                                </t>
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Telephone</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <t t-if="o.contact_id">
                                  <span t-field="o.contact_id.phone" />
                                </t>
                                <t t-else="">
                                  <span t-field="o.partner_id.phone" />
                                </t>
                              </td>
                            </tr>
                          </table>

                        </div>

                      </div>
                    </div>
                  </th>
                  <th>
                    <div style="width:340px;height:130px;">
                      <br />
                      <div class="col-auto" t-if="o.partner_shipping_id">
                        <div class="row mt32 mb32">
                          <table style="margin-top:-20px;padding : 15px; width: 100%;">
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Ship To</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-if="o.partner_shipping_id.parent_id"
                                  t-field="o.partner_shipping_id.parent_id.name" />
                                <span t-else="" t-field="o.partner_shipping_id.name" />
                                <span t-field="o.partner_shipping_id"
                                  t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}" />
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">C. Person</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.partner_shipping_id.name" />
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Telephone</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.partner_shipping_id.phone" />
                              </td>
                            </tr>
                          </table>

                        </div>

                      </div>
                    </div>
                    <!-- <div style="width:340px;height:120px;">
                                        <br/>
                                          <div class="col-auto" t-if="o.partner_id">
                                            <div class="row mt32 mb32">
                                                <table style="padding : 15px; width: 100%;">
                                                    <tr>
                                                        <td style="padding-left: 10px; text-align:left; font-size:12px;width:80px">Deliver to</td>
                                                        <td style="font-size:12px; padding-left: 5px;">:</td>
                                                        <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                                            <span t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id" t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}"/>
                                                            <span t-else="" t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}"/>
                                                        </td>
                                                    </tr>
                                                </table>
                                              </div>
                                              
                                          </div>
                                      </div> -->
                  </th>
                </tr>
              </table>
              <!-- <br/> -->
              <div style="min-height : 280px">
                <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                  <thead style="font-size : 12px;">
                    <tr style="background-color: lightgrey;">
                      <th name="th_description" style="width:100px" class="text-left"><span>Cust P/N</span></th>
                      <th name="th_desc" style="width:150px" class="text-left"><span>Description</span></th>
                      <!-- <th name="th_desc" style= "width:120px" class="text-center"><span>Est Del Date</span></th> -->
                      <th name="th_qty" style="width:60px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Order Qty</span></th>
                      <th name="th_unit_price" style="width:60px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Unit Price</span></th>
                      <th name="th_total" style="width:80px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Total Amount</span></th>

                    </tr>
                  </thead>
                  <tbody style="font-size : 12px;" class="invoice_tbody">
                    <t t-set="current_subtotal" t-value="0" />
                    <t t-set="line_count" t-value="0" />

                    <t t-set="lines"
                      t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)" />

                    <t t-foreach="lines" t-as="line">
                      <t t-set="line_count" t-value="line_count + 1" />
                      <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                        groups="account.group_show_line_subtotals_tax_excluded" />
                      <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                        groups="account.group_show_line_subtotals_tax_included" />

                      <tr
                        t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else 'line.display_type == line'">
                        <t t-if="not line.display_type" name="account_invoice_line_accountable">
                          <td name="account_invoice_line_name"><span t-field="line.product_id.name" /></td>
                          <td class="text-left"><span t-field="line.name" /></td>
                          <!-- <td class="text-center"><span t-field="line.move_id.est_del_date" t-options="{'widget': 'date'}"/></td> -->
                          <td class="text-right">
                            <span class="text-nowrap" t-esc="'{:.0f}'.format(line.quantity)"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <span class="text-nowrap" t-field="line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                          </td>
                          <td class="text-right">
                            <span class="text-nowrap" t-field="line.price_unit"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <span class="text-nowrap" t-field="line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                          </td>
                          <td class="text-right o_price_total">
                            <span class="text-nowrap" t-field="line.price_subtotal"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <span class="text-nowrap" t-field="line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                          </td>
                        </t>
                        <t t-if="line.display_type == 'line_section'">
                          <td colspan="99">
                            <span t-field="line.name" t-options="{'widget': 'text'}" />
                          </td>
                          <t t-set="current_section" t-value="line" />
                          <t t-set="current_subtotal" t-value="0" />
                        </t>
                        <t t-if="line.display_type == 'line_note'">
                          <td colspan="99">
                            <span t-field="line.name" t-options="{'widget': 'text'}" />
                          </td>
                        </t>
                      </tr>

                      <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                        <tr class="is-subtotal text-right">
                          <td colspan="99">
                            <strong class="mr16">Subtotal</strong>
                            <span t-esc="current_subtotal"
                              t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}" />
                          </td>
                        </tr>
                      </t>
                    </t>
                  </tbody>
                </table>
              </div>
              <!-- <div style="font-size : 12px" class="text-left">Remarks: T/T and correspondent bank charges to be borne by payer</div> -->
              <!--<div style="font-size : 12px; border-bottom: 1px solid black; position: absolute; width : 680px">-->
              <!-- <i>  <span t-field="o.company_id.remarks_header"/></i> -->
              <!--   <br/>-->
              <!--   <i><span style="font-size : 11px; font-style: italic;">For attention: Mc'Coy Components offer to sell product shall be solely in accordance with the standard Terms and Conditions of Sales </span></i>-->
              <!-- </div>-->
              <!-- <div style="font-size : 11px; font-style: italic;" >For attention: Mc'Coy Components offer to sell product shall be solely in accordance with the standard Terms and Conditions of Sales </div> -->
              <!--<t t-if="line_count &lt;= 5">-->

              <!--  </t>-->

              <div class="col-auto" style="page-break-inside: avoid">
                <div class="row mt32 mb32">

                  <div class="col-auto">

                    <div style="margin-left : -15px" class="col-auto">
                      <div><span style="font-size : 10px;"> For overseas customer, kindly T/T the amount due to below
                          McCoy bank details: </span></div>


                      <!-- <div><span style="font-size : 11px; text-decoration: underline;"> Bank Details </span></div> -->
                      <div class="row mt32 mb32">
                        <table style="font-size : 11px; width: 100%;">
                          <tr>
                            <td style="padding-left: 15px" width="150px">USD Account</td>
                            <td width="10px" />
                            <td>
                              <!-- <span t-field="o.currency_id"/>  -->
                            </td>
                          </tr>
                        </table>


                      </div>
                      <div class="row mt32 mb32">
                        <table style="font-size : 11px; width: 100%;">
                          <tr>
                            <td style="padding-left: 15px" width="150px">Beneficiary</td>
                            <td width="10px">:</td>
                            <td>
                              <span t-field="o.company_id.name" />

                            </td>
                          </tr>
                        </table>


                      </div>

                      <div class="row mt32 mb32">
                        <table style="font-size : 11px; width: 100%;">
                          <tr>
                            <td style="padding-left: 15px" width="150px">Bank</td>
                            <td width="10px">:</td>
                            <td>
                              <span>DBS Bank Ltd</span>

                            </td>
                          </tr>
                        </table>



                      </div>
                      <div class="row mt32 mb32">
                        <table style="font-size : 11px; width: 100%;">
                          <tr>
                            <td style="padding-left: 15px" width="150px">Address</td>
                            <td width="10px">:</td>
                            <td>
                              <span>12 Marine Boulevard, Marina Bay Financial Centre</span>
                              <span>Tower 3, DBS, Asia Central, Singapore 018982. </span>

                            </td>
                          </tr>
                        </table>


                      </div>

                      <div class="row mt32 mb32">
                        <table style="font-size : 11px; width: 100%;">
                          <tr>
                            <td style="padding-left: 15px" width="150px">Account No</td>
                            <td width="10px">:</td>
                            <td>
                              <!-- <t t-if="o.currency_id == o.company_id.currency_id">
                                                <span>0109004947 (SGD)</span>
                                              </t>
                                              <t t-if="o.currency_id != o.company_id.currency_id">
                                               <span> 0109004947 (USD)</span>
                                              </t> -->
                              <span> 0003-017698-01-3 (<span t-field="o.currency_id.name" />)</span>
                            </td>
                          </tr>
                        </table>


                      </div>
                      <div class="row mt32 mb32">
                        <table style="font-size : 11px; width: 100%;">
                          <tr>
                            <td style="padding-left: 15px" width="150px">SWIFT Code</td>
                            <td width="10px">:</td>
                            <td>
                              <span>DBSSSGSG</span>

                            </td>
                          </tr>
                        </table>


                      </div>


                    </div>

                    <!--<span t-field="o.company_id.remarks"/>-->

                  </div>

                  <div class="col-auto" style="margin-top : 10px; max-height: 80px;">

                    <table class="table" style="  font-size : 11px; width:80%; float : right; border:1px solid #000;">
                      <tr class="border-black o_total" style="border-bottom: 1px solid #000 !important;">
                        <td
                          style="padding: 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                          <span style="padding-left : 8px;">SUBTOTAL</span></td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <span><span t-field="o.invoice_subtotal" /></span>
                        </td>
                      </tr>
                      <tr style="">
                        <td
                          style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                          <span style="padding-left : 8px;">DISCOUNT
                            <!-- <span t-field="o.percentage_downpayment"/> --> </span></td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <!-- <span><span t-field="o.invoice_downpayment"/></span> -->
                        </td>
                      </tr>
                      <tr style="">
                        <td
                          style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                          <span style="padding-left : 8px;">Freight
                            <!-- <span t-field="o.percentage_downpayment"/> --> </span></td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <!-- <span><span t-field="o.invoice_downpayment"/></span> -->
                        </td>
                      </tr>
                      <tr style="">
                        <td
                          style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                          <span style="padding-left : 8px;">GST 8%</span></td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <t t-foreach="o.amount_by_group" t-as="amount_by_group">
                            <t
                              t-if="len(o.line_ids.filtered(lambda line: line.tax_line_id)) in [0, 1] and o.amount_untaxed == amount_by_group[2]">
                              <span><span class="text-nowrap" t-esc="amount_by_group[3]" /></span>

                            </t>
                            <t t-else="">

                              <span> <span class="text-nowrap" t-esc="amount_by_group[3]" /></span>

                            </t>

                          </t>
                          <!--<span t-field="o.amount_untaxed"/>-->
                        </td>
                      </tr>
                      <tr style="">
                        <td
                          style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                          <!-- <span style="padding-left : 8px;">
                                          <t t-if="o.currency_id == o.company_id.currency_id">
                                                <span>Please Pay (SGD)</span>
                                              </t>
                                              <t t-if="o.currency_id != o.company_id.currency_id">
                                               <span> Please Pay (USD)</span>
                                              </t>

                                        </span> -->
                          <span>Total Amount</span>
                        </td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <span><span class="text-nowrap" t-field="o.amount_total" /></span>
                        </td>
                      </tr>

                    </table>
                    <br />


                  </div>


                  <!--<img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 65px;" alt="Logo"/>-->
                </div>
                <div class="row mt32 mb32" style="page-break-inside: avoid">
                  <div class="col-auto" style="margin-top: -90">
                    <div class="signature">
                      <br />
                      <br />
                      <br />
                      <br />
                      <div>________________________________________________</div>
                      <div style="margin-left: 75px; font-weight : 900;">Authorized Signature</div>

                    </div>
                  </div>
                  <t t-if="o.company_id.name in ['iConnexion Asia Pte Ltd']">
                    <div class="col-auto" style="margin-top: -35px;">
                      <t t-if="o.state in ['posted']">
                        <br />
                        <div class="row mt16 mb16">
                          <div class="col-auto">
                            <img style="width : 90mm; margin-left: -97mm;"
                              src="/iconnexion_custom/static/src/img/keith_signature.png" />
                          </div>
                          <div class="col-auto">
                            <img style="width : 30mm; margin-left: -97mm;"
                              src="/iconnexion_custom/static/src/img/stamp_iconnexion-removebg.png" />
                          </div>
                        </div>
                      </t>
                    </div>
                  </t>
                  <t t-if="o.company_id.name in ['McCoy Pte Ltd']">
                    <div class="col-auto" style="margin-top: -35px;">
                      <t t-if="o.state in ['posted']">
                        <br />
                        <div class="row mt16 mb16">
                          <!--<div class="col-auto">-->
                          <!--  <img style="width : 140mm; margin-left: -124mm;" src="/iconnexion_custom/static/src/img/keith_signature.png"/>-->
                          <!--</div>-->
                          <div class="col-auto">
                            <img style="width : 25mm; margin-left: -63mm;margin-top:5mm;"
