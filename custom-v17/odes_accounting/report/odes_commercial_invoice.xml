                          </div>
                        </div>
                      </t>
                    </div>
                  </t>
                </div>
              </div>

            </div>
          </t>
        </t>
      </t>


    </template>

    <record id="report_commercial_invoice" model="ir.actions.report">
      <field name="name">McCoy - Commercial Invoice</field>
