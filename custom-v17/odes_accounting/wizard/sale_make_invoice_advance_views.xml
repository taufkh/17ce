<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="odes_accounting_view_sale_advance_payment_inv_inherit" model="ir.ui.view">
        <field name="name">odes.accounting.view.sale.advance.payment.inv.inherit</field>
        <field name="model">sale.advance.payment.inv</field>
        <field name="inherit_id" ref="sale.view_sale_advance_payment_inv"/>
