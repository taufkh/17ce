<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_odes_assets_inherit_move_form" model="ir.ui.view">
        <field name="name">odes.account.assets.inherit.form.inherit</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
        <!--<field name="priority">1</field>-->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='acquisition_date']" position="after">
                <field name="location"/>
                <field name="asset_register_no"/>
                
            </xpath>
        </field>
    </record>

    <record id="view_odes_assets_inherit_move_tree" model="ir.ui.view">
        <field name="name">odes.account.assets.inherit.tree.inherit</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_purchase_tree"/>
        <!--<field name="priority">1</field>-->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='book_value']" position="after">
                <field name="location" optional="hide"/>
                <field name="asset_register_no" optional="hide" />
                
            </xpath>
        </field>
    </record>
       
</odoo>