<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_odes_res_company_form" model="ir.ui.view">
        <field name="name">res.company.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <field name="phone" position="after">
                        <field name="fax" />

                    </field>
            <notebook position="inside">
                    
                <page string="Other Config">
                    <group>
                        <group name="Report Invoice" string="Invoice Report Config">
                            <field name="remarks_header"/>
                            <field name="remarks"/>

                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="service_journal_id" domain="[('type', '=', 'sale')]" options="{'no_open': 1, 'no_create': 1}"/>
                        </group>
                        <group>
                            <field name="component_journal_id" domain="[('type', '=', 'sale')]" options="{'no_open': 1, 'no_create': 1}"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>


</odoo>