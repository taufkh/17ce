<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <record id="view_odes_sale_order_form" model="ir.ui.view">
        <field name="name">odes.sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <!--<field name="priority">1</field>-->
        <field name="arch" type="xml">
            <xpath expr="//group[@name='order_details']/field[@name='payment_term_id']" position="after">
                <field name="freight_terms"/>
                

                
            </xpath>

            <xpath expr="//field[@name='order_line']//tree//field[@name='name']" position="after">
                <field name="request_date" optional="hide" />
                <field name="promise_date" optional="hide" />
                
            </xpath>

            <xpath expr="//page[@name='other_information']//group[@name='sale_info']/field[@name='fiscal_position_id']" position="after">
                <field name="request_date" widget="date"/>
                <field name="promise_date" widget="date"/>
            </xpath>
            <notebook position="inside">
                <page string="Forecasted Invoice Information" name="forecasted_info" >
                    <group string="Forecasted Invoice">
                            
                            <field nolabel="1" name="invoice_forecats_line_ids">
                                <tree editable="bottom">
                                    <field name="date_invoice" required="1" widget="date"/>
                                    <field name="amount" required="1" />
                                    
                                </tree>
                            </field>
                            
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>