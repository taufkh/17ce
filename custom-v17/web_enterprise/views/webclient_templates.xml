<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="webclient_bootstrap" inherit_id="web.webclient_bootstrap" name="web_enterprise bootstrap compatibility">
        <xpath expr="//t[@t-set='body_classname']" position="attributes">
            <attribute name="t-value">'o_web_client o_web_enterprise_compat'</attribute>
        </xpath>
    </template>
</odoo>
