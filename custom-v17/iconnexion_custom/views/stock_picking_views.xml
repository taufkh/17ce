<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_icon_stock_picking_form" model="ir.ui.view">
        <field name="name">icon.stock.picking.form.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>        
        <field name="arch" type="xml">            
            <xpath expr="//field[@name='move_ids_without_package']//tree//field[@name='product_id']" position="after">
                <field name="name" groups="iconnexion_custom.group_iconnexion_company" string="CPN"/>  
                <field name="customer_part_number" groups="iconnexion_custom.group_iconnexion_company" invisible="1"/>     
            </xpath>
        </field>
    </record>

    <record id="view_icon_stock_move_line_detailed_operation" model="ir.ui.view">
        <field name="name">icon.stock.move.line.form.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>        
        <field name="arch" type="xml">        
            <xpath expr="//field[@name='product_id']" position="before">
                <field name="serial_numbers"/>
            </xpath>
        </field>
    </record>
</odoo>