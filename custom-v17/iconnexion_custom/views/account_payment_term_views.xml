<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_payment_term_form_inherit" model="ir.ui.view">
        <field name="name">payment.term.form.inherit</field>
        <field name="model">account.payment.term</field>
        <field name="inherit_id" ref="account.view_payment_term_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="Pro-Forma Invoice">
                        <group id="header_left_group">
                            <field name="payment_term_type" string="Payment Term Type"/>
                            <field name="dep_paid_1st" string="1st Dep Paid (%)" invisible="payment_term_type not in ('partial_before_delivery_term', 'partial_cod_term')"/>
                            <field name="dep_paid_2nd" string="2nd Dep Paid (%)" invisible="payment_term_type not in 'partial_before_delivery_term'"/>
                        </group>
                        <group id="header_right_group">
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>