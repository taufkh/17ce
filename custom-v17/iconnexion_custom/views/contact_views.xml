<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="contacts.action_contacts" model="ir.actions.act_window">
        <field name="name">Contacts</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form,activity</field>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
        <!-- <field name="domain">[('company_id', 'in', allowed_company_ids)]</field> -->
        <field name="context">{'default_is_company': True,'disable_search':True}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create a contact in your address book
          </p><p>
            ODES helps you to easily track all activities related to a customer.
          </p>
        </field>
    </record>

    <record id="icon_res_partner_search_view" model="ir.ui.view">
        <field name="name">res.partner</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter" />
        <field name="arch" type="xml">
            <filter name="type_person" position="before">
                <filter string="Customer" name="customer_rank" domain="[('customer_rank', '>', 0)]" />
                <filter string="Vendor" name="supplier_rank" domain="[('supplier_rank', '>', 0)]" />
               
            </filter>
        </field>
    </record>
    <record id="icon_view_partner_tree_view" model="ir.ui.view">
        <field name="name">res.partner</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree" />
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="export_xlsx">0</attribute>               
            </xpath>
        </field>
    </record>


  </odoo>