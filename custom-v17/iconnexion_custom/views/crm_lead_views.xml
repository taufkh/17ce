            <tree string="iCon Type" editable="bottom">                
                <field name="name" required="1"/>
                <field name="notes" />
                <field name="type" invisible="1"/>
            </tree>
        </field>
    </record>
    
    <record id="icon_lead_type_action" model="ir.actions.act_window">
