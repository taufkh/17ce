    <menuitem id="menu_icon_lead_type3_act" parent="crm.menu_crm_config_lead" sequence="99" name="Business Activity" action="icon_lead_type3_action" groups="group_iconnexion_business_activity,group_iconnexion_company"/>

    <record id="icon_lead_type4_action" model="ir.actions.act_window">
        <field name="name">iCon Type</field>
        <field name="res_model">iconnexion.lead.type</field>
        <field name="view_id" ref="icon_lead_type_tree"/>
        <field name="domain">[('type', '=', 'bidding')]</field> 
         <field name="context" eval="{
