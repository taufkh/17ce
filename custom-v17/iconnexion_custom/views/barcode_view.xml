<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- v16: stock_barcode is Enterprise-only (not available in Community).
         This view override is disabled. The custom fields (coo, dc, dimension_*, weight)
         are still accessible via the standard stock.move.line form (see records below).
    <record id="stock_barcode.stock_move_line_product_selector" model="ir.ui.view">
        <field name="name">stock.product.selector</field>
        <field name="model">stock.move.line</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form string="Select a Product" class="o_barcode_line_form">
                ...
            </form>
        </field>
    </record>
    -->
    <record id="stock.view_stock_move_operations" model="ir.ui.view">
        <field name="name">stock.move.operations.form</field>
        <field name="model">stock.move</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form string="Move Detail">
                <field name="sequence" invisible="1" />
                <field name="company_id" invisible="1" />
                <field name="state" invisible="1" />
                <field name="location_id" invisible="1" />
                <field name="location_dest_id" invisible="1" />
                <field name="picking_id" invisible="1" />
                <field name="is_locked" invisible="1" />
                <field name="picking_type_entire_packs" invisible="1" />
                <field name="display_assign_serial" invisible="1" />
                <group>
                    <group>
                        <field name="product_id" readonly="1" />
                        <label for="product_uom_qty" />
                        <div class="o_row">
                            <span>
                                <field name="product_uom_qty" readonly="1" nolabel="1" /></span>
                            <span>
                                <field name="product_uom" readonly="1" nolabel="1" /></span>
                        </div>
                        <label for="quantity_done" />
                        <div class="o_row">
                            <span>
                                <field name="quantity_done" readonly="1" nolabel="1" /></span>
                            <span invisible="state == 'done'"> / </span>
                            <span>
                                <field name="reserved_availability" nolabel="1"
                                    invisible="state == 'done'" /></span>
                            <span>
                                <field name="product_uom" readonly="1" nolabel="1" /></span>
                            <span>
                                <field name="is_iconnexion" readonly="1" nolabel="1" invisible="1" /></span>
                        </div>
                        <field name="next_serial" invisible="not display_assign_serial" />
                        <label for="next_serial_count" invisible="not display_assign_serial" />
                        <div class="o_row" invisible="not display_assign_serial">
                            <span>
                                <field name="next_serial_count" /></span>
                            <button name="action_assign_serial_show_details" type="object" class="btn-link"
                                title="Assign Serial Numbers">
                                <span>Assign Serial Numbers</span>
                            </button>
                        </div>
                    </group>
                </group>
                <field name="move_line_ids"
                    readonly="state == 'cancel' or (state == 'done' and is_locked)"
                    context="{'tree_view_ref': 'stock.view_stock_move_line_operation_tree', 'default_product_uom_id': product_uom, 'default_picking_id': picking_id, 'default_move_id': id, 'default_product_id': product_id, 'default_location_id': location_id, 'default_location_dest_id': location_dest_id, 'default_company_id': company_id}" />
                <footer class="oe_edit_only"
                    invisible="state == 'cancel' or (state == 'done' and is_locked)">
                    <button string="Confirm" special="save" class="oe_highlight" />
                    <button string="Discard" special="cancel" />
                </footer>
                <footer class="oe_edit_only"
                    invisible="(state != 'cancel' and state != 'done') or (state == 'done' and not is_locked)">
                    <button string="Close" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="stock_move_line_product_selector_form_inherit" model="ir.ui.view">
        <field name="name">stock.move.line.product.selector.form.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form" />
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='origin']" position="replace">
                    <field name="origin" invisible="is_iconnexion" />
                    <field name="source_po_id" invisible="not is_iconnexion" />
                </xpath>
                <xpath expr="//field[@name='lot_id']" position="after">
                    <label for="dimension_length"/>
                    <div name="dimension_length_cm" class="o_row">
                        <field name="dimension_length"/>
                        <span class="oe_read_only">CM</span>
                    </div>
                    <label for="dimension_width"/>
                    <div name="dimension_width_cm" class="o_row">
                        <field name="dimension_width"/>
                        <span class="oe_read_only">CM</span>
                    </div>
                    <label for="dimension_height"/>
                    <div name="dimension_height_cm" class="o_row">
                        <field name="dimension_height"/>
                        <span class="oe_read_only">CM</span>
                    </div>
                    <field name="weight"/>
                    <field name="coo"/>
                    <field name="dc"/>
                    <field name="no" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='reference']" position="replace">
                    <field name="picking_id" string="Reference" invisible="0"/>
                </xpath>

            </data>
        </field>
    </record>

    <record id="view_stock_move_line_operation_tree" model="ir.ui.view">
        <field name="name">stock.move.line.operations.tree</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="before">
                <field name="coo" />
                <field name="dc" />
            </xpath>
            <xpath expr="//field[@name='lot_name']" position="after">
                <!-- v16: invisible with Python expressions not in RELAXNG schema.
                     Use optional="show/hide" so users can toggle columns as needed.
                     dimension = combined LxWxH (for non-iconnexion), shown by default.
                     dimension_length/width/height = separate fields (for iconnexion), hidden by default. -->
                <field name="dimension" optional="show" />
                <field name="dimension_length" optional="hide" />
                <field name="dimension_width" optional="hide" />
                <field name="dimension_height" optional="hide" />
                <field name="weight" />
                <field name="is_iconnexion" invisible="1" />
                <field name="no" invisible="1" />
            </xpath>
        </field>
    </record>

    <!-- 
view_stock_move_nosuggest_operations

 <field name="move_line_nosuggest_ids" readonly="state == 'cancel' or (state == 'done' and is_locked)" context="{'tree_view_ref': 'stock.view_stock_move_line_operation_tree','default_picking_id': picking_id, 'default_move_id': id, 'default_product_id': product_id, 'default_location_id': location_id, 'default_location_dest_id': location_dest_id, 'default_company_id': company_id}"/> -->

</odoo>
