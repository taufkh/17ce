    <record id="odes_view_order_form_inherit" model="ir.ui.view">
        <field name="name">odes.sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="odes_custom.odes_view_order_form_inherit" />
        <field name="arch" type="xml">
            <header position="inside">
                <field name="is_proforma_invoice" invisible="1"/>
                <field name="is_generate_proforma_to_process" invisible="1"/>
                <field name="is_generate_proforma" invisible="1"/>
                <field name="is_generate_proforma_partial" invisible="1"/>
                <field name="is_generate_proforma_partial_before_delivery" invisible="1"/>
                <button name="button_quote_crm" string="Quote From CRM"
                    invisible="not opportunity_id" type="object" class="btn-primary"
                    groups="sales_team.group_sale_salesman" />
                <!-- <button name="button_create_pi" string="Create PI" type="object" class="btn-primary"/> -->
                <button name="button_create_pi" string="Create PI" type="object" class="btn-primary" invisible="(is_proforma_invoice or not is_generate_proforma_to_process) or state == 'sale'"/>
                <button name="button_create_pi" string="Create PI" type="object" class="btn-primary" invisible="(is_proforma_invoice or not is_generate_proforma) or state != 'sale'"/>
                <button name="button_create_pi" string="Create PI" type="object" class="btn-primary" invisible="(is_proforma_invoice or not is_generate_proforma_partial_before_delivery) or state != 'sale'"/>
                <button name="button_create_pi" string="Create PI" type="object" class="btn-primary" invisible="(is_proforma_invoice or not is_generate_proforma_partial) or state != 'draft'"/>
                <button name="button_create_pi" string="Create PI" type="object" class="btn-primary" invisible="(is_proforma_invoice or not is_generate_proforma_partial_before_delivery) or state != 'draft'"/>
            </header>
            <!-- v17: inject stat buttons directly inside button box for stable xpath -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">

                <button name="preview_pinvoice" type="object" class="oe_stat_button" icon="fa-paste" invisible="proforma_invoice_count == 0">
                    <div class="o_stat_info">
                        <field name="proforma_invoice_count" class="o_stat_value"/>
                        <span class="o_stat_text">Pro-Forma</span>
                        <span class="o_stat_text">Invoice</span>
                    </div>
                </button>
                <button name="preview_pinvoice_so" type="object" class="oe_stat_button" icon="fa-paste" invisible="proforma_invoice_count_so == 0 or is_proforma_invoice">
                    <div class="o_stat_info">
                        <field name="proforma_invoice_count_so" class="o_stat_value"/>
                        <span class="o_stat_text">Pro-Forma</span>
                        <span class="o_stat_text">Invoice</span>
                    </div>
                </button>
            </xpath>

            <!-- <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][1]" position="attributes">
                <attribute name="invisible">is_iconnexion</attribute>



            </xpath>
            <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][2]" position="attributes">
                <attribute name="invisible">1</attribute>

            </xpath> -->
            <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                <attribute name="invisible">not is_iconnexion</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="invisible">not is_iconnexion</attribute>
            </xpath>
            <xpath expr="//page[@name='mccoy_info']" position="attributes">
                <attribute name="string">Other Information</attribute>
            </xpath>
            <xpath expr="//page[@name='mccoy_info']" position="attributes">

            </xpath>
            <xpath expr="//field[@name='min_order']" position="after">
                <field name="bank_charges" invisible="not is_iconnexion" />
                <field name="is_iconnexion" invisible="1" />
                <field name="is_pi_clear" invisible="1" />
                <field name="is_generate_proforma_to_process" invisible="1" />
                <field name="is_generate_proforma" invisible="1" />
                <field name="is_proforma_invoice" invisible="0" />
                <field name="proforma_number" invisible="1" />

            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="contact_id" domain="[('parent_id','=',partner_id)]"
                    context="{'default_parent_id': partner_id,'form_view_ref': 'iconnexion_custom.view_partner_form3','mail_create_nolog':True}"
                    widget="res_partner_many2one" />
                <field name="invoice_address_selection"/>
                <field name="delivery_address_selection"/>
            </xpath>
            <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='mccoy_info']/group/group" position="inside">
                <field name="reason" string="Reason Lower Margin" readonly="1" invisible="1" />
                <field name="is_lower_margin" invisible="1" />

            </xpath>

        </field>
    </record>
