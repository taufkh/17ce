    <record id="sale_order_line_payment_tree" model="ir.ui.view">
        <field name="name">sale.order.line.payment</field>
        <field name="model">sale.order.line</field>
        <!-- v16: type="html" → type="xml" to avoid HTML parser issues -->
        <field name="arch" type="xml">
            <tree string="Matching of Payment Data" create="false">
                <field name="create_date" optional="show" />
                <field name="create_uid" optional="show" />
                <field name="order_id" optional="show" />
                <field name="client_order_ref_rel" optional="show" />
                <field name="order_partner_id" optional="show" />
                <field name="product_id" string="MPN" optional="show" />
                <field name="name" string="CPN" optional="show" />
                <field name="salesman_id" optional="show" widget="many2one_avatar_user" />
                <field name="product_uom_qty" optional="show" />
                <field name="product_uom" optional="show" />
                <field name="product_uom_category_id" optional="show" invisible="1" />
                <field name="quote_price_unit" optional="show" />
                <field name="price_subtotal" sum="Total" widget="monetary" optional="show" />
                <field name="currency_id" invisible="1" optional="show" />
                <field name="company_id" optional="show" />
                <field name="state" decoration-success="state == 'sale' or state == 'done'"
                    decoration-info="state == 'draft' or state == 'sent'" widget="badge" optional="show" />
                <field name="payment_state" optional="show" widget="badge"
                    decoration-danger="payment_state == 'not_paid'"
                    decoration-warning="payment_state in ('partial', 'in_payment')"
                    decoration-success="payment_state in ('paid', 'reversed')" />
            </tree>
        </field>
    </record>


