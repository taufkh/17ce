    <record id="sale_order_icon_tree" model="ir.ui.view">
        <field name="name">sale.order.icon.tree</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <tree string="Sale Order Lines" create="false">
                <field name="name" readonly="1" />
                <field name="client_order_ref" readonly="1" />
            </tree>
        </field>
    </record>
    <record id="view_icon_order_form" model="ir.ui.view">
        <field name="name">sale.order.icon.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <!-- Ensure boolean used by form modifiers is always available in the view -->
            <xpath expr="//sheet" position="inside">
                <field name="is_iconnexion" invisible="1" />
                <field name="is_sale_view" invisible="1" />
            </xpath>
            <header position="inside">
                <!-- v16: states attribute deprecated → use invisible expression -->
                <button name="print_icon_quotation" string="Print Quotation" type="object"
                    invisible="state not in ('draft', 'sent', 'done')"
                    groups="iconnexion_custom.group_iconnexion_company" class="btn-primary" />
                <button name="print_icon_so" string="Print Sale Order" type="object"
                    invisible="state != 'sale'"
                    groups="iconnexion_custom.group_iconnexion_company" class="btn-primary" />
            </header>
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_uom_qty']" position="before">
                <!-- v16: invisible removed (not in RELAXNG schema); optional preserves default visibility -->
                <field name="customer_request_date" optional="hide" />
                <field name="committed_date" optional="hide" />
                <field name="icon_scheduled_date" optional="show" />
                <field name="icpo_request_deliver_date" invisible="1" />
            </xpath>
            <!-- v16: promise_date and request_date removed from sale.order.line tree in v16 -->
            <!-- <xpath expr="//field[@name='order_line']//tree//field[@name='promise_date']" position="replace">
                <field name="promise_date" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='request_date']" position="replace">
                <field name="request_date" invisible="1" />
            </xpath> -->
            <xpath expr="//field[@name='order_line']//tree//field[@name='is_downpayment']" position="before">
                <field name="serial_numbers" />
                <field name="is_special_price" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='name']" position="after">
                <field name="current_stock" string="Buffer Stock" digits="[42,2]" />
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='price_unit']" position="after">
                <field name="icon_sale_price" invisible="1" />
                <!-- v16: moq_id disabled (mccoy.product.moq not available) -->
                <!-- <field name="moq_id" invisible="1" /> -->
                <!-- v16: invisible removed; optional="hide" = hidden by default (iconnexion-specific columns) -->
                <field name="moq"
                    readonly="state != 'draft'"
                    optional="show" />
                <field name="spq"
                    readonly="state != 'draft'"
                    optional="show" />
                <field name="a_moq" invisible="1" />
                <field name="a_spq" invisible="1" />
                <field name="ar_code" invisible="1" />
                <field name="r_code" readonly="1" optional="hide" />
                <field name="sale_delay"
                    readonly="state != 'draft'"
                    string="Lead Time" optional="hide" />
                <field name="brand" readonly="1" optional="show" />
                <field name="quote_price_unit" optional="show" string="U/P" />
                <field name="s_margin" invisible="1" />
                <field name="s_margin_char" string="S. Margin" optional="hide" />
                <field name="is_iconnexion" invisible="1" />
                <field name="reason" invisible="1" />
                <field name="is_lower_margin" invisible="1" />
                <field name="is_request_margin" invisible="1" />
                <field name="approve_user_id" invisible="1" />

            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='price_subtotal']" position="after">
                <button name="%(iconnexion_custom.action_icon_quotation_reason_wizard)d" type="action"
                    string="New Pricing Request"
                    invisible="not is_lower_margin or is_request_margin"
                    class="btn-primary" />
                <button name="%(iconnexion_custom.action_icon_quotation_approve_wizard)d" type="action"
                    string="View Request" invisible="not is_request_margin" class="btn-primary"
                    groups="iconnexion_custom.group_iconnexion_sales_manager" />
            </xpath>

            <xpath expr="//field[@name='order_line']//form//field[@name='tax_id']" position="after">
                <field name="icon_purchase_id" optional="show" />
                <field name="icon_purchase_ids" optional="show" widget="many2many_tags" />
                <field name="customer_request_date" optional="show"
                    invisible="not parent.is_sale_view" />
                <field name="icpo_request_deliver_date" optional="show"
                    invisible="not parent.is_sale_view" />
                <field name="delivery_date" optional="show"
                    invisible="not parent.is_sale_view" />
                <!-- v16: invisible is invalid in form subviews; use invisible instead -->
                <field name="icon_scheduled_date" invisible="not parent.is_sale_view"
                    optional="show" />

            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='name']" position="attributes">

                <attribute name="string">CPN</attribute>
            </xpath>
            <!-- v16: invisible with expression not in RELAXNG schema for tree fields.
                 Use optional="hide" so these columns are hidden by default (iconnexion uses
                 quote_price_unit/U/P instead of price_unit, and hides uom/lead-time columns). -->
            <xpath expr="//field[@name='order_line']//tree//field[@name='price_unit']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']//tree//field[@name='tax_id']" position="attributes">

            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_uom']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='customer_lead']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_uom_qty']" position="attributes">
                <attribute name="string">Order Qty</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_id']" position="attributes">
                <attribute name="string">MPN</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_id']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='price_total']" position="attributes">
                <attribute name="string">Total Price</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//tree//field[@name='product_template_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- <xpath expr="//notebook/page/field/form/div[@name='invoice_lines']" position="after">
                <div name="sales_history_ids">
                    <label for="sales_history_ids"/>
                    <field name="sales_history_ids">
                        <tree>
                            <field name="currency_id" invisible="1"/>
                            <field name="date" widget="date"/>
                            <field name="order_id" optional="hide"/>
                            <field name="partner_id" optional="hide"/>
                            <field name="user_id" optional="hide"/>
                            <field name="product_id"/>
                            <field name="qty"/>
                            <field name="price_unit" digits="[42,4]" options="{'currency_field': 'currency_id'}"/>
                            <field name="price_subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/> 
                        </tree>
                    </field>
                </div>
            </xpath> -->


            <xpath expr="//page[@name='order_lines']" position="after">
                <page name="so_analyze" string="Order Analysis"
                    groups="iconnexion_custom.group_iconnexion_sales_manager"
                    invisible="not is_iconnexion">
                    <field name="sale_order_line_analyze_ids">
                        <tree editable="bottom" create="0" delete="0">
                            <field name="name" readonly="1" invisible="1" />
                            <field name="product_id" readonly="1" string="Code" />
                            <field name="product_uom_qty" readonly="1" string="Order Qty" />
                            <field name="a_moq" readonly="1" />
                            <field name="a_spq" readonly="1" />
                            <field name="ar_code" readonly="1" />
                            <field name="icon_sale_price" invisible="1" />
                            <field name="quote_price_unit" readonly="1" string="U/P" />
                            <field name="s_margin_char" readonly="1" string="S. Margin" />
                            <field name="price_unit" invisible="1" />
                            <field name="price_subtotal" invisible="1" />
                            <field name="cost_price" readonly="1"
                                groups="iconnexion_custom.group_iconnexion_sales_manager" />
                            <field name="a_margin_char" readonly="1" string="A. Margin" />
                            <field name="total_a_margin" readonly="1" string="Total A. Margin" />
                        </tree>
                    </field>
                </page>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="attachment_count" invisible="1" />
            </xpath>

            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="attachment_ids" widget="many2many_binary" />
            </xpath>

            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="readonly">state in ('done', 'cancel', 'quote_lock')</attribute>
            </xpath>

            <xpath expr="//button[@name='action_cancel']" position="before">
                <button name="action_confirm" id="action_confirm" string="Confirm" class="btn-primary" type="object"
                    invisible="state not in ('quote_lock')" />
            </xpath>

            <xpath expr="//button[@name='action_cancel']" position="attributes">
                <attribute name="invisible">(state not in ["draft", "sent", "sale", "quote_lock"]) or (not id)</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <!-- <field name="select_address" invisible="not is_iconnexion" /> -->
                <field name="bill_to_street" invisible="not is_iconnexion" />
                <field name="bill_to_block" string="" invisible="not bill_to_block" />
                <field name="bill_to_city" string="" invisible="not bill_to_city" />
                <field name="bill_to_state" string="" invisible="not bill_to_state" />
                <field name="bill_to_zip" string="" invisible="not bill_to_zip" />
                <field name="bill_to_country_id" string=""
                    invisible="not bill_to_country_id" />
                <field name="bill_to_remarks" string="" invisible="not bill_to_remarks" />
                <field name="bill_to_contact_person" invisible="1"/>
                <field name="ship_to_street" invisible="not is_iconnexion" />
                <field name="ship_to_block" string="" invisible="not ship_to_block" />
                <field name="ship_to_city" string="" invisible="not ship_to_city" />
                <field name="ship_to_state" string="" invisible="not ship_to_state" />
                <field name="ship_to_zip" string="" invisible="not ship_to_zip" />
                <field name="ship_to_country_id" string=""
                    invisible="not ship_to_country_id" />
                <field name="ship_to_remarks" string="" invisible="not ship_to_remarks" />
                <field name="bill_to_contact_person" invisible="1"/>
                <field name="is_sale_view" widget="boolean_toggle" />
                <field name="client_order_ref" invisible="not is_sale_view" />
            </xpath>

        </field>
    </record>

