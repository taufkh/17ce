<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_committed_date_tree" model="ir.ui.view">
        <field name="name">icon.committeddate.history.tree</field>
        <field name="model">icon.committeddate.history</field>
        <field name="arch" type="xml">
            <tree string="date" create="false">
                <field name="date" />
                <field name="change_reason" />
            </tree>
        </field>
    </record>
    <record id="view_order_product_tree" model="ir.ui.view">
        <field name="name">sale.report.tree</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <tree string="Sales Analysis">
                <field name="product_tmpl_id" />
                <field name="product_brand_id" />
                <field name="product_uom_qty" />
                <field name="qty_delivered" />
                <field name="qty_invoiced" />

                <field name="date" />
                <field name="price_subtotal" />
                <field name="state" />
            </tree>
        </field>
    </record>
    <record id="icon_sale_report_action" model="ir.actions.act_window">
        <field name="name">Sale Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_order_product_tree" />
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">

            </p>
            <p>

            </p>
        </field>
    </record>

    <record id="sale_view_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.view.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <!-- v16: groups_id on inherited view not allowed; removed -->
        <field name="arch" type="xml">
            <field name="name" position="attributes">
                <attribute name="readonly">1</attribute>
            </field>
        </field>
    </record>

    <record id="view_icon_order_line_tree" model="ir.ui.view">
        <field name="name">sale.order.line.tree</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <tree string="Sales Order Lines" create="1">
                <field name="create_date" invisible="0" optional="show" readonly="1" />
                <field name="create_uid" invisible="0" optional="show" readonly="1" />
                <field name="order_id" optional="show" />
                <field name="client_order_ref_rel" optional="show" />
                <field name="order_partner_id" optional="show" />
                <field name="supplier_name_id" optional="show" />
                <field name="product_id" string="MPN" optional="show" />
                <field name="is_special_price" string="Special" optional="show" invisible="1" />
                <field name="name" string="CPN" optional="show" />
                <field name="committed_date" optional="show" />
                <field name="customer_request_date2" optional="show" />
                <field name="customer_request_date" widget="remaining_days" string="Aging Date" optional="show" />
                <field name="icon_scheduled_date" optional="show" />
                <field name="salesman_id" optional="show" />
                <field name="product_uom_qty" string="Qty" optional="show" />
                <field name="qty_delivered" optional="show" />
                <field name="qty_invoiced" optional="show" />
                <field name="qty_to_invoice" optional="show" />
                <field name="product_uom" string="Unit of Measure" groups="uom.group_uom" optional="show" />
                <field name="quote_price_unit" string="Unit Price" optional="show" />
                <field name="price_subtotal" sum="Total" widget="monetary" optional="show" />
                <field name="currency_id" invisible="1" optional="show" />
                <field name="state" optional="show" />
                <button name="action_committed_history_wizard" string="Change Committed Date" type="object"
                    class="btn-primary" />
                <button name="action_view_history_wizard" string="View History" type="object" class="btn-primary" />

            </tree>
        </field>
    </record>

    <record id="view_icon_picklist_order_line_tree" model="ir.ui.view">
        <field name="name">picklist.sale.order.line.tree</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <tree string="Sales Order Lines" editable="bottom" create="false">
                <field name="create_date" invisible="0" optional="show" readonly="1" />
                <field name="create_uid" invisible="0" optional="show" readonly="1" />
                <field name="order_id" optional="show" readonly="1" />
                <field name="client_order_ref_rel" optional="show" readonly="1" />
                <field name="order_partner_id" optional="show" readonly="1" />
                <field name="supplier_name_id" optional="show" readonly="1" />
                <field name="product_id" string="MPN" optional="show" readonly="1" />
                <field name="name" string="CPN" optional="show" readonly="1" />
                <field name="committed_date" optional="show" readonly="1" />
                <field name="customer_request_date2" optional="show" readonly="1" />
                <field name="customer_request_date" widget="remaining_days" string="Aging Date" optional="show"
                    readonly="1" />
                <field name="icon_scheduled_date" optional="show" readonly="1" />
                <field name="salesman_id" optional="show" readonly="1" />
                <field name="product_uom_qty" string="Qty" optional="show" readonly="1" />
                <field name="qty_delivered" optional="show" readonly="1" />
                <field name="qty_invoiced" optional="show" readonly="1" />
                <field name="qty_to_invoice" optional="show" readonly="1" />
                <field name="product_uom" string="Unit of Measure" groups="uom.group_uom" optional="show"
                    readonly="1" />
                <field name="quote_price_unit" string="Unit Price" optional="show" readonly="1" />
                <field name="price_subtotal" sum="Total" widget="monetary" optional="show" readonly="1" />
                <field name="currency_id" invisible="1" optional="show" readonly="1" />
                <field name="state" optional="show" readonly="1" />
                <field name="is_pick" readonly="0" />
                <button name="action_committed_history_wizard" string="Change Committed Date" type="object"
                    class="btn-primary" />
                <button name="action_view_history_wizard" string="View History" type="object" class="btn-primary" />

            </tree>
        </field>
    </record>

    <record id="sale_order_line_view_search" model="ir.ui.view">
        <field name="name">sale.order.line.select</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <search string="Search Sale Order">
                <field name="order_id" string="Order Reference" filter_domain="[('order_id.name', 'ilike', self)]" />
                <field name="order_id" string="Source Document" filter_domain="[('order_id.origin', 'ilike', self)]" />
                <filter string="Order" name="Sale Order" domain="[('order_id.state', '=', 'sale')]" />
                <field name="name" string="CPN" />
                <field name="product_id" string="MPN" />
                <!-- v16: product_qty renamed to product_uom_qty -->
                <field name="product_uom_qty" string="Qty" />
                <field name="order_id" string="Customer" filter_domain="[('order_id.partner_id', 'ilike', self)]" />
                <field name="icpo_request_deliver_date" string="Iconn Request Date" />
            </search>
        </field>
    </record>
    <record id="icon_sale_order_line_action" model="ir.actions.act_window">
        <field name="name">Sale Orders Line</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order.line</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_icon_order_line_tree" />
        <field name="domain">[]</field>
        <field name="search_view_id" ref="sale_order_line_view_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">

            </p>
            <p>

            </p>
        </field>
    </record>
    <record id="icon_picklist_sale_order_line_action" model="ir.actions.act_window">
        <field name="name">Picklist</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order.line</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_icon_picklist_order_line_tree" />
        <field name="domain">[('company_id', '=', 3)]</field>
        <field name="search_view_id" ref="sale_order_line_view_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">

            </p>
            <p>

            </p>
        </field>
    </record>
    <menuitem id="icon_item_sale_order_line" name="Sale Order Line"
        action="iconnexion_custom.icon_sale_order_line_action" parent="sale.sale_order_menu"
        groups="sales_team.group_sale_salesman" sequence="7" />

    <menuitem id="icon_picklist_sale_order_line" name="Picklist"
        action="iconnexion_custom.icon_picklist_sale_order_line_action" parent="sale.sale_order_menu" sequence="8" />

    <record id="action_quotations_with_onboarding_current" model="ir.actions.act_window">
        <field name="name">Quotations (Current)</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order</field>
        <field name="view_id" ref="sale.view_quotation_tree_with_onboarding" />
        <field name="view_mode">tree,kanban,form,calendar,pivot,graph,activity</field>
        <field name="search_view_id" ref="sale.sale_order_view_search_inherit_quotation" />
        <field name="context">{'search_default_is_current': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new quotation, the first step of a new sale!
            </p>
            <p>
                Once the quotation is confirmed by the customer, it becomes a sales order.<br /> You will be able to
                create an invoice and collect the payment.
            </p>
        </field>
    </record>

    <menuitem id="menu_sale_quotations_current" action="action_quotations_with_onboarding_current"
        parent="sale.sale_order_menu" sequence="1" groups="sales_team.group_sale_salesman" />

    <record id="view_proforma_invoice_tree" model="ir.ui.view">
        <field name="name">sale.order.tree</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree" />
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- v16: invisible not in RELAXNG schema for tree views → use invisible instead -->
            <!-- parent view already has string="Number" readonly="1" decoration-bf="1" on name field -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="proforma_number" />
            </xpath>
        </field>
    </record>




