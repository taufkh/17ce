<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead2opportunity_partner" model="ir.ui.view">
        <field name="name">odes.crm.lead2opportunity.partner.inherit</field>
        <field name="model">crm.lead2opportunity.partner</field>
        <field name="inherit_id" ref="odes_custom.view_crm_lead2opportunity_partner"/>
        <field name="arch" type="xml">        
             <xpath expr="//field[@name='end_product_id']" position="after">
                <field name="end_partner_char"  />
            </xpath>
            <xpath expr="//field[@name='odes_part_ids']" position="replace">
               <field name="odes_part_ids">
                        <tree editable="bottom">
                            <field name="name" required="1"/>
                            <field name="manufacture" required="1"/>
                            <field name="price" required="1"/>
                            <field name="product_id"/>
                            <field name="competitor_information"/>
                            <field name="quoted_price"/>
                            <field name="competitor_mpn"/>
                            <field name="competitor_pricing"/>
                            <field name="competitor_moq"/>
                            <field name="icon_date"/>
                        </tree>
                    </field>
            </xpath>            
        </field>
    </record>
</odoo>