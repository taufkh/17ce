<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="icon_select_company_wizard" model="ir.ui.view">
        <field name="name">icon.select.company.wizard</field>
        <field name="model">icon.select.company.wizard</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Select Company">
                <group>
                    <group invisible="0">
                        <field name="companys"  options="{'no_create': 1,'no_open':1}"/>
                    </group>                    
                </group>
                <footer>
                    <button name="button_change" type="object" class="oe_highlight" string="Confirm"/>
                </footer>
            </form>
        </field>
    </record>
     <record id="action_icon_select_company_wizard" model="ir.actions.act_window">
        <field name="name">Change Company</field>
        <field name="res_model">icon.select.company.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
   <!--  <record id="action_icon_select_company_wizard" model="ir.actions.server">
