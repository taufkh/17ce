                              <!--<td class="text-center">-->
                              <!--    <span class="text-nowrap" t-esc="o.get_usd_value(line.quote_price_unit)" groups="account.group_show_line_subtotals_tax_excluded" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 3}"/>-->
