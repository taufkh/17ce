                                <!--<span class="text-nowrap" t-esc="o.get_usd_total_value(line.quote_price_unit, line.product_uom_qty)" groups="account.group_show_line_subtotals_tax_excluded" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 3}"/>-->
                                <!--<span class="text-nowrap" t-esc="o.get_usd_value(line.price_total)" groups="account.group_show_line_subtotals_tax_included" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 3}"/>-->
                                <!--<t t-set="sgd_subtotal" t-value="sgd_subtotal+o.get_usd_total_value(line.quote_price_unit, line.product_uom_qty)"/>-->
                              </td>
                              <td class="text-center o_lead_time">
                                <span t-esc="int(line.sale_delay)" /> Wks
                              </td>
                            </t>
                            <t t-if="line.display_type == 'line_section'">
