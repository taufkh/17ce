              <div style="min-height : 280px">
                <table style=" margin-top : 8px;" class="table table-sm o_main_table"
                  name="invoice_line_table">
                  <thead style="font-size : 12px;">
                    <tr style="background-color: lightgrey;">
                      <th name="th_description" style="width:100px" class="text-left">
                        <span>Cust P/N</span>
                      </th>
                      <th name="th_desc" style="width:150px" class="text-left">
                        <span>MPN</span>
                      </th>
                      <th name="th_req_date" style="width:120px" class="text-right">
                        <span>Cust Req Date</span>
                      </th>
                      <th name="th_pro_date" style="width:120px" class="text-right">
                        <span>Est Del Date</span>
                      </th>

                      <th name="th_unit_price" style="width:60px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Unit Price US$</span>
                      </th>
                      <th name="th_qty" style="width:60px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Order Qty</span>
                      </th>
                      <th name="th_uom" style="width:60px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>UOM</span>
                      </th>
                      <th name="th_total" style="width:80px"
                        t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Total Amount US$</span>
                      </th>

                    </tr>
                  </thead>
                  <tbody style="font-size : 12px;" class="invoice_tbody">
                    <t t-set="current_subtotal" t-value="0" />
                    <t t-set="line_count" t-value="0" />

                    <t t-set="lines" t-value="o.order_line" />

                    <t t-foreach="lines" t-as="line">
                      <t t-set="line_count" t-value="line_count + 1" />
                      <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                        groups="account.group_show_line_subtotals_tax_excluded" />
                      <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                        groups="account.group_show_line_subtotals_tax_included" />

                      <tr
                        t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                        <t t-if="not line.display_type" name="account_invoice_line_accountable">
                          <td name="account_invoice_line_name">
                            <span t-field="line.product_id.name" t-options="{'widget': 'text'}" />
                          </td>
                          <td class="text-left">
                            <span t-field="line.name" t-options="{'widget': 'text'}" />
                          </td>
                          <td class="text-right">
                            <span t-if="line.customer_request_date"
                              t-esc="line.customer_request_date.strftime('%d.%m.%Y')" />
                          </td>
                          <td class="text-right">
                            <span t-if="line.committed_date"
                              t-esc="line.committed_date.strftime('%d.%m.%Y')" />
                          </td>

                          <td class="text-right">
                            <span class="text-nowrap" t-field="line.price_unit"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <span class="text-nowrap" t-field="line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                          </td>
                          <td class="text-right">
                            <span class="text-nowrap" t-field="line.product_uom_qty"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <span class="text-nowrap" t-field="line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                          </td>
                          <td class="text-right">
                            <span class="text-nowrap" t-field="line.product_id.uom_id"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                          </td>
                          <td class="text-right o_price_total">
                            <span class="text-nowrap" t-field="line.price_subtotal"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <span class="text-nowrap" t-field="line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                          </td>
                        </t>
                        <t t-if="line.display_type == 'line_section'">
                          <td colspan="99">
                            <span t-field="line.name" t-options="{'widget': 'text'}" />
                          </td>
                          <t t-set="current_section" t-value="line" />
                          <t t-set="current_subtotal" t-value="0" />
                        </t>
                        <t t-if="line.display_type == 'line_note'">
                          <td colspan="99">
                            <span t-field="line.name" t-options="{'widget': 'text'}" />
                          </td>
                        </t>
                      </tr>

