<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="paperformat_iconnexion_delivery_order" model="report.paperformat">
      <field name="name">Iconnexion Delivery Order</field>
      <field name="default" eval="True" />
      <field name="format">A4</field>
      <field name="page_height">0</field>
      <field name="page_width">0</field>
      <field name="orientation">Portrait</field>
      <field name="margin_top">60</field>
      <field name="margin_bottom">72</field>
      <field name="margin_left">15</field>
      <field name="margin_right">15</field>
      <field name="header_line" eval="False" />
      <field name="header_spacing">53</field>
      <field name="dpi">80</field>
    </record>


    <template id="report_iconnexion_stock_picking_delivery_order_doc">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.html_container">
          <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
            <div class="header">
              <div class="row mt32 mb32">
                <div class="col-auto">
                  <img style="width : 100%; max-height:45mm; max-width:45mm; margin-top: 2mm;" src="/iconnexion_custom/static/src/img/icon.png"/>
                </div>
                <div class="col-auto">
                  <h3 style="text-align: right;">DELIVERY ORDER</h3>
                </div>
              </div>
              <br/>

              <div class="row mt32 mb32">
                <div class="col-auto">
                  <div><span style="font-size : 15px; text-decoration: underline; font-weight: bold;" t-field="o.company_id.name"/></div>
                  <div style="font-size : 12px;"><span t-field="o.company_id.street"/> </div>
                  <div style="font-size: 12px;"><span t-field="o.company_id.street2"/> </div>
                  <div style="font-size : 12px;"> <span t-field="o.company_id.country_id"/> <span t-field="o.company_id.zip"/> </div>
                  <div style="font-size : 12px;">Tel : <span t-field="o.company_id.partner_id.phone"/></div>
                  <div style="font-size : 12px;">Fax : <span t-field="o.company_id.fax"/></div>
                </div>
                <div style="font-size : 12px;width:60%;">

                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      COMPANY REG NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase">200718664Z</span>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      GST REG NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase">200718664Z</span>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      D.O DATE :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <t t-if="o.state == 'done'">
                        <span class="text-uppercase" t-esc="o.date_done.strftime('%d.%m.%Y')"/>

                      </t>
                      <t t-else="">
                        <span class="text-uppercase" t-esc="context_timestamp(datetime.datetime.now()).strftime('%d.%m.%Y')"/>
                      </t>

                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      D.O NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-field="o.name"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      CUSTOMER PO NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-field="o.sale_id.client_order_ref"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      PAYMENT TERMS :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.sale_id.payment_term_id"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      FREIGHT TERMS :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.sale_id.freight_terms"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      ORDERED BY :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.sale_id.contact_id.name"/>
                    </div>

                  </div>

                </div>
              </div>

            </div>
            <div class="page">

              <table style=" font-size : 14px; width:80%; border:1px solid #000;margin-top:-6mm;">
                <tr>
                  <th style="border-right: 1px solid #000 !important;">
                    <div style="width:340px;height:160px;">
                      <br/>
                      <div class="col-auto">
                        <div class="row mt32 mb32">
                          <table style="margin-top:-20px;padding : 15px; width: 100%;">
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Bill to</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.sale_id.partner_id"/><br/>
                                <t t-if="o.sale_id.bill_to_street">
                                  <span t-field="o.sale_id.bill_to_street"/><br/>
                                </t>
                                <t t-if="o.sale_id.bill_to_block">
                                  <span t-field="o.sale_id.bill_to_block"/><br/>
                                </t>
                                <t t-if="o.sale_id.bill_to_city">
                                  <span t-field="o.sale_id.bill_to_city"/><br/>
                                </t>
                                <t t-if="o.sale_id.bill_to_state">
                                  <span t-field="o.sale_id.bill_to_state"/><br/>
                                </t>
                                <span t-field="o.sale_id.bill_to_country_id"/>
                                <span t-field="o.sale_id.bill_to_zip"/>
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">C.Person</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.sale_id.contact_id.name"/>
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Telephone</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.sale_id.contact_id.phone"/>
                              </td>
                            </tr>
                          </table>

                        </div>

                      </div>
                    </div>
                  </th>
                  <th>
                    <div style="width:340px;height:120px;">
                      <br/>
                      <div class="col-auto">
                        <div class="row mt32 mb32">
                          <table style="margin-top:-20px;padding : 15px; width: 100%;">
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">Deliver to
                              </td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.sale_id.partner_id"/><br/>
                                <t t-if="o.sale_id.ship_to_street">
                                  <span t-field="o.sale_id.ship_to_street"/><br/>
                                </t>
                                <t t-if="o.sale_id.ship_to_block">
                                  <span t-field="o.sale_id.ship_to_block"/><br/>
                                </t>
                                <t t-if="o.sale_id.ship_to_city">
                                  <span t-field="o.sale_id.ship_to_city"/><br/>
                                </t>
                                <t t-if="o.sale_id.ship_to_state">
                                  <span t-field="o.sale_id.ship_to_state"/><br/>
                                </t>
                                <span t-field="o.sale_id.ship_to_country_id"/>
                                <span t-field="o.sale_id.ship_to_zip"/><br/>
                                <t t-if="o.sale_id.ship_to_remarks">
                                  <span t-field="o.sale_id.ship_to_remarks"/>
                                </t>

                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">C.Person</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.sale_id.partner_shipping_id.name"/>
                              </td>
                            </tr>
                            <tr>
                              <td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">Telephone</td>
                              <td style="font-size:12px; padding-left: 5px;">:</td>
                              <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                <span t-field="o.sale_id.partner_shipping_id.phone"/>
                              </td>
                            </tr>
                          </table>
                        </div>

                      </div>
                    </div>
                  </th>
                </tr>
              </table>
              <!-- <br/> -->
              <div style="min-height : 280px">
                <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                  <thead style="font-size : 12px;">
                    <tr style="background-color: lightgrey;">
                      <th name="th_desc" style="width: 40px" class="text-left"><span>No.</span></th>
                      <th name="th_desc" style="width: 150px" class="text-left"><span>P/N Description</span></th>
                      <th name="th_description" style="width: 150px" class="text-left"><span>Cust P/N</span></th>
                      <th name="th_desc" style="width: 50px" class="text-center"><span/></th>
                      <th name="th_description" style="width: 120px" class="text-center"><span>COO</span></th>
                      <th name="th_qty" style="width: 80px" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                        <span>Quantity</span></th>
                      <th name="th_description" style="width: 100px" class="text-center"><span>UOM</span></th>
                    </tr>
                  </thead>
                  <tbody style="font-size : 12px;" class="invoice_tbody">
                    <t t-set="current_subtotal" t-value="0"/>
                    <t t-set="line_count" t-value="0"/>

                    <t t-set="lines" t-value="o.move_line_ids_without_package"/>

                    <t t-foreach="lines" t-as="line">
                      <t t-set="line_count" t-value="line_count + 1"/>
                      <!--<t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>-->
                      <!--<t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>-->

                      <tr t-att-class="'font-weight-bold o_line_section'">
                        <t name="account_invoice_line_accountable">
                          <td name="count"><span t-esc="line_count" t-options="{'widget': 'text'}"/></td>
                          <td name="account_invoice_line_name"><span t-field="line.product_id.name"/></td>
                          <td class="text-left"><span t-field="line.move_id.name" t-options="{'widget': 'text'}"/>
                          </td>
                          <td/>
                          <td class="text-center"><span t-field="line.product_id.product_tmpl_id.coo_id.name" t-options="{'widget': 'text'}"/></td>
                          <td class="text-right"><span t-field="line.qty_done" t-options="{'widget': 'integer'}"/></td>
                          <td class="text-center"><span t-field="line.product_uom_id.name" t-options="{'widget': 'text'}"/></td>
                        </t>
                      </tr>
                      <!--<tr>-->
                      <!--  <td/>-->
                      <!--  <td><div style="margin-top:20px;margin-left:50px;text-align:left;font-size:12px;" t-field="o.note"/></td>-->
                      <!--  <td/>-->
                      <!--  <td/>-->
                      <!--</tr>-->
                    </t>
                    <!-- </t> -->
                  </tbody>
                </table>
                <div style="font-size : 10px;margin-top:0mm">
                  <tr>
                    <!--<td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">Note </td>-->
                    <!--<td style="font-size:12px; padding-left: 5px;">:</td>-->
                    <td style="padding-left: 10px; text-align:left; font-size:12px;">
                      <span t-field="o.note"/><br/>
                    </td>
                  </tr>
                </div>
              </div>
              <!--<t t-if="line_count &lt;= 5">-->
              <!--  <i style="font-size: 12px">  <span t-field="o.note"/></i>-->
              <!--  </t>-->
              <!--<div style="font-size : 12px; border-bottom: 1px solid black; position: absolute; width : 680px">-->

              <!--</div>-->
              <!--<div style="font-size : 11px; text-align: right;">Received above mentioned goods in good order and condition</div>-->

              <!--<br/><br/><br/><br/><br/><br/>-->

              <div class="footer">
                <div style="font-size : 9px;">
                  CR NUMBER : CR78664170000E<br/><br/>
                  REMARKS:<br/>
                  1.Please check GOODS and advise Deficiency in Volume and Stock within 7<br/>
                  Days of Receipt.<br/>
                  2. Quote Delivery Order No. and/or Batch Number when making enquiry.<br/>
                  3. GOODS deemed as accepted by CUSTOMERS if deficiency is not reflected<br/>
                  within the stipulated time.

                </div>
                <br/>
                <br/>
                <div class="row mt32 mb32">
                  <div class="col-auto">
                    <div class="signature">
                      <br/>
                      <br/>


                      <div>________________________________________________</div>
                      <div style="margin-left: 75px; font-weight : 900; font-size:12px;">Authorized Signature</div>
                    </div>
                  </div>
                  <div class="col-auto">
                    <div class="signature">
                      <br/>
                      <br/>


                      <div>________________________________________________</div>
                      <div style="margin-left: 10mm; font-weight : 900; font-size: 12px; text-align:">Customer's
                        Signature
                        and Company Stamp</div>
                    </div>

                  </div>
                </div>
                <div class="row">
                  <div class="col-12 text-center">
                    <small>
                      <span>Page</span>
                      <span class="page"/>
                      /
                      <span class="topage"/>
                    </small>
                  </div>
                </div>
              </div>
            </div>
          </t>
        </t>
      </t>
    </template>

    <record id="paperformat_packinglist_delivery_icon" model="report.paperformat">
      <field name="name">Paper Packinglist / Delivery Order (Iconnnexion)</field>
      <field name="default" eval="True" />
      <field name="format">A4</field>
      <field name="orientation">Portrait</field>
      <field name="margin_top">20</field>
      <field name="margin_bottom">5</field>
      <field name="margin_left">15</field>
      <field name="margin_right">15</field>
      <field name="header_line" eval="False" />
      <field name="header_spacing">50</field>
      <field name="dpi">80</field>
    </record>

    <record id="report_iconnexion_stock_picking_delivery_order" model="ir.actions.report">
        <field name="name">Delivery Order (Iconnexion)</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">iconnexion_custom.report_iconnexion_stock_picking_delivery_order_doc</field>
        <field name="report_file">iconnexion_custom.report_iconnexion_stock_picking_delivery_order_doc</field>
        <field name="binding_model_id" search="[('model', '=', 'stock.picking')]"/>
        <field name="binding_type">report</field>
    </record>

    <record id="report_iconnexion_stock_picking_delivery_order" model="ir.actions.report">
      <field name="paperformat_id" ref="iconnexion_custom.paperformat_iconnexion_delivery_order" />
      <field name="groups_id" eval="[(4, ref('iconnexion_custom.group_iconnexion_company'))]" />
    </record>

  </data>
</odoo>