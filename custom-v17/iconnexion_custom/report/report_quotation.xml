<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="purchase.report_purchasequotation_document">
    <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-set="address">
            <div t-field="o.partner_id"
            t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
            <p t-if="o.partner_id.vat"><t t-esc="o.company_id.country_id.vat_label or 'Tax ID'"/>: <span t-field="o.partner_id.vat"/></p>
        </t>
        <t t-if="o.dest_address_id">
            <t t-set="information_block">
                <strong>Shipping address:</strong>
                <div t-field="o.dest_address_id"
                    t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}' name="purchase_shipping_address"/>
            </t>
        </t>
        <div class="page">
            <div class="oe_structure"/>
           
            <h2>Request for Quotation<span t-field="o.name"/></h2>

            <table class="table table-sm">
                <thead>
                    <tr class="border-blacks" style="border-top: 2px solid black !important; border-bottom:2px solid black !important;">

                        <th name="th_s/n"><strong>S/N</strong></th>
                        <th name="th_code"><strong>Code</strong></th>
                        <th name="th_quantity"><strong>Quantity</strong></th>
                        <th name="th_uom"><strong>UOM</strong></th>
                        <th name="th_moq"><strong>MOQ</strong></th>
                        <th name="th_spq"><strong>SPQ</strong></th>
                        <th name="th_lead_time"><strong>Lead Time</strong></th>
                        <th name="th_brand"><strong>Brand</strong></th>
                        <th name="th_unit_price"><strong>U/Price</strong></th>
                        <th name="th_total"><strong>Total</strong></th>
                        <th name="th_remarks"><strong>Remarks</strong></th>

                     <!--    <th name="th_description"><strong>Description</strong></th>
                        <th name="th_expected_date" class="text-center"><strong>Expected Date</strong></th>
                        <th name="th_quantity" class="text-right"><strong>Qty</strong></th> -->
                    </tr>
                </thead>
                <tbody>
                   <!--  <tr class="border-blacks" style="border-bottom:2px solid black !important;"> -->

                    <t t-set="get_number" t-value="1" />
                    <t t-foreach="o.order_line" t-as="order_line" >
                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if order_line.display_type == 'line_section' else 'font-italic o_line_note' if order_line.display_type == 'line_note' else ''" style="border-bottom:2px solid black !important;" >
                            <t t-if="not order_line.display_type">
                                <td>
                                    <span t-esc="get_number"/>
                                </td>

                                <td id="product">
                                    <span t-field="order_line.name"/>
                                </td>                     
                        
                                
                                <td class="text-center">
                                    <span t-esc="'%.0f'%order_line.product_qty"/>
                              
                                </td>
                                <td class="text-center">
                                   
                                    <span t-field="order_line.product_uom" groups="uom.group_uom"/>
                                </td>
                               <!--   <t t-if="'min_qty' in line.product_id.moq_ids"> -->
                                    <td class="text-center">
                                        <span t-esc="'%.0f'%order_line.product_id.moq_ids.min_qty" />
                                    </td>
                                <!-- </t>
                                -->
                                <td class="text-center">

                                    <span t-field="order_line.product_id.qty_multiply"/>
                                </td>
                                <td class="text-center">

                                    <span t-esc="'%.0f'%order_line.product_id.sale_delay"/>
                                    <span>wks</span>

                                </td>
                                <td class="text-cnter">

                                    <span t-field="order_line.product_id.product_brand_id.name"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="order_line.price_unit"/>
                              
                                </td>
                                <td class="text-center">
                                    <span t-field="order_line.price_subtotal"/>
                                   
                              
                                </td>

                            
                            </t>
                            <t t-else="">
                                <td colspan="99" id="section">
                                    <span t-field="order_line.name"/>
                                </td>
                            </t>
                            <t t-set="get_number" t-value="get_number+1"/>
                        </tr>
                    </t>
                </tbody>
            </table>

            <p t-field="o.notes"/>

            <div class="oe_structure"/>
        </div>
    </t>
</template>

<template id="purchase.report_purchasequotation">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="purchase.report_purchasequotation_document" t-lang="o.partner_id.lang"/>
        </t>
    </t>
</template>
</odoo>
