<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="barcode_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">

                        <br></br>
                        <br></br>
                          <h2><span t-field="o.name"/></h2>
                        <br></br>
                        <br></br>
                       <t t-set="lines" t-value="o.move_ids_without_package"/>

                        <t t-foreach="lines" t-as="line">
                        <div style="width: 32%; display: inline-table; height:14rem;">
                            <table class="table table-bordered mb-0" style="border: 2px solid black;">
                                <tr>
                                    <td class="text-center align-middle" style="height: 6rem">
                                         
                                            <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('QR', {line.product_id.id, line.product_uom_qty, line.product_id.coo_id.name, o.scheduled_date.strftime('%Y/%m'),line.description_picking }, 600, 500)" style="width:100%;height::4rem;"/>

                                            <span t-field="line.product_id"/>
                                    
                                      
                                    </td>
                                </tr>
                            </table>
                            <br></br>
                        <br></br>
                            
                        </div>
                        </t>
                        <br></br>
