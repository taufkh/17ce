                                <tr>
                                    <td class="text-center align-middle" style="height: 6rem">
                                         
                                            <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s' % ('EAN13', {line.product_id.id, line.product_uom_qty, o.scheduled_date.strftime('%Y/%m/%d'), line.product_id.coo_id.id}, 600, 150)" style="width:100%;height::4rem;"/>
                                            <span t-field="line.product_id"/>
                                    
                                      
                                    </td>
                                </tr>
                            </table>
                            <br></br>
                        <br></br>
                            
                        </div>
                        </t> -->
          
                    </div>
                    </t>
                </t>
            </t>
        </template>


        <record id="barcode_report_report" model="ir.actions.report">
            <field name="name">Barcode (Iconnexion)</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">iconnexion_custom.barcode_report</field>
            <field name="report_file">iconnexion_custom.barcode_report</field>
            <field name="binding_model_id" search="[('model', '=', 'stock.picking')]"/>
            <field name="binding_type">report</field>
        </record>
        
       <record id="barcode_report_report" model="ir.actions.report">
            <field name="paperformat_id" ref="odes_custom.paperformat_a4_no_header"/>
            <field name="groups_id" eval="[(4, ref('iconnexion_custom.group_iconnexion_company'))]"/>
        </record>

    </data>
</odoo>