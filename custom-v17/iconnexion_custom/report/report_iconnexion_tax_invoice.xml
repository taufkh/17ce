                        </td>
                        <td width="40%"/>
                      </tr>
                      <tr>
                        <td/>
                        <td><span t-field="o.currency_id.name"/> 1.00 = </td>
                        <td>SGD</td>
                        <td><span t-esc="o.get_sgd_value(1)" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 6}"/></td>
                        <td/>
                      </tr>
                      <tr>
                        <td/>
                        <td>Subtotal = </td>
                        <td>SGD</td>
                        <td><span t-esc="o.get_sgd_value(o.amount_untaxed)" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/></td>
                        <td/>
                      </tr>
                      <tr>
                        <td/>
                        <td>GST 8%</td>
                        <td>SGD</td>
                        <td><span t-esc="o.get_sgd_value(o.amount_tax)" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/></td>
                        <td/>
                      </tr>
                      <tr>
                        <td/>
                        <td>Total Amount</td>
                        <td>SGD</td>
                        <td><span t-esc="o.get_sgd_value(o.amount_total)" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}"/></td>
                        <td/>
                      </tr>
                    </table>
                  </div>
                </t>
                <div style="font-size : 12px; border-bottom: 1px solid black; position: absolute; width : 680px">
                  <br/>
                  <i> <span t-field="o.company_id.remarks_header"/></i>
