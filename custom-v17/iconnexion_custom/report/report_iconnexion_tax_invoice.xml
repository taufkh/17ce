<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="report_iconnexion_invoice_customize_document">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <t t-foreach="docs" t-as="o">

            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>

            <div class="header">
              <div class="row mt32 mb32">
                <div class="col-auto">
                </div>
                <t t-if="o.company_id.name in ['iConnexion Asia Pte Ltd']">
                  <div class="col-auto">
                    <img style="width : 100%; max-height:45mm; max-width:45mm;margin-left:-62.5mm;" src="/iconnexion_custom/static/src/img/icon.png"/>
                  </div>
                </t>
                <t t-if="o.company_id.name in ['McCoy Pte Ltd']">
                  <div class="col-auto">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 65px;margin-left:-62.5mm;" alt="Logo"/>
                  </div>
                </t>
                <div class="col-auto">
                  <h2 style="text-align: right; color:#0068a6;">TAX INVOICE</h2>
                </div>
              </div>


              <div style="margin-top : 5px;" class="row mt32 mb32">
                <div class="col-auto">
                  <div><span style="font-size : 15px; text-decoration: underline; font-weight: bold;" t-field="o.company_id.name"/></div>
                  <div style="font-size : 12px;"><span t-field="o.company_id.street"/> </div>
                  <div style="font-size: 12px;"><span t-field="o.company_id.street2"/> </div>
                  <div style="font-size : 12px;"> <span t-field="o.company_id.country_id"/> <span t-field="o.company_id.zip"/> </div>
                  <div style="font-size : 12px;">Tel : <span t-field="o.company_id.partner_id.phone"/></div>
                  <div style="font-size : 12px;">Fax : <span t-field="o.company_id.fax"/></div>

                  <!-- <br/>                    -->
                </div>
                <div style="font-size : 12px;" class="col-auto">
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      COMPANY REG NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-esc="o.company_id.vat"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      GST REG NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-esc="o.company_id.company_registry"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      DATE :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-esc="o.date.strftime('%d.%m.%Y')"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      TAX INVOICE NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span class="text-uppercase" t-field="o.name"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      CUSTOMER PO NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-field="o.ref"/>
                    </div>

                  </div>
                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      QUOTATION NO :
                    </div>
                    <div class="col-auto" style="text-align : right;">
                      <span t-esc="o.get_quotation_no()"/>
                    </div>

                  </div>

                  <div class="row mt32 mb32">
                    <div class="col-auto" style="text-align : right;">
                      PAYMENT TERMS :
                    </div>
                    <div class="col-auto" style="text-align : right;">
