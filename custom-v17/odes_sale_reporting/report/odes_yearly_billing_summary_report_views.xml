<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="odes_yearly_billing_summary_report_pivot" model="ir.ui.view">
         <field name="name">odes.yearly.billing.summary.report.pivot</field>
         <field name="model">odes.yearly.billing.summary.report</field>
         <field name="arch" type="xml">
             <pivot disable_linking="True" sample="1">
                 <field name="date" interval="month" type="row"/> 
                 <field name="product_brand_id" type="row"/>
                 <field name="price_subtotal" type="measure"/>
             </pivot>
         </field>
    </record>
    <record id="odes_yearly_billing_summary_report_view_tree" model="ir.ui.view">
        <field name="name">odes.yearly.billing.summary.report.view.tree</field>
         <field name="model">odes.yearly.billing.summary.report</field>
        <field name="type">tree</field>
        <field name="arch" type="xml"> 
            <tree create="0" edit="0" delete="0">
                <field name="year"/>
                <field name="date"/>
                <field name="product_brand_id"/>

                <field name="origin_price_subtotal" optional="hide"/>
                <field name="origin_currency_id" optional="hide"/>
                <field name="currency_rate" digits="[12,12]"  optional="hide"/>

                <!-- <field name="price_unit"/> -->
                <field name="price_subtotal"/>
                <field name="state" optional="hide"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="odes_yearly_billing_summary_report_graph" model="ir.ui.view">
         <field name="name">odes.yearly.billing.summary.report.graph</field>
         <field name="model">odes.yearly.billing.summary.report</field>
         <field name="arch" type="xml">
             <graph type="line" sample="1" disable_linking="1">
                 <field name="date" type="row" interval="month"/>
                  <field name="product_brand_id"/>
                 <field name="price_subtotal" type="measure"/>
             </graph>
         </field>
    </record>

    <record id="odes_yearly_billing_summary_report_search" model="ir.ui.view">
        <field name="name">odes.yearly.billing.summary.report.search</field>
        <field name="model">odes.yearly.billing.summary.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_brand_id"/>
                <field name="year"/>
                <group expand="0" string="Extended Filters">
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <group expand="1" string="Group By">
                    <filter string="This Month" name="filter_this_month" 
                        domain="[('date','&lt;',(context_today()+relativedelta(months=1)).strftime('%%Y-%%m-01')), ('date','&gt;=',time.strftime('%%Y-%%m-01'))]"/>
                    <filter string="This Year" name="filter_this_year" 
                        domain="[('date','&lt;=', time.strftime('%%Y-12-31')),('date','&gt;=',time.strftime('%%Y-01-01'))]"/>

                    <filter string="Company" name="company" groups="base.group_multi_company" context="{'group_by':'company_id'}"/>
                    <filter string="Posted" name="filter_posted" domain="[('state','=','posted')]"/>
                </group>
            </search>
        </field>
    </record>


    <record id="odes_yearly_billing_summary_report_action" model="ir.actions.act_window">
        <field name="name">Summary Year - Billing / Sales</field>
        <field name="res_model">odes.yearly.billing.summary.report</field>
        <!-- <field name="view_mode">graph,pivot</field> -->
        <field name="view_mode">tree,pivot,graph</field>
        <field name="view_id"></field>  <!-- force empty -->
        <field name="search_view_id" ref="odes_yearly_billing_summary_report_search"/>
        <field name="context">{ 
            'search_default_filter_this_year':1, 
            'graph_mode':'bar',
            'search_default_filter_posted':1 
        }</field>
    </record> 

    <menuitem id="odes_yearly_billing_summary_report_menu"
        name="Billing Summary"
        action="odes_yearly_billing_summary_report_action"
        parent="odes_yearly_billing_sale_summary_menu_root"
        sequence="10"/>
 
</odoo>