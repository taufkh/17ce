<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="odes_sale_tracker_product_report_view_tree" model="ir.ui.view">
        <field name="name">odes.sale.tracker.product.report.view.tree</field>
         <field name="model">odes.sale.tracker.product.report</field>
        <field name="type">tree</field>
        <field name="arch" type="xml"> 
            <tree create="0" edit="0" delete="0">
                <!-- <field name="product_id"/> -->
                <field name="product_brand_id"/>
                <field name="date"/>
                <field name="origin_total_sales" optional="hide"/>
                <field name="origin_sol_currency_id" optional="hide"/>
                <field name="sol_currency_rate" digits="[12,12]" optional="hide"/>
                <field name="origin_total_cost" optional="hide"/>
                <field name="origin_pol_currency_id" optional="hide"/>
                <field name="pol_currency_rate" digits="[12,12]" optional="hide"/>

                <field name="total_sales"/>
                <field name="total_cost"/>
                <field name="gross_profit"/> 

                <field name="so_number" optional="hide"/>
                <field name="date" optional="hide"/>
                <field name="state" optional="hide"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="odes_sale_tracker_product_report_search" model="ir.ui.view">
        <field name="name">odes.sale.tracker.product.report.search</field>
        <field name="model">odes.sale.tracker.product.report</field>
        <field name="arch" type="xml">
            <search>
                <!-- <filter name="search_product" string="Product" domain="[('product_id','ilike',self)]"/> -->

                <field name="product_brand_id"/>
                <group expand="0" string="Extended Filters">
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <group expand="1" string="Group By">
                    <filter string="Brand" name="group_brand" context="{'group_by':'product_brand_id'}"/>
                    <filter string="This Month" name="filter_this_month" 
                    domain="[('date','&lt;',(context_today()+relativedelta(months=1)).strftime('%%Y-%%m-01')), ('date','&gt;=',time.strftime('%%Y-%%m-01'))]"/>
                    <filter string="Company" name="company" groups="base.group_multi_company" context="{'group_by':'company_id'}"/>
                    <filter string="Sales Order" name="filter_sales_order" domain="[('state','=','sale')]"/>
                </group>
            </search>
        </field>
    </record>


    <record id="odes_sale_tracker_product_report_view_graph" model="ir.ui.view">
         <field name="name">odes_sale_tracker_product_report_view_graph</field>
         <field name="model">odes.sale.tracker.product.report</field>
         <field name="arch" type="xml">
             <graph type="line" sample="1" disable_linking="1">
                <field name="date" type="row" interval="month"/>
                <field name="product_brand_id" type="row"/>
                <field name="gross_profit" type="measure"/> 
             </graph>
         </field>
    </record>



    <record id="odes_sale_tracker_product_report_action" model="ir.actions.act_window">
        <field name="name">Summary - Order Tracker</field>
        <field name="res_model">odes.sale.tracker.product.report</field>
        <!-- <field name="view_mode">graph,pivot</field> -->
        <field name="view_mode">tree</field>
        <field name="view_id"></field>  <!-- force empty -->
        <field name="search_view_id" ref="odes_sale_tracker_product_report_search"/>
        <field name="context">{ 
            'search_default_group_brand':1,
            'search_default_filter_this_month':1, 
            'graph_mode':'bar',
            'search_default_filter_sales_order':1 
        }</field>
    </record> 

    <menuitem id="odes_sale_tracker_product_report_menu"
        name="By Brand"
        action="odes_sale_tracker_product_report_action"
        parent="odes_sale_tracker_report_menu_root"
        sequence="10"/>

</odoo>