<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="odes_sale_billing_detail_pivot" model="ir.ui.view">
         <field name="name">odes.sale.billing.detail.report.pivot</field>
         <field name="model">odes.sale.billing.detail.report</field>
         <field name="arch" type="xml">
             <pivot disable_linking="True" sample="1">
                 <field name="date" interval="month" type="row"/>
                 <field name="ttype" type="row"/>
                 <field name="gross_profit" type="measure"/>
             </pivot>
         </field>
    </record>



    <record id="odes_sale_billing_detail_view_tree" model="ir.ui.view">
        <field name="name">odes.sale.billing.detail.view.tree</field>
        <field name="model">odes.sale.billing.detail.report</field>
        <field name="type">tree</field>
        <field name="arch" type="xml"> 
            <tree create="false" delete="false">
                <field name="month" string="Month"/> 
                <field name="ttype"/>
                <field name="date"/>
                <field name="invoice_id"/>
                <field name="purchase_order_id"/>
                <field name="customer_code"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="country_id"/>
                <field name="product_id"/>
                <field name="item_description"/>
                <field name="product_brand_id"/>
                <field name="qty"/>

                <field name="origin_sol_currency_id" optional="hide"/>
                <field name="origin_pol_currency_id" optional="hide"/>
                <field name="sol_currency_rate" digits="[12,12]" optional="hide"/>
                <field name="pol_currency_rate" digits="[12,12]" optional="hide"/>
                
                <field name="origin_sales_price" optional="hide"/>
                <field name="origin_total_sales" optional="hide"/>
                <field name="origin_cost_price" optional="hide"/>
                <field name="origin_total_cost" optional="hide"/>

                <field name="sales_price"/>
                <field name="total_sales"/>
                <field name="cost_price"/>
                <field name="total_cost"/>
                <field name="gross_profit"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="odes_sale_billing_detail_report_search" model="ir.ui.view">
        <field name="name">odes.sale.billing.detail.report.search</field>
        <field name="model">odes.sale.billing.detail.report</field>
        <field name="arch" type="xml">
            <search string="Billing Detail">
                <field name="purchase_order_id" filter_domain="[('purchase_order_id','ilike',self)]" />
                <field name="customer_code" filter_domain="[('customer_code','ilike',self)]" />
                <field name="partner_id" filter_domain="[('partner_id','ilike',self)]" />
                <field name="user_id" filter_domain="[('user_id','ilike',self)]" />
                <field name="country_id" filter_domain="[('country_id','ilike',self)]" />
                <field name="product_id" filter_domain="[('product_id','ilike',self)]" />
                <field name="item_description" filter_domain="[('item_description','ilike',self)]" />
                <field name="product_brand_id" filter_domain="[('product_brand_id','ilike',self)]" />

                <filter string="Date" name="year" invisible="1" date="date" default_period="this_year"/>

                <field name="month"/>
                <field name="date"/>
                <field name="invoice_id"/>
                <field name="purchase_order_id"/>
                <field name="partner_id"/>

                <group expand="0" string="Extended Filters">
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <group expand="1" string="Group By">
                    <filter string="Month" name="month" context="{'group_by':'month'}"/>
                    <filter string="Date" name="date" context="{'group_by':'date'}"/>
                    <filter string="Num" name="invoice_id" context="{'group_by':'invoice_id'}"/>
                    <filter string="P.O. No" name="purchase_order_id" context="{'group_by':'purchase_order_id'}"/>
                    <filter string="Name" name="partner_id" context="{'group_by':'partner_id'}"/>
                    <filter string="Company" name="company" groups="base.group_multi_company" context="{'group_by':'company_id'}"/>
                </group>

                <filter string="This Month" name="this_month" domain="[('date','&lt;',(context_today()+relativedelta(months=1)).strftime('%%Y-%%m-01')), ('date','&gt;=',time.strftime('%%Y-%%m-01'))]"/>

            </search>
        </field>
    </record>

    <record id="odes_sale_billing_detail_report_view_graph" model="ir.ui.view">
         <field name="name">odes_sale_billing_detail_report_view_graph</field>
         <field name="model">odes.sale.billing.detail.report</field>
         <field name="arch" type="xml">
             <graph type="line" sample="1" disable_linking="1">
                <field name="date" type="row" interval="month"/>
                 <field name="ttype" type="row"/>
                 <field name="gross_profit" type="measure"/>
             </graph>
         </field>
    </record>

    <record id="odes_sale_billing_detail_report_action" model="ir.actions.act_window">
        <field name="name">Billing Detail</field>
        <field name="res_model">odes.sale.billing.detail.report</field>
        <!-- <field name="view_mode">graph,pivot</field> -->
        <field name="view_mode">tree</field>
        <field name="view_id"></field>  <!-- force empty -->
        <field name="search_view_id" ref="odes_sale_billing_detail_report_search"/>
        <field name="context">{'search_default_this_month':1,'graph_mode':'bar' }</field>
    </record>


    <menuitem id="odes_sale_billing_detail_report_menu"
        name="Billing Detail"
        action="odes_sale_billing_detail_report_action"
        parent="sale.menu_sale_report"
        sequence="13"/>

</odoo>