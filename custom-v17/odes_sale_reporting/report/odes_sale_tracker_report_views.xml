<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <menuitem id="odes_sale_tracker_report_menu_root"
        name="Order Tracker"
        parent="sale.menu_sale_report"
        sequence="10"/>
    
    
    <record id="odes_sale_tracker_report_pivot" model="ir.ui.view">
         <field name="name">odes.sale.tracker.report.pivot</field>
         <field name="model">odes.sale.tracker.report</field>
         <field name="arch" type="xml">
             <pivot disable_linking="True" sample="1">
                 <field name="date" interval="month" type="row"/>
             </pivot>
         </field>
    </record>

    <record id="odes_sale_tracker_report_graph" model="ir.ui.view">
         <field name="name">odes.sale.tracker.report.graph</field>
         <field name="model">odes.sale.tracker.report</field>
         <field name="arch" type="xml">
             <graph type="line" sample="1" disable_linking="1">
                 <field name="date" type="row" interval="day"/>
             </graph>
         </field>
    </record>

    <record id="odes_sale_tracker_report_view_tree" model="ir.ui.view">
        <field name="name">odes.sale.tracker.report.view.tree</field>
         <field name="model">odes.sale.tracker.report</field>
        <field name="type">tree</field>
        <field name="arch" type="xml"> 
            <tree create="false" delete="false">
                <field name="date"/>
                <field name="territory"/>
                <field name="user_id"/>

                <field name="partner_id"/>
                <field name="purchase_partner_id"/>

                <field name="product_brand_id"/>
                <field name="client_order_ref"/>
                <field name="purchase_order_line_id"/>

                <field name="state"/>
                <field name="product_id" optional="hide"/>
                <field name="part_no"/>
                <field name="qty"/>

                <field name="origin_sol_currency_id" optional="hide"/>
                <field name="origin_pol_currency_id" optional="hide"/>
                <field name="sol_currency_rate" digits="[12,12]" optional="hide"/>
                <field name="pol_currency_rate" digits="[12,12]" optional="hide"/>
                
                <field name="origin_sales_price" optional="hide"/>
                <field name="origin_total_sales" optional="hide"/>
                <field name="origin_cost_price" optional="hide"/>
                <field name="origin_total_cost" optional="hide"/>

                <field name="sales_price"/>
                <field name="total_sales"/>
                <field name="cost_price"/>
                <field name="total_cost"/>
                <field name="gross_profit"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <record id="odes_sale_tracker_report_search" model="ir.ui.view">
        <field name="name">odes.sale.tracker.report.search</field>
        <field name="model">odes.sale.tracker.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="client_order_ref" filter_domain="[('client_order_ref','ilike',self)]" />
                <field name="partner_id" filter_domain="[('partner_id','ilike',self)]" />
                <field name="purchase_partner_id" filter_domain="[('partner_id','ilike',self)]" />
                <field name="user_id" filter_domain="[('user_id','ilike',self)]" />
                <field name="territory" filter_domain="[('territory','ilike',self)]" />
                <field name="product_id" filter_domain="[('product_id','ilike',self)]" />
                <field name="product_brand_id" filter_domain="[('product_brand_id','ilike',self)]" />
                <field name="state" filter_domain="[('state','ilike',self)]" />

                <filter string="Date" name="year" invisible="1" date="date" default_period="this_year"/>

                <field name="date"/>
                <field name="partner_id"/>
                <field name="purchase_partner_id"/>
                <field name="client_order_ref"/>

                <group expand="0" string="Extended Filters">
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <group expand="1" string="Group By">
                    <filter string="SO Date" name="date" context="{'group_by':'date'}"/>
                    <filter string="Customer" name="partner_id" context="{'group_by':'partner_id'}"/>
                    <filter string="Supplier" name="purchase_partner_id" context="{'group_by':'purchase_partner_id'}"/>
                    <filter string="Cust. PO" name="client_order_ref" context="{'group_by':'client_order_ref'}"/>
                    <filter string="Company" name="company" groups="base.group_multi_company" context="{'group_by':'company_id'}"/>
                </group>
                <filter string="This Month" name="this_month" domain="[('date','&lt;',(context_today()+relativedelta(months=1)).strftime('%%Y-%%m-01')), ('date','&gt;=',time.strftime('%%Y-%%m-01'))]"/>
            </search>
        </field>
    </record>
<!-- 

    <record id="odes_sale_tracker_report_view_graph" model="ir.ui.view">
         <field name="name">odes_sale_tracker_report_view_graph</field>
         <field name="model">odes.sale.tracker.report</field>
         <field name="arch" type="xml">
             <graph type="line" sample="1" disable_linking="1">
                 <field name="date" type="row" interval="month"/>
                 <field name="product_brand_id" type="row"/>
                 <field name="gross_profit" type="measure"/>
             </graph>
         </field>
    </record> -->



    <record id="odes_sale_tracker_report_action" model="ir.actions.act_window"> 
        <field name="name">Order Tracker Details</field>
        <field name="res_model">odes.sale.tracker.report</field>
        <!-- <field name="view_mode">graph,pivot</field> -->
        <field name="view_mode">tree</field>
        <field name="view_id"></field>  <!-- force empty -->
        <field name="search_view_id" ref="odes_sale_tracker_report_search"/>
        <field name="context">{'search_default_this_month':1}</field>
    </record>


    <menuitem id="odes_sale_tracker_report_menu"
        name="By Sales Orders"
        action="odes_sale_tracker_report_action"
        parent="odes_sale_tracker_report_menu_root"
        sequence="10"/>

</odoo>