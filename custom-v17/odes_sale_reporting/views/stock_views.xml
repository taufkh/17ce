<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record model="ir.ui.view" id="quant_search_view">
            <field name="name">quant_search_view</field>
            <field name="model">stock.quant</field>
            <field name="inherit_id" ref="stock.quant_search_view" />
            <field name="arch" type="xml">
                <field name="product_id" position="before">
                    <field name="wh_id" />
                    <field name="product_brand_id"/>
                </field>
            </field>
        </record>

    <record model="ir.ui.view" id="view_stock_quant_tree_report">
        <field name="name">stock.quant.tree</field>
        <field name="model">stock.quant</field>
        <field eval="10" name="priority"/>
        <field name="arch" type="xml">
            <tree string="Inventory Valuation" js_class="inventory_report_list"
                  create="0" delete="0" expand="1">
                <field name="product_id" invisible="context.get('single_product', False)"/>
                <field name="location_id" invisible="context.get('hide_location', False)"/>
                <field name="lot_id" groups="stock.group_production_lot"
                       invisible="context.get('hide_lot', False)"/>
                <field name="package_id" groups="stock.group_tracking_lot"/>
                <field name="owner_id" groups="stock.group_tracking_owner"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="quantity"/>
                <field name="in_date"/>
                 <field name="currency_id" invisible="1"/>
                <field name="value" string="Cost"/>
                <field name='company_id' invisible="1"/>
            </tree>
        </field>
    </record>


    <record id="odes_stock_on_hand_graph" model="ir.ui.view">
         <field name="name">odes_stock_on_hand_graph</field>
         <field name="model">stock.quant</field>
         <field name="arch" type="xml">
             <graph type="line" sample="1" disable_linking="1">
                 <field name="in_date" type="row" interval="month"/>
                  <field name="product_brand_id"/>
                 <field name="quantity" type="measure"/>
             </graph>
         </field>
    </record>


	    
    <record id="odes_stock_on_hand_action" model="ir.actions.act_window">
        <field name="name">Inventory Report</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">tree,pivot</field>
        <field name="context">{ 
            'graph_mode':'bar',
            'tree_view_ref':'odes_sale_reporting.view_stock_quant_tree_report',
             'search_default_internal_loc':1,
             'group_by': ['wh_id','product_brand_id','product_id'], 

        }</field>
    </record>

     <menuitem id="stock.menu_valuation" name="Inventory Report"
              parent="stock.menu_warehouse_report" sequence="100"
              action="odes_stock_on_hand_action"/>


</odoo>