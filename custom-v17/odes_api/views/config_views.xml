<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="odesapi_res_config_settings_view_form" model="ir.ui.view">
            <field name="name">odesapi_res_config_settings_view_form</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="10000"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="API Apps" name="odes_api">
                        <block title="API Token Setup" name="odes_api_token_setup">
                            <setting id="odes_api_token_setting">
                                <field name="token_api" string="Token"/>
                                <button name="generate_token_api" type="object" string="Generate Token" class="btn btn-primary mt-2"/>
                            </setting>
                        </block>
                        <block title="Auth Key Notification Firebase" name="odes_api_firebase">
                            <setting id="odes_api_auth_key_setting">
                                <field name="auth_key_notif"/>
                            </setting>
                        </block>
                        <block title="Database Configuration" name="odes_api_db_configuration">
                            <setting id="odes_api_database_config_setting">
                                <field name="database_config_ids">
                                    <tree editable="bottom">
                                        <field name="name" invisible="1"/>
                                        <field name="domain" required="1" placeholder="https://odes.com.sg/"/>
                                        <field name="is_multiple_database"/>
                                        <field name="database_name" placeholder="ODES_XXX"/>
                                    </tree>
                                </field>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
        
    </data>
</odoo>
