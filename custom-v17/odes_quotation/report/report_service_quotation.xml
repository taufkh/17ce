<?xml version="1.0" encoding="utf-8"?>
<odoo>    
    <template id="report_service_quotation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
                    <div t-attf-class="header o_company_#{doc.company_id.id}_layout" t-att-style="report_header_style">
                        <div class="col-6" style="margin-top: 18px;">
                            <img src="/odes_quotation/static/src/img/mccoy.png" style="max-height: 90px;" alt="Logo"/>
                        </div>
                        <div class="col-6">
                            <div class="col-12 text-right">
                                <h1 style="font-weight: bold;">Quotation</h1>
                            </div>
                            <div class="col-6 text-right">
                                Date
                            </div>
                            <div class="col-1"></div>
                            <div class="col-5 text-left">
                                <t t-if="doc.date_order">
                                    <t t-esc="doc.date_order.strftime('%d %B %Y')"/>
                                </t>
                            </div>
                            <div class="col-6 text-right">
                                Quotation #
                            </div>
                            <div class="col-1"></div>
                            <div class="col-5 text-left">
                                <span t-field="doc.name"/>
                            </div>
                        </div>
                    </div>
                    
                    <div class="page service_quotation font14" style="page-break-after: always;">
                        <div class="oe_structure"/>

                        <span>McCoy Pte Ltd (UEN: 200207945R)</span><br/>
                        <span>3 Ang Mo Kio Street 62,#01-57, LINK@AMK, Singapore 569139</span><br/>
                        <span>T: +65 65152988 F: +65 65154515</span><br/>

                        <div style="margin-top: 5px; margin-bottom: 5px;">Quote To:</div>

                        <span t-field="doc.service_contact_person"/>
                        <t t-if="doc.service_contact_person_title">
                            <br/><span t-field="doc.service_contact_person_title"/>
                        </t>
                        <div t-field="doc.partner_id"
                            t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}' />

                        <t t-if="doc.service_contact_person_phone or doc.service_contact_person_email or doc.service_contact_person_office_tel">
                            <div class="pt-2">
                                <t t-if="doc.service_contact_person_email">
                                    Email: <span t-field="doc.service_contact_person_email"/><br/>
                                </t>
                                <t t-if="doc.service_contact_person_phone">
                                    Mobile: <span t-field="doc.service_contact_person_phone"/><br/>
                                </t>
                                <t t-if="doc.service_contact_person_office_tel">
                                    Office Tel: <span t-field="doc.service_contact_person_office_tel"/>
                                </t>
                            </div>
                        </t>

                        <p class="pt-2">Dear <span t-field="doc.service_contact_person"/>,</p>
                        <!-- <strong>
                            <p>
                                RE: Quotation for the Business Consultancy, Design, Development and Implementation of a fully integrated customized workflow driven end to end Business Management Modules using Mccoy On-Demand Enterprise Solution
                            </p>
                        </strong> -->

                        <div class="quotation-html">
                            <span t-field="doc.service_description" t-options='{"widget": "html"}'/>
                        </div>

                        <div class="pt-5">
                            <div class="col-6">
                                <span>Yours Sincerely,</span><br/><br/><br/><br/><br/><br/>
                                Mike Tiong<br/>
                                (MBA, PMC)<br/>
                                Lead Business and Application Consultant
                            </div>
                            <div class="col-6 signature text-center">
                                <div style="border-bottom: 1px solid black;">Accepted By</div>
                                <div class="background-blue">-</div>
                                <div>Signature / Date</div>
                                <div class="background-blue">-</div>
                                <div>Name</div>
                                <div class="background-blue">-</div>
                                <div>Designation</div>
                            </div>
                        </div>

                        <div class="oe_structure"/>
                    </div>
                    <t t-if="doc.quotation_type == 'service'">
                        <div class="page service_quotation font14" style="page-break-after: always;">
                            <div class="oe_structure"/>

                            <p class="text-center">
                                <strong>Appendix A</strong>
                            </p>

                            <table class="table-appendix">
                                <colgroup>
                                    <col width="5%"/>
                                    <col width="25%"/>
                                    <col width="14%"/>
                                    <col width="8%"/>
                                    <col width="15%"/>
                                    <col width="33%"/>
                                </colgroup>
                                <thead>
                                    <th class="text-center">Phase</th>
                                    <th>Task / Descriptions</th>
                                    <th class="text-center">Cost</th>
                                    <th class="text-center">Consultant Man-days</th>
                                    <th>Project Team Members</th>
                                    <th>Deliverables</th>
                                </thead>
                                <tbody>
                                    <t t-set="total_quantity" t-value="0"/>
                                    <t t-foreach="doc.order_line" t-as="line">
                                        <tr>
                                            <td class="text-center">
                                                <span t-esc="line_index + 1"/>
                                            </td>
                                            <td class="quotation-html">
                                                <span t-field="line.name" t-options='{"widget": "html"}'/>
                                            </td>
                                            <td class="text-center">
                                                <span t-field="line.price_subtotal"/>
                                                <t t-if="line.get_total_original_price()">
                                                    <del><span t-esc="line.get_total_original_price()" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/></del>
                                                </t>
                                            </td>
                                            <td class="text-center">
                                                <t t-if="line.service_line_type == 'day'">
                                                    <t t-if="line.product_uom_qty != round(line.product_uom_qty)">
                                                        <span t-esc="line.product_uom_qty"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="int(line.product_uom_qty)"/>
                                                    </t>
                                                    <t t-set="total_quantity" t-value="total_quantity + line.product_uom_qty"/>
                                                </t>
                                                <t t-if="line.service_line_type == 'off'">
                                                    NA
                                                </t>
                                            </td>
                                            <td>
                                                <span t-field="line.team_members"/>
                                            </td>
                                            <td class="quotation-html">
                                                <span t-field="line.deliverables" t-options='{"widget": "html"}'/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr class="total">
                                        <td></td>
                                        <td>Total</td>
                                        <td class="text-right"><span t-field="doc.amount_untaxed"/></td>
                                        <td class="text-center">
                                            <t t-if="total_quantity != round(total_quantity)">
                                                <span t-esc="total_quantity"/> man-days
                                            </t>
                                            <t t-else="">
                                                <span t-esc="int(total_quantity)"/> man-days
                                            </t>
                                        </td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                    <t t-foreach="doc.amount_by_group" t-as="amount_by_group">
                                        <tr class="total">
                                            <td></td>
                                            <td><span t-esc="amount_by_group[0]"/></td>
                                            <td class="text-right">
                                                <span t-esc="amount_by_group[1]"
                                                t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                            </td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                    </t>
                                    <tr class="total">
                                        <td></td>
                                        <td>Net Total</td>
                                        <td class="text-right"><span t-field="doc.amount_total"/></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <t t-if="not doc.is_wst">
                        <t t-foreach="doc.breakdown_line_ids" t-as="breakdown_line">
                            <div class="page service_quotation font14" style="page-break-after: always;">
                                <div class="oe_structure"/>

                                <p>
                                    <strong>
                                        Breakdown on Phase <t t-esc="breakdown_line_index + 1"/>: <span t-field="breakdown_line.name"/>
                                    </strong>
                                </p>

                                <table class="table-breakdown" style="margin-top: -5px;">
                                    <colgroup>
                                        <col width="5%"/>
                                        <col width="25%"/>
                                        <col width="40%"/>
                                        <col width="10%"/>
                                        <col width="10%"/>
                                        <col width="10%"/>
                                    </colgroup>
                                    <thead>
                                        <th class="text-center">S/N</th>
                                        <th>Activities</th>
                                        <th>Stages</th>
                                        <th class="text-center">Consult.</th>
                                        <th class="text-center">No. of Days</th>
                                        <th class="text-center">Total Man-day</th>
                                    </thead>
                                    <tbody>
                                        <t t-set="total_mandays" t-value="0"/>
                                        <t t-foreach="breakdown_line.breakdown_phase_line_ids" t-as="line">
                                            <tr>
                                                <td class="text-center">
                                                    <span t-esc="line_index + 1"/>
                                                </td>
                                                <td class="quotation-html">
                                                    <span t-field="line.name" t-options='{"widget": "html"}'/>
                                                </td>
                                                <td class="quotation-html">
                                                    <span t-field="line.stages" t-options='{"widget": "html"}'/>
                                                </td>
                                                <td class="text-center va-middle">
                                                    <t t-if="line.consultation != round(line.consultation)">
                                                        <span t-esc="line.consultation"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="int(line.consultation)"/>
                                                    </t>
                                                </td>
                                                <td class="text-center va-middle">
                                                    <t t-if="line.days != round(line.days)">
                                                        <span t-esc="line.days"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="int(line.days)"/>
                                                    </t>
                                                </td>
                                                <td class="text-center va-middle">
                                                    <t t-if="line.total_mandays != round(line.total_mandays)">
                                                        <span t-esc="line.total_mandays"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="int(line.total_mandays)"/>
                                                    </t>
                                                    <t t-set="total_mandays" t-value="total_mandays + line.total_mandays"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <tr class="total">
                                            <td colspan="5" class="text-right">Total Man-Day</td>
                                            <td class="text-center">
                                                <t t-if="total_mandays != round(total_mandays)">
                                                    <span t-esc="total_mandays"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="int(total_mandays)"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                        <div style="page-break-after: always;"/>

                        <div class="page service_quotation font14" t-if="doc.timeline_line_ids">
                            <div class="oe_structure"/>

                            <div class="pb-2">
                                <strong>
                                    Proposed Project Timeline
                                    <div class="quotation-html">
                                        <span t-field="doc.timeline_remark" t-options='{"widget": "html"}'/>
                                    </div>
                                </strong>
                            </div>

                            <table class="table-timeline">
                                <colgroup>
                                    <col width="10%"/>
                                    <col width="45%"/>
                                    <col width="15%"/>
                                    <col width="15%"/>
                                    <col width="15%"/>
                                </colgroup>
                                <thead>
                                    <th class="text-center">Task ID</th>
                                    <th>Task / Descriptions</th>
                                    <th class="text-center">Duration</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.timeline_line_ids" t-as="line">
                                        <tr>
                                            <td class="text-center va-middle">
                                                <span t-esc="line_index + 1"/>
                                            </td>
                                            <td class="quotation-html">
                                                <span t-field="line.name" t-options='{"widget": "html"}'/>
                                            </td>
                                            <td class="text-center va-middle">
                                                <span t-field="line.duration"/>
                                            </td>
                                            <td class="text-center va-middle">
                                                <span t-esc="line.start_date.strftime('%d-%b-%y')"/>
                                            </td>
                                            <td class="text-center va-middle">
                                                <span t-esc="line.end_date.strftime('%d-%b-%y')"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        </t>
                    </t>

                    <div t-attf-class="footer o_standard_footer o_company_#{doc.company_id.id}_layout">
                        <div class="text-center" style="padding-top: 20px;">
                            <img src="/odes_quotation/static/src/img/odes.png" style="max-height: 35px;" alt="Logo"/>
                        </div>
                        <div class="text-center">
                            <span t-field="doc.company_id.website"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>