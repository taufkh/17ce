<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_quotation_company_configuration_form" model="ir.ui.view">
        <field name="name">quotation.company.configuration.form</field>
        <field name="model">res.company</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Configuration" create="0" delete="0">
                <sheet>
                    <notebook colspan="4">
                        <page string="Quotation">
                            <group groups="base.group_system">
                                <field name="quotation_to_company_id"/>
                                <field name="quotation_prefix_id"/>
                                <field name="quotation_old_prefix" required="quotation_to_company_id"/>
                                <field name="quotation_new_prefix" required="quotation_to_company_id"/>
                            </group>
                            <group>
                                <field name="quotation_description" widget="html"/>
                                <field name="quotation_timeline_remark" widget="html"/>
                                <field name="quotation_default_product_id"/>

                                <!-- tambahkan field untum m2o -->
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_quotation_company_configuration_tree" model="ir.ui.view">
        <field name="name">quotation.company.configuration.tree</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <tree string="Configuration" create="0" delete="0">
                <field name="name"/>
            </tree>
        </field>
    </record>



    <record id="view_odes_quotation_res_company_form" model="ir.ui.view">
        <field name="name">odes.quotation.res.company.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Quotation">
                    <group>
                        <group name="invoice_attachment" string="Invoice Attachment">
                            <field name="quotation_report_template" domain="[('model','=', 'sale.order')]" string="Quotation to use on email"/>
                            <!-- <field name="report_name" invisible="not report_template"/> -->
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>


    <record id="action_quotation_company_configuration" model="ir.actions.act_window">
        <field name="name">Configuration</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
           eval="[(5, 0, 0),
                  (0, 0, {'view_mode': 'tree', 'view_id': ref('view_quotation_company_configuration_tree')}),
                  (0, 0, {'view_mode': 'form', 'view_id': ref('view_quotation_company_configuration_form')})]"/>
    </record>

    <menuitem
        id="menu_quotation_company_configuration" name="Configuration"
        parent="sale.menu_sale_config" action="action_quotation_company_configuration" groups="sales_team.group_sale_manager"/>
</odoo>