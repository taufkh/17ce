<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="iot_quotation_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <table width="100%">
                            <tr>
                                <td><img t-att-src="'/mccoy_smart_iot_quotation/static/src/img/smarioT LOGO.png'" style="max-height: 65px;" alt="Logo"/></td>
                                <td><h3 style="text-align: right;">OFFICIAL QUOTATION</h3></td>
                            </tr>
                        </table>
                        <br/>
                        <div class="row">
                            <div class="col-5">
                                <table width="100%" style="font-size: 12px;">
                                    <tr>
                                        <td>
                                            <span style="text-decoration: underline; font-weight: bold;" t-field="o.company_id.name"/><br/>
                                            <span t-field="o.company_id.street"/> <span t-field="o.company_id.country_id"/> <span t-field="o.company_id.zip"/><br/>
                                            T: <span t-field="o.company_id.phone"/> F: <span t-field="o.company_id.fax"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-7">
                                <table width="100%" style="font-size: 12px;">
                                    <tr>
                                        <td width="45%" style="text-align : right;">DATE :</td>
                                        <td width="5%" rowspan="5"></td>
                                        <td width="50%"><span class="text-uppercase" t-esc="o.date_order.strftime('%d.%m.%Y')"/></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align : right;">QUOTATION NO :</td>
                                        <td><span class="text-uppercase" t-field="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="text-align : right;">TO :</td>
                                        <td>
                                            <span t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id.name"/>
                                            <span t-else="" t-field="o.partner_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align : right;">ATTN :</td>
                                        <td>
                                            <t t-if="o.contact_id">
                                                <span t-field="o.contact_id.name"/>&amp;nbsp;
                                            </t>
                                            <t t-else="">
                                                <span t-field="o.partner_id.name"/>&amp;nbsp;
                                            </t>
                                            <span class="text-nowrap" t-if="o.partner_id.phone">(<span t-field="o.partner_id.phone"/>)</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align : right;">ADDRESS :</td>
                                        <td>
                                            <span t-field="o.partner_id.contact_address_complete"/>
                                            <!-- <span t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}"/>
                                            <span t-else="" t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}"/> -->
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <br/>
                        <div class="row mt32 mb32">
                            <div class="col-auto">
                                <div style="min-height : 100px">
                                    <t t-set="task" t-value="1"/>
                                    <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                                        <thead style="font-size: 12px;">
                                            <tr style="background-color: #c3deb1">
                                                <th name="th_description" class="text-center" style="border:1px solid black;text-align:justify;"><span>Item</span></th>
                                                <th width="40%" name="th_desc" class="text-left" style="border:1px solid black;text-align:justify;"><span>Product</span></th>
                                                <th name="th_mpn" class="text-left" style="border:1px solid black;text-align:justify;"><span>Task/Description</span></th>
                                                <th name="th_qty" class="text-center" style="border:1px solid black;text-align:justify;"><span>Quantity</span></th>
                                                <th name="th_unit_price" class="text-center" style="border:1px solid black;text-align:justify;"><span>Unit Price</span></th>
                                                <th name="th_total" class="text-center" style="border:1px solid black;text-align:justify;"><span>UOM</span></th>
                                                <th name="th_total" class="text-center" style="border:1px solid black;text-align:justify;"><span>Total</span></th>
                                            </tr>
                                        </thead>
                                        <tbody style="font-size: 12px;" class="invoice_tbody">
                                            <t t-set="current_subtotal" t-value="0"/>
                                            <t t-set="line_count" t-value="0"/>
                                            <t t-set="lines" t-value="o.order_line"/>
                                            <t t-foreach="lines" t-as="line">
                                                <t t-set="line_count" t-value="line_count + 1"/>
                                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                                    <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                                        <td style="border:1px solid black;" name="account_invoice_line_name"><span class="text-nowrap" t-esc="task"/></td>
                                                        <td style="border:1px solid black;" class="text-left"><span t-field="line.product_id"/></td>
                                                        <td style="border:1px solid black;" class="text-left"><t t-out="line.name" /></td>
                                                        <td style="border:1px solid black;" class="text-center"><span t-field="line.product_uom_qty"/></td>
                                                        <td style="border:1px solid black;" class="text-center"><span t-esc="'%.2f'% line.price_unit"/></td>
                                                        <td style="border:1px solid black;" class="text-center o_price_total"><span t-field="line.product_uom.name" /></td>
                                                        <td style="border:1px solid black;" class="text-center o_lead_time"><span t-field="line.price_subtotal"/></td>
                                                    </t>
                                                    <t t-if="line.display_type not in ['line_section','line_note']">
                                                        <t t-set="task" t-value="task+1"/>
                                                    </t>
                                                    <t t-else=""></t>
                                                    <t t-if="line.display_type == 'line_section'">
                                                    <td colspan="99" style="border:1px solid black;">
                                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                    </td>
                                                    <t t-set="current_section" t-value="line"/>
                                                        <t t-set="current_subtotal" t-value="0"/>
                                                    </t>
                                                    <t t-if="line.display_type == 'line_note'">
                                                        <td colspan="99" style="border:1px solid black;">
                                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                        </td>
                                                    </t>
                                                </tr>
                                            </t>
                                            <tr>
                                                <td colspan="4" rowspan="3"></td>
                                                <th colspan="2" style="border:1px solid black;">Sub Total</th>
                                                <td style="border:1px solid black;"><span t-field="o.amount_untaxed"/></td>
                                            </tr>
                                            <tr>
                                                <th colspan="2" style="border:1px solid black;">Tax GST: 7%</th>
                                                <td style="border:1px solid black;">
                                                    <t t-foreach="o.amount_by_group" t-as="amount_by_group">
                                                        <t t-if="len(o.order_line.filtered(lambda line: line.tax_id)) in [0, 1] and o.amount_untaxed == amount_by_group[2]">
                                                            <strong><span class="text-nowrap" t-esc="amount_by_group[3]"/></strong>
                                                        </t>
                                                        <t t-else="">
                                                            <strong> <span class="text-nowrap" t-esc="amount_by_group[3]"/></strong>
                                                        </t>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr>
                                                <th colspan="2" style="border:1px solid black;">Total Amount</th>
                                                <td style="border:1px solid black;"><strong><span class="text-nowrap" t-field="o.amount_total"/></strong></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <t t-set="validity_quote" t-value="False"/>
                                <t t-set="payment_term" t-value="False"/>
                                <t t-set="currency" t-value="False"/>
                                <t t-set="freight_term" t-value="False"/>
                                <t t-set="term_condition" t-value="o.get_term_condition()"/>

                                <t t-if="'%(validity_quote)' in term_condition">
                                    <t t-set="term_condition" t-value="term_condition.replace('%(validity_quote)',str(o.validity_quote))"/>
                                </t>

                                <t t-if="'%(payment_term)' in term_condition">
                                    <t t-set="term_condition" t-value="term_condition.replace('%(payment_term)',str(o.payment_term_id.name))"/>
                                </t>

                                <t t-if="'%(currency)' in term_condition">
                                    <t t-set="term_condition" t-value="term_condition.replace('%(currency)',str(o.currency_id.name))"/>
                                </t>

                                <t t-if="'%(freight_term)' in term_condition">
                                    <t t-set="term_condition" t-value="term_condition.replace('%(freight_term)',str(o.freight_terms))"/>
                                </t>

                                <table width="100%" style="font-size: 12px;">
                                    <tr>
                                        <td padding= "10px">
                                            <t t-out="term_condition"/>
                                        </td>
                                    </tr>
                                </table>
                                
                                <br/>
                                <div class="row">
                                    <div class="col-4">
                                        <!-- <table style="font-size: 12px;" width="100%">
                                            <tr><th style="border:1px solid black;">Comments or Special Instructions:</th></tr>
                                            <tr><th style="border:1px solid black;height:20px;"> </th></tr>
                                            <tr><td style="border:1px solid black;height:25px;"></td></tr>
                                        </table> -->
                                        <br/>
                                        <p style="font-size: 12px;">Thank you for your business.</p>
                                        <table style="font-size: 12px;" width="100%">
                                            <!-- <tr><td><b>Name:</b></td></tr>
                                            <tr><td><b>Designation:</b></td></tr> -->
                                            <tr><td><span t-field="o.user_id.name"/></td></tr>
                                            <tr><td><span t-field="o.designation"/></td></tr>
                                        </table>
                                    </div>
                                    <div class="col-4">

                                    </div>
                                    <div class="col-4">
                                        <br/>
                                        <table style="font-size: 12px;" width="100%">
                                            <tr><td>Accepted by</td></tr>
                                            <tr><th>Company name:</th></tr>
                                            <tr><td>Signature/Company Stamp</td></tr>
                                            <tr><td height="80px"></td></tr>
                                            <tr><th style="border-top:1px solid black;">Authorize Signature</th></tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="iot_quotation_report_action" model="ir.actions.report">
        <field name="name">Mccoy - Smart IOT</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mccoy_smart_iot_quotation.iot_quotation_report</field>
        <field name="report_file">mccoy_smart_iot_quotation.iot_quotation_report</field>
        <field name="print_report_name">('Smart IOT Quotation - %s' % (object.name))</field>
        <field name="binding_model_id" search="[('model', '=', 'sale.order')]"/>
        <field name="binding_type">report</field>
    </record>

    <record id="iot_paperformat_a4" model="report.paperformat">
        <field name="name">IOT Paper A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">12.5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">80</field>
    </record>

    <record id="iot_quotation_report_action" model="ir.actions.report">
        <field name="paperformat_id" ref="iot_paperformat_a4"/>
    </record>
    
</odoo>
