                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="smart_iot_term_condition_action" model="ir.actions.act_window">
        <field name="name">Smart IOT Term and Condition</field>
        <field name="res_model">smart.iot.term.condition</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="mccoy_smart_iot_quotation.smart_iot_term_condition_view_tree"/>
    </record>

    <menuitem
            id="menu_term_condition"
            name="Smart IOT T&amp;C"
            parent="sale.menu_sales_config"
            action="mccoy_smart_iot_quotation.smart_iot_term_condition_action"
            sequence="10"/>

