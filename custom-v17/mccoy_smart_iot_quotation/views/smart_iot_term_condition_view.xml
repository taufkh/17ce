<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="smart_iot_term_condition_view_tree" model="ir.ui.view">
        <field name="name">smart.iot.term.condition.view.tree</field>
        <field name="model">smart.iot.term.condition</field>
        <field name="arch" type="xml">
            <tree string="Smart IOT Term and Condition">
                <field name="name" />
            </tree>
        </field>
    </record>

    <record id="smart_iot_term_condition_view_form" model="ir.ui.view">
        <field name="name">smart.iot.term.condition.view.form</field>
        <field name="model">smart.iot.term.condition</field>
        <field name="arch" type="xml">
            <form string="Smart IOT Term and Condition">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Term and Condition Form"/>
                        <h1><field name="name" required="1"/></h1>
                        <br/><br/>
                    </div>
                    <div>
                        <h3>Term and Condition Form</h3>
                        In order to build customized Term and Condition:
                        You can use the following keywords in the text
                        <table>
                            <tr>
                                <td>%(validity_quote)</td>
                                <td>:</td>
                                <td>Validity Quote</td>
                            </tr>
                            <tr>
                                <td>%(payment_term)</td>
                                <td>:</td>
                                <td>Payment Terms</td>
                            </tr>
                            <tr>
                                <td>%(currency)</td>
                                <td>:</td>
                                <td>Currency</td>
                            </tr>
                            <tr>
                                <td>%(freight_term)</td>
                                <td>:</td>
                                <td>Freight Terms</td>
                            </tr>
                        </table>
                        <br/>
                    </div>
                    <notebook>
                        <page name="term_condition" string="Term and Condition">
                            <field name="term_condition"  widget="html"/>
                        </page>
