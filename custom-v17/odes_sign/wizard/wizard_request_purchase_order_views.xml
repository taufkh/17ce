<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="odes_request_purchase_order_wizard_view_form" model="ir.ui.view">
        <field name="name">odes.request.purchase.order.wizard.form</field>
        <field name="model">odes.request.purchase.order.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    
                    <field name="line_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="product_id" required="1"/>
                            <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'supplier', 'show_vat': True}"
                                placeholder="Name, TIN, Email, or Reference"
                            />
                            <field name="qty_demand" readonly="1"/>
                            <field name="qty"/>
                            
                            
                            <!-- <field name="is_create_po"/> -->
                            <field name="move_id" invisible="1"/>
                            
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="action_create_po" string="Create PO" type="object"/>
                </footer>
            </form>            
        </field>
    </record>

    <record id="odes_request_purchase_order_wizard_view_form_action" model="ir.actions.act_window">
        <field name="name">Mccoy Create PO</field>
        <field name="res_model">odes.request.purchase.order.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="stock.model_stock_picking" />
        <field name="binding_view_types">list</field>
    </record>

    <!-- <menuitem id="odes_request_purchase_order_wizard_view_form_menu"
        name="Mccoy Create PO"
        parent="mrp.menu_mrp_reporting"
        action="odes_request_purchase_order_wizard_view_form_action"/> -->
</odoo>