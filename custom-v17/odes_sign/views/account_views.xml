<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit" model="ir.ui.view">
        <field name="name">view_move_form_inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='country_code']" position="after">
                <field name="is_expense" invisible="1"/>
            </xpath>
            <xpath expr="//group[@id='header_right_group']" position="inside">
                <field name="account_balance_id" invisible="not is_expense" required="is_expense" options="{'no_create': True}" domain="[('deprecated', '=', False)]"/>
            </xpath>
        </field>
    </record>

    <record id="action_odes_accounting_expense" model="ir.actions.act_window">
        <field name="name">Expense Input</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="account.view_in_invoice_tree"/>        
        <field name="search_view_id" ref="account.view_account_invoice_filter"/>
        <field name="domain">[('move_type', '=', 'in_receipt'), ('is_expense', '=', True)]</field>
        <field name="context">{'default_move_type': 'in_receipt', 'default_is_expense': True}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Register a new expense
          </p>
        </field>
    </record>

    <menuitem id="menu_odes_accounting_expense" action="action_odes_accounting_expense" parent="account.menu_finance_payables"/>
</odoo>