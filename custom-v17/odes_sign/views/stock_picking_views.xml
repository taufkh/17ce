<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        
        <record id="view_picking_form_purchase_inherit" model="ir.ui.view">
            <field name="name">view.picking.form.purchase.inherit</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field eval="1" name="priority"/>
            <field name="arch" type="xml">
                <data>
                    <div name="button_box" position="inside">
                        <button class="oe_stat_button o_res_partner_tip_opp" type="object"
                            name="action_view_purchase"
                            icon="fa-star">
                            <field string="Purchase" name="purchase_count" widget="statinfo"/>
                        </button>
                    </div>
                </data>
            </field>
        </record>


</odoo>