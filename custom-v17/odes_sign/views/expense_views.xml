<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_expense_view_form_odes_sign" model="ir.ui.view">
        <field name="name">hr.expense.view.form.odes.sign</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
           <xpath expr="//field[@name='date']" position="after">
                <field name="expense_approved_dates"/>
            </xpath>
        </field>
    </record>

    <record id="hr_expense_sheet_view_form_odes_sign" model="ir.ui.view">
        <field name="name">hr.expense.sheet.view.form.odes.sign</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_sheet_move_create']" position="attributes">
                <attribute name="invisible">"1"</attribute>
            </xpath>
            <xpath expr="//header" position="inside">
                <button string="UPDATE TO POSTED" class="btn btn-primary" name="update_to_posted" type="object" invisible="state != 'approve'" groups="account.group_account_invoice"/>
            </xpath>
            <xpath expr="//button[@name='action_register_payment']" position="replace">
                <button name="set_to_paid"
                            type="object"
                            class="oe_highlight o_expense_sheet_pay"
                            invisible="state != 'post'"                            
                            string="Update to Paid"
                            groups="account.group_account_invoice"/>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="expense_approved_dates"/>
                <field name="paid_date" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='expense_line_ids']" position="attributes">
                <attribute name="readonly">state not in ('draft', 'submit')</attribute>
            </xpath>
        </field>
    </record>

    <record id="hr_expense_sheet_view_form_odes_sign_inherit_hr_admin" model="ir.ui.view">
        <field name="name">hr.expense.sheet.view.form.odes.sign.inherit.hr.admin</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense_sheet_view_form_odes_sign"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='paid_date']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
        </field>
    </record>

</odoo>
