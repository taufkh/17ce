<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="odes_accounting.report_odes_proforma_invoice_document">
              <t t-foreach="docs" t-as="o">
                <t t-call="web.html_container">
                    <t t-call="web.external_layout">
                        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
                        <div class="header">
                          <div class="row mt32 mb32">
                            <div class="col-auto">
                                <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 65px;" alt="Logo"/>
<!--                                <t t-if="o.journal_id.logo_journal">
                                  <img t-if="o.journal_id.logo_journal" t-att-src="image_data_uri(o.journal_id.logo_journal)" style="max-height: 65px;" alt="Logo"/>
                                  
                                
                                </t> 
                                <t t-if="not o.journal_id.logo_journal">
                                  <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 65px;" alt="Logo"/>
                                </t> -->
                                         
                            </div>
                            <div class="col-auto">
                              <h2 style="text-align: right;">PROFORMA INVOICE</h2>
                            </div>
                            </div>

                            <!-- <br/> -->

                            
                             <div class="row mt32 mb32">
                            <div class="col-auto">
                           <div><span style="font-size : 15px; text-decoration: underline; font-weight: bold;" t-field="o.company_id.name"/></div>
                            <div style="font-size : 12px;"><span t-field="o.company_id.house_no"/> </div>
                            <div style="font-size : 12px;"><span t-field="o.company_id.unit_no"/> </div>
                            <div style="font-size : 12px;"><span t-field="o.company_id.street"/> </div>
                            <div style="font-size : 12px;"><span t-field="o.company_id.street2"/> </div>
                            <div style="font-size : 12px;"><span t-field="o.company_id.city"/> <span t-field="o.company_id.state_id"/></div>
                            <div style="font-size : 12px;"> <span t-field="o.company_id.country_id"/> <span t-field="o.company_id.zip"/> </div>
                            <div style="font-size : 12px;">Tel : <span t-field="o.company_id.partner_id.phone"/></div>
                            <div style="font-size : 12px;">Fax : <span t-field="o.company_id.fax"/></div>                  
                            </div>
                            <div style="font-size : 12px;" class="col-auto">
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                Company Reg No : 
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <span class="text-uppercase" t-field="o.company_id.vat"/>
                                </div>
                                
                              </div>
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                GST Reg No :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <span class="text-uppercase" t-field="o.company_id.company_registry"/>
                                </div>
                                
                              </div>
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                DATE :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <span class="text-uppercase" t-esc="o.date.strftime('%d.%m.%Y')"/>
                                </div>
                                
                              </div>
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                INVOICE NO :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <span class="text-uppercase" t-field="o.name"/>
                                </div>
                                
                              </div>
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                CUSTOMER PO NO :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <t t-if="o.po_no">
                                  <span t-field="o.po_no"/>
                                </t>
                                <t t-else="">
                                  <span t-field="o.ref"/>
                                </t>
                                </div>
                                
                              </div>
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                QUOTATION NO :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <span t-esc="o.get_quotation_no()"/>
                                </div>
                                
                              </div>
                              
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                PAYMENT TERMS :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                <span t-field="o.partner_id.property_payment_term_id"/>
                                </div>                               
                              </div>
                              <div class="row mt32 mb32">
                                <div class="col-auto" style="text-align : right;">
                                FREIGHT TERMS :
                                </div>
                                <div class="col-auto" style="text-align : right;">
                                  <span t-field="o.freight_terms"/>
                                </div>
                                
                              </div>
                              
                              
                            </div>
                            </div>
                            <!-- <br/> -->
                        </div>
                        <div class="page">
                          
                             <table  style=" font-size : 14px; width:80%; border:1px solid #000;">
                              <tr>
                                  <th style="border-right: 1px solid #000 !important;">
                                      <div style="width:340px;height:170px;">
                                        <br/>
                                          <div class="col-auto" t-if="o.partner_id">
                                            <div class="row mt32 mb32">
                                              <table style="padding : 15px; width: 100%;">
                                                <tr>
                                                    <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Bill to</td>
                                                    <td style="font-size:12px; padding-left: 5px;">:</td>
                                                    <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                                        <span t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id" t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}"/>
                                                        <span t-else="" t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}"/>
                                                    </td>
                                                </tr>
                                                <tr> 
                                                  <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">C.Person</td>
                                                  <td style="font-size:12px; padding-left: 5px;">:</td>
                                                    <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                                        <span t-field="o.contact_id.name"/>
                                                    </td>
                                                </tr>
                                                <tr> 
                                                  <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Telephone</td>
                                                  <td style="font-size:12px; padding-left: 5px;">:</td>
                                                    <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                                      <span t-field="o.contact_id.phone"/>
                                                    </td>
                                                </tr>
                                            </table>
                                                
                                              </div>
                                              
                                          </div>
                                      </div>
                                  </th>
                                  <th>
                                      <div style="width:340px;height:170px;">
                                        <br/>
                                          <div class="col-auto" t-if="o.partner_id">
                                            <div class="row mt32 mb32">
                                                <table style="padding : 15px; width: 100%;">
                                                    <tr>
                                                        <td style="padding-left: 10px; text-align:left; font-size:12px;width:80px">Deliver to</td>
                                                        <td style="font-size:12px; padding-left: 5px;">:</td>
                                                        <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                                            <span t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id" t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}"/>
                                                            <span t-else="" t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}"/>
                                                        </td>
                                                    </tr>
                                                </table>
                                              </div>
                                              
                                          </div>
                                      </div>
                                  </th>
                              </tr>
                          </table>
                          <!-- <br/> -->
                            <div style="min-height : 280px">
                      <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                        <thead style="font-size : 12px;">
                            <tr style="background-color: lightgrey;">
                                <th name="th_description" style= "width:100px" class="text-left"><span>Cust P/N</span></th>
                                <th name="th_desc" style= "width:150px" class="text-left"><span>P/N Description</span></th>
                                <th name="th_desc" style= "width:120px" class="text-center"><span>Est Del Date</span></th>
                                <th name="th_unit_price" style= "width:60px" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Unit Price</span></th>
                                <th name="th_qty" style= "width:60px" t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Order Qty</span></th>
                                <th name="th_total" style= "width:80px"  t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Total Amount</span></th>
                                
                            </tr>
                        </thead>
                        <tbody style="font-size : 12px;" class="invoice_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-set="line_count" t-value="0"/>
                            
                            <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>

                            <t t-foreach="lines" t-as="line">
                              <t t-set="line_count" t-value="line_count + 1"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else 'line.display_type == line'">
                                    <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                        <td name="account_invoice_line_name"><span t-field="line.product_id.name"/></td>
                                        <td class="text-left"><span t-field="line.name"/></td>
                                        <td class="text-center"><span t-if="line.move_id.est_del_date" t-esc="line.move_id.est_del_date.strftime('%d.%m.%Y')"/></td>
                                        <td class="text-right">
                                            <span class="text-nowrap" t-field="line.price_unit" groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                        <td class="text-right">
                                            <span class="text-nowrap" t-esc="'%.d'%line.quantity" groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                        <td class="text-right o_price_total">
                                            <span class="text-nowrap" t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </td>
                                    </t>
                                </tr>

                                <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                                    <tr class="is-subtotal text-right">
                                        <td colspan="99">
                                            <strong class="mr16">Subtotal</strong>
                                            <span t-esc="current_subtotal" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>
                  </div>
                   <!-- <div style="font-size : 12px" class="text-left">Remarks: T/T and correspondent bank charges to be borne by payer</div> -->
                   <div style="font-size : 12px; border-bottom: 1px solid black; position: absolute; width : 680px">
                      <!-- <i>  <span t-field="o.company_id.remarks_header"/></i> -->
                      <br/>
                      <i><span style="font-size : 11px; font-style: italic;" >For attention: Mc'Coy Components offer to sell product shall be solely in accordance with the standard Terms and Conditions of Sales </span></i>
                    </div>
                    <br/>
                    <!-- <div style="font-size : 11px; font-style: italic;" >For attention: Mc'Coy Components offer to sell product shall be solely in accordance with the standard Terms and Conditions of Sales </div> -->
                    <t t-if="line_count &lt;= 5">
                      <!-- <br/><br/><br/><br/><br/> -->
                      </t>
                            <br/>
                    
                    <div class="row mt32 mb32">
                      
                                <div class="col-auto">
                                  
                                 <div style="margin-left : -15px" class="col-auto">
                              <div><span style="font-size : 10px; text-decoration: underline; font-weight: bold;"> Please Kindly T/T the amount to McCOy's bank as details below:  </span></div>
                                    
                                  
                              <!-- <div><span style="font-size : 11px; text-decoration: underline;"> Bank Details </span></div> -->
                              <div class="row mt32 mb32">
                                <table style="font-size : 11px; width: 100%;">
                                                <tr>
                                                    <td style="padding-left: 15px" width="150px">Currency</td>
                                                    <td width="10px">:</td>
                                                    <td>
                                                         <span t-field="o.currency_id"/> 
                                                    </td>
                                                </tr>
                                            </table>
                                
                                
                              </div>
                              <div class="row mt32 mb32">
                                <table style="font-size : 11px; width: 100%;">
                                                <tr>
                                                    <td style="padding-left: 15px" width="150px">Beneficiary</td>
                                                    <td width="10px">:</td>
                                                    <td>
                                                         <span t-field="o.company_id.name"/>

                                                    </td>
                                                </tr>
                                            </table>
                                
                                
                              </div>
                              
                              <div class="row mt32 mb32">
                                <table style="font-size : 11px; width: 100%;">
                                                <tr>
                                                    <td style="padding-left: 15px" width="150px">Bank</td>
                                                    <td width="10px">:</td>
                                                    <td>
                                                         <span>DBS BANK</span>

                                                    </td>
                                                </tr>
                                            </table>
                                
                                
                                
                              </div>
                              <div class="row mt32 mb32">
                                <table style="font-size : 11px; width: 100%;">
                                    <tr>
                                        <td style="padding-left: 15px" width="150px">Address</td>
                                        <td width="10px">:</td>
                                        <td>
                                             <span>12 Marine Boulevard, Marina Bay Financial Centre</span>
<span>Tower 3, DBS, Asia Central, Singapore 018982. </span>

                                        </td>
                                    </tr>
                                </table>
                                
                                
                              </div>
                              
                              <div class="row mt32 mb32">
                                <table style="font-size : 11px; width: 100%;">
                                    <tr>
                                        <td style="padding-left: 15px" width="150px">Account No</td>
                                       <td width="10px">:</td>
                                        <td>
                                             <t t-if="o.currency_id == o.company_id.currency_id">
                                                <!-- <span>0109004947 (SGD)</span> -->
                                                <span> 0003017698013022 (USD)</span>
                                              </t>
                                              <t t-if="o.currency_id != o.company_id.currency_id">
                                               <span> 0109004947 (USD)</span>
                                              </t>

                                        </td>
                                    </tr>
                                </table>
                                
                                
                              </div>
                              <div class="row mt32 mb32">
                                <table style="font-size : 11px; width: 100%;">
                                    <tr>
                                        <td style="padding-left: 15px" width="150px">SWIFT Code</td>
                                        <td width="10px">:</td>
                                        <td>
                                             <span>DBSSSGSG</span>

                                        </td>
                                    </tr>
                                </table>
                                
                                
                              </div>
                              
                              
                            </div>
                                  
                                  <!--<span t-field="o.company_id.remarks"/>-->
                                  
                                </div>

                                <div class="col-auto" style="margin-top : 10px; max-height: 80px;">
                                  
                                  <table class="table" style="  font-size : 11px; font-weight : 800; width:80%; float : right; border:1px solid #000;">
                                    <tr class="border-black o_total" style="border-bottom: 1px solid #000 !important;">
                                        <td  style="padding: 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;"><strong style="padding-left : 8px;">SUBTOTAL</strong></td>
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <!-- <strong><span t-field="o.invoice_subtotal"/></strong> -->
                                            <strong><span t-field="o.amount_total"/></strong>
                                        </td>
                                    </tr>
                                    <tr style="">
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                                          <strong style="padding-left : 8px;">Downpayment Requested <!-- <span t-field="o.percentage_downpayment"/> --> </strong></td>
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <!-- <strong><span t-field="o.invoice_downpayment"/></strong> -->
                                            <!-- need to fix for downpayment -->
                                        </td>
                                    </tr>
                                    <t t-foreach="o.taxes()" t-as="tx">
                                      <t t-if="tx['amount'] * (tx['tax']/100) != 0">
                                        <tr style="">
                                          <td
                                            style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                                            <strong style="padding-left : 8px;">GST <span t-esc="int(tx['tax'])" />% on Downpayment</strong>
                                          </td>
                                          <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <strong><span t-if="o.currency_id" t-field="o.currency_id.symbol" />
                                              <t t-esc="tx['amount'] * (tx['tax']/100)"
                                                    t-options="{'widget': 'float', 'precision': 2}" />
                                            </strong>
                                          </td>
                                        </tr>
                                      </t>
                                    </t>
                                    
                                    <tr style="">
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; "><strong style="padding-left : 8px;">
                                          <t t-if="o.currency_id == o.company_id.currency_id">
                                                <span>Please Pay (USD)</span>
                                              </t>
                                              <t t-if="o.currency_id != o.company_id.currency_id">
                                               <span> Please Pay (<span t-field="o.currency_id"/>)</span>
                                              </t>

                                        </strong></td>
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <strong><span class="text-nowrap" t-field="o.amount_total"/></strong>
                                        </td>
                                    </tr>
                                    
                                </table>
                                <br/>
                                
                                  
                            </div>
                            
                            
                                <!--<img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 65px;" alt="Logo"/>-->
                      </div>
                                <div class="row mt32 mb32">
                                  <div class="col-auto">
                                    <div class="signature">
                                      <br/>
                                      <br/>
                                      <div class="row mt16 mb16">
                                        
                                        <div class="col-auto">
                                         <img style="width : 24%; margin-left: 95px;" src="/odes_sign/static/src/img/stamp_mccoy-removebg.png"/>
                                         </div>
                                        
                                        </div>
                                      
                                      
                                      <div>________________________________________________</div>
                                      <div style="margin-left: 75px; font-weight : 900;">Authorized Signature</div>
                                    </div>
                                  </div>
                                  <div class="col-auto">
                                    <t t-if="o.journal_id.logo_journal">
                                      <br/>
                                      <br/>
                                      <br/>
                                      <br/>
                                      <br/>
                                      
                                      <img t-if="o.journal_id.logo_journal" t-att-src="image_data_uri(o.journal_id.logo_journal)" style="max-height: 45px; margin-left : 235px;  " alt="Logo"/>
                                    </t>
                                  </div>
                                </div> 
                           </div>
                    </t>
                </t>
            </t>
            
            
        </template>

