                                             <span>All Bank commission as well as bank charges are to be borne by payer</span>

                                        </td>
                                    </tr>
                                </table>
                                
                                
                              </div>
                              
                              
                            </div>
                            <br/>
                                
                                </div>
                                <div class="col-auto" style="margin-top : 10px">                                  
                                  <table class="table" style="  font-size : 12px; font-weight : 800; width:80%; float : right; border:1px solid #000;">
                                    <tr class="border-black o_total" style="border-bottom: 1px solid #000 !important;">
                                        <td style="padding: 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;"><strong style="padding-left : 8px;">SUBTOTAL</strong></td>
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <strong><span t-field="o.amount_untaxed"/></strong>
                                        </td>
                                    </tr>
                                    <tr style="">
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; "><strong style="padding-left : 8px;">DISCOUNT</strong></td>
                                        <td class="padding : 5px; text-right" style="padding : 1px; border-bottom: 1px solid #000 !important;">
                                            <!--<span t-field="o.amount_untaxed"/>-->
                                        </td>
                                    </tr>
                                    <tr style="">
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; "><strong style="padding-left : 8px;">FREIGHT</strong></td>
                                        <td class="padding : 5px; text-right" style="padding : 1px; border-bottom: 1px solid #000 !important;">
                                            <!--<span t-field="o.amount_untaxed"/>-->
                                        </td>
                                    </tr>
                                    <tr style="">
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;"><strong style="padding-left : 8px;">GST 8 %</strong></td>
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <t t-foreach="o.amount_by_group" t-as="amount_by_group">
                                                    <t t-if="len(o.line_ids.filtered(lambda line: line.tax_line_id)) in [0, 1] and o.amount_untaxed == amount_by_group[2]">
                                                            <strong><span class="text-nowrap" t-esc="amount_by_group[3]"/></strong>
                                                        
                                                    </t>
                                                    <t t-else="">
                                                        
                                                           <strong> <span class="text-nowrap" t-esc="amount_by_group[3]"/></strong>
                                                        
                                                    </t>
                                                
                                            </t>
                                        </td>
                                    </tr>
                                    <tr style="">
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; "><strong style="padding-left : 8px;">Total Amount</strong></td>
                                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                            <strong><span class="text-nowrap" t-field="o.amount_total"/></strong>
                                        </td>
                                    </tr>
                                    <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()"/>
                        <t t-foreach="payments_vals" t-as="payment_vals">
                            <tr style="">
                                <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; "><strong style="padding-left : 8px;"><i class="oe_form_field text-right oe_payment_label">Paid on <t t-esc="payment_vals['date']" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></i></strong></td>
                                <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                    <strong><span t-esc="payment_vals['amount']" t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" class="text-nowrap"/></strong>
                                </td>
                            </tr>
                        </t>
                        <t t-if="len(payments_vals) &gt; 0">
                          <tr style="">
                                <td style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; "><strong style="padding-left : 8px;">Amount Due</strong></td>
                                <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                    <strong><span class="text-nowrap" t-field="o.amount_residual"/></strong>
                                </td>
                            </tr>
                        </t>
                                    
                                </table>
                                <br/>
                                
                                  
                    </div>
                            
                                </div>
                                <div class="row mt32 mb32">
                                  <div class="col-auto">
                                    <div class="signature">
                                      <br/>
                                      <br/>
                                      <div class="row mt16 mb16">
                                        
                                        <div class="col-auto">
                                         <img style="width : 24%; margin-left: 95px;" src="/odes_sign/static/src/img/stamp_mccoy-removebg.png"/>
                                         </div>
                                        
                                        </div>
                                      
                                      
                                      <div>________________________________________________</div>
                                      <div style="margin-left: 75px; font-weight : 900;">Authorized Signature</div>
                                    </div>
                                  </div>
                                  <div class="col-auto">
                                    <t t-if="o.journal_id.logo_journal">
                                      <br/>
                                      <br/>
                                      <br/>
                                      <br/>
                                      <br/>
                                      
                                      <!-- <img t-if="o.journal_id.logo_journal" t-att-src="image_data_uri(o.journal_id.logo_journal)" style="max-height: 45px; margin-left : 235px;  " alt="Logo"/> -->
                                    </t>
                                  </div>
                                  
                                </div>
                                <p style="font-size:15px">This is a computer generated invoice and no signature required</p>
                                
                           </div>     
                                
                           </div>
                          
                        
                    </t>
                </t>
            </t>
            
            
            
        </template>

