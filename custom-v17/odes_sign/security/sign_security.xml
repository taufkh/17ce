<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_odes_purchase_confirm" model="res.groups">
        <field name="name">Mccoy Confirm Purchase</field>
        <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        <field name="category_id" ref="base.module_category_inventory_purchase"/>
         <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="purchase.group_purchase_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="base.module_category_inventory_purchase"/>
        <field name="implied_ids" eval="[(4, ref('group_odes_purchase_confirm'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>


</odoo>