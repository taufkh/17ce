<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ceris_rebranding.res_config_edition" t-inherit="res_config_edition" t-inherit-mode="extension">
        <xpath expr="//h3" position="replace">
            <h3 class="px-0">
                CERIS <t t-esc="serverVersion"/>
                (Community Edition)
            </h3>
        </xpath>
        <xpath expr="//small" position="replace">
            <small>
                Copyright © 2004
                <a target="_blank" href="https://ceris.id" style="text-decoration: underline;">CERIS</a>
                <a id="license" target="_blank" href="http://www.gnu.org/licenses/lgpl.html" style="text-decoration: underline;">GNU LGPL Licensed</a>
            </small>
        </xpath>
    </t>
</templates>
