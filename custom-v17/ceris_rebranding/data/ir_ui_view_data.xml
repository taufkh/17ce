<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="web.brand_promotion_message" model="ir.ui.view">
        <field name="arch" type="xml">
            <t name="Brand Promotion Message" t-name="web.brand_promotion_message">
                <t t-set="ceris_logo">
                    <a target="_blank" t-attf-href="https://ceris.id?utm_source=db&amp;utm_medium=#{_utm_medium}" class="badge text-bg-light">
                        <span style="font-weight: 700; letter-spacing: .02em;">CERIS</span>
                    </a>
                </t>
                <t t-set="final_message">Powered by %s%s</t>
                <t t-out="final_message % (ceris_logo, _message and ('- ' + _message) or '')"/>
            </t>
        </field>
    </record>

    <record id="ceris_res_config_settings_about_inherit" model="ir.ui.view">
        <field name="name">ceris.res.config.settings.about.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//widget[@name='res_config_edition']" position="replace">
                <div class="o_web_settings_compact_subtitle text-muted">
                    <div class="user-heading">
                        <h3 class="px-0">CERIS (Community Edition)</h3>
                    </div>
                    <small>
                        Copyright © 2004
                        <a target="_blank" href="https://ceris.id" style="text-decoration: underline;">CERIS</a>
                        <a id="license" target="_blank" href="http://www.gnu.org/licenses/lgpl.html" style="text-decoration: underline;">GNU LGPL Licensed</a>
                    </small>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
