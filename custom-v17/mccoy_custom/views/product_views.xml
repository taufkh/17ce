<odoo>

    <record id="product.product_packaging_tree_view" model="ir.ui.view">
            <field name="name">product.packaging.tree.view</field>
            <field name="model">product.packaging</field>
            <field name="arch" type="xml">
                <tree string="Product Packagings">
                    <field name="sequence" widget="handle"/>
                    <field name="product_id"/>
                    <field name="name" string="Packaging"/>
                    <field name="qty"/>
                    <field name="product_uom_id" options="{'no_open': True, 'no_create': True}" groups="uom.group_uom"/>
                    <field name="manufacturing_company_id"/>
                    <field name="company_id" invisible="1"/>
                </tree>
            </field>
        </record>



        <record id="product.product_packaging_form_view" model="ir.ui.view">
            <field name="name">product.packaging.form.view</field>
            <field name="model">product.packaging</field>
            <field name="arch" type="xml">
                <form string="Product Packaging">
                    <sheet>
                        <label for="name" string="Packaging"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                        <group>
                            <field name="id" invisible='1'/>
                            <group name="group_product">
                                <field name="product_id"  required='True' readonly="id"/>
                            </group>
                            <group name="qty">
                                <label for="qty" string="Contained quantity"/>
                                <div class="o_row">
                                    <field name="qty"/>
                                    <field name="product_uom_id" options="{'no_open': True, 'no_create': True}" groups="uom.group_uom"/>
                                </div>
                                <field name="barcode"/>
                                <field name="manufacturing_company_id"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    <record id="product.product_supplierinfo_tree_view" model="ir.ui.view">
            <field name="name">product.supplierinfo.tree.view</field>
            <field name="model">product.supplierinfo</field>
            <field name="arch" type="xml">
                <tree string="Vendor Information" multi_edit="1">
                    <field name="sequence" widget="handle"/>
                    <field name="name" readonly="1"/>
                    <field name="product_id" readonly="1" optional="show"
                        invisible="context.get('product_template_invisible_variant', False)"
                        groups="product.group_product_variant"/>
                    <field name="product_tmpl_id" string="Product" readonly="1"
                        invisible="context.get('visible_product_tmpl_id', True)"/>
                    <field name="product_name" optional="hide"/>
                    <field name="volume" readonly="1" force_save="1" invisible="1"/>
                    <field name="mpn"/>
                    <field name="min_qty" string="Quantity" optional="show"/>
                    <field name="price" string="Price" optional="show"/>
                    <field name="product_code" optional="hide"/>
                    <field name="currency_id" groups="base.group_multi_currency"/>
                    <field name="date_start" optional="hide"/>
                    <field name="date_end" optional="hide"/>
                    <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                    <field name="product_uom" groups="uom.group_uom"/>
                    <field name="delay" optional="hide"/>
                </tree>
            </field>
        </record>

    <record id="product_wishlist_form_view" model="ir.ui.view">
        <field name="name">product_wishlist_form_view</field>
        <field name="model">product.wishlist</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="create_date" readonly="1"/>
                        <field name="partner_id" string="Partner"/>
                        <field name="product_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_wishlist_tree_view" model="ir.ui.view">
        <field name="name">product_wishlist_tree_view</field>
        <field name="model">product.wishlist</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id" string="Partner"/>
                <field name="create_date"/>
                <field name="product_id"/>
            </tree>
        </field>
    </record>

    <record id="product_wishlist_action" model="ir.actions.act_window">
        <field name="name">Product Wishlist</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">product.wishlist</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="product_wishlist_menu" name="Product Wishlist"
              action="product_wishlist_action"
              parent="website_sale.menu_catalog"
              sequence='3'
              />

    <record id="product_class_form_view" model="ir.ui.view">
        <field name="name">product_class_form_view</field>
        <field name="model">product.class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_class_tree_view" model="ir.ui.view">
        <field name="name">product_class_tree_view</field>
        <field name="model">product.class</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="product_class_action" model="ir.actions.act_window">
        <field name="name">Product Class</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">product.class</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="mccoy_custom.product_class_tree_view"/>
    </record>

    <menuitem id="product_class_menu" name="Product Class"
              action="product_class_action"
              parent="website_sale.menu_ecommerce_settings"
               sequence="3"/>


    <record id="ecommerce_theme.product_brand_form_view" model="ir.ui.view">
        <field name="name">product.brand.form</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                     <field name="image" widget='image' class="oe_avatar"/>
                    <group>
                        <field name="name"/>
                        <field name="manufacturing_company_id"/>
                        <field name="description"/>
                        <field name="is_mccoypublished"/>
                        <field name="page_id"/>
                        <field name="key_search"/>
                        <field name="template_product"/>
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record model="ir.ui.view" id="mccoy_custom_product_public_categ_form_view">
        <field name="name">mccoy_custom_product_public_categ_form_view</field>
        <field name="model">product.public.category</field>
        <field name="inherit_id" ref="website_sale.product_public_category_form_view"/>
        <field name="arch" type="xml">
            <field name="website_id" position="after">
                <field name="is_mccoypublished"/>
            </field>
                
        </field>
    </record>

    <record id="ecommerce_theme.product_brand_tree_view" model="ir.ui.view">
        <field name="name">product.brand.tree</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="manufacturing_company_id"/>
                <field name="description"/>
                <field name="is_mccoypublished"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <record id="ecommerce_theme.product_brand_action_form" model="ir.actions.act_window">
        <field name="name">Product Brand</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">product.brand</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="ecommerce_theme.product_brand_tree_view"/>
    </record>

    <menuitem id="ecommerce_theme.product_brand" name="Product Brand"
              action="ecommerce_theme.product_brand_action_form"
              parent="website_sale.menu_ecommerce_settings"
              sequence="2"/>

    <record model="ir.ui.view" id="mccoy_custom_product_template_form_stock_view">
        <field name="name">mccoy_custom_product_template_form_stock_view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <field name="responsible_id" position="after">
                <field name="warehouse_id"/>
            </field>
        </field>
    </record>

    <record model="ir.ui.view" id="mccoy_custom_product_template_form_brand_view">
        <field name="name">mccoy_custom_product_template_form_view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="ecommerce_theme.product_template_brand_form_view"/>
        <field name="arch" type="xml">
            <field name="product_brand_id" position="replace">
                <label for="product_brand_id"/>
                <div class="oe_inline">
                    <field name="product_brand_id"  class="oe_inline"/>
                    <button name="set_desc_html_from_brand" type="object" class="oe_highlight" string="Set Template" invisible="not product_brand_id" style="font-size: 9px;margin-left: 10px;border-radius: 10px;"/>
                </div>
            </field>
        </field>
    </record>

    <record model="ir.ui.view" id="mccoy_custom_product_template_form_view">
        <field name="name">mccoy_custom_product_template_form_view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="company_id" position="before">
                <field name="qty_multiply_info"/>
            </field>
            <field name="categ_id" position="after">
                <field name="subcateg_id" string="Product Subcategory"/>
                <field name="sap_ref_no"/>
                <field name="description_mpn"/>
                <field name="class_id"/>
                <field name="last_stock"/>
            </field>
            <field name="taxes_id" position="before">
                <field name="manufacturing_company_id" readonly="1" />
<!--                 <label for="manufacturing_company_id"/>
                <div class="oe_inline">
                    <field name="manufacturing_company_id" readonly="1" class="oe_inline"/>
                    <button name="set_desc_html_from_brand" type="object" class="oe_highlight" string="Set Template" invisible="not manufacturing_company_id" style="font-size: 9px;margin-left: 10px;border-radius: 10px;"/>
                </div> -->
            </field>
            <field name="taxes_id" position="after">
                <field name="avg_cost" options="{'currency_field': 'cost_currency_id'}"/>
                <field name="total_cost" options="{'currency_field': 'cost_currency_id'}"/>
            </field>

            <xpath expr="//group[@name='product_template_images']" position="before">
                <group name="web_desciption" string="Description For Website">
                    <field name="website_description" nolabel="1"/>
                </group>
                <group name="custom_tabs_product" string="Custom Product Tabs">
                    <field name="custom_tab_ids" nolabel="1">
                        <tree>
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="content_type"/>
                            <field name="is_active"/>
                        </tree>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name"/>
                                        <field name="content_type" required="1"/>
                                    </group>
                                    <group>
                                        <field name="sequence"/>
                                        <field name="is_active"/>
                                    </group>
                                </group>
                                <separator string="Custom Content" invisible="content_type != 'custom'"/>
                                <group invisible="content_type != 'custom'">
                                    <field name="content" nolabel="1" required="content_type == 'custom'"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </group>
                <group name="related_blog_product" string="Related Blog">
                    <field name="related_blog_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="name"/>
                        </tree>
                    </field>
                </group>
                <group name="case_study_blog_product" string="Case Study Blog">
                    <field name="case_study_blog_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="name"/>
                        </tree>
                    </field>
                </group>
            </xpath>
            <xpath expr="//group[@name='sale']" position="before">
                <group name="mccoy_sale">
                    <field name="qty_multiply"/>
                </group>
                <group name="moq_ids" string="MOQ'S">
                    <field name="moq_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="product_variant_id" domain="[('product_tmpl_id','=',parent.id)]"/>
                            <field name="min_qty"/>
                            <field name="price_unit"/>
                        </tree>
                    </field>
                </group>
            </xpath> 
                
        </field>
    </record>


    <record id="product_moq_qty_form_view" model="ir.ui.view">
        <field name="name">product_moq_qty_form_view</field>
        <field name="model">product.template.moq.qty</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="apply_on"/>
                            <field name="categ_id" invisible="apply_on != 'category'" required="apply_on == 'category'"/>
                            <field name="product_id" invisible="apply_on != 'product'" required="apply_on == 'product'"/>
                        </group>
                        <group>
                            <field name="moq_qty" required="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Price Lines"/>
                    <group>
                        <field name="price_line_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="min_qty" required="1"/>
                                <field name="price_unit" required="1"/>
                                <field name="pricelist_id" required="1" options="{'no_create': True,'no_open':True}"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_moq_qty_tree_view" model="ir.ui.view">
        <field name="name">product_moq_qty_tree_view</field>
        <field name="model">product.template.moq.qty</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="moq_qty"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="product_moq_qty_act" model="ir.actions.act_window">
        <field name="name">MOQs Configuration</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">product.template.moq.qty</field>
        <field name="view_mode">tree,form</field>
    </record>



    <menuitem id="product_moq_qty_menu" name="MOQs Configuration"
              action="product_moq_qty_act"
              parent="website_sale.menu_catalog"
              active='false'
              />


    <record model="ir.ui.view" id="mccoy_custom_product_product_form_view">
        <field name="name">mccoy_custom_product_product_form_view</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <field name="lst_price" position="attributes">
               <attribute name="attrs">{'readonly': 0}</attribute>
            </field>
        </field>
    </record>

    <record id="odes_product_template_attribute_line_tree" model="ir.ui.view">
        <field name="name">odes.product.template.attribute.line.tree</field>
        <field name="model">product.template.attribute.line</field>
        <field name="arch" type="xml">
            <tree string="Product Template Attribute" editable="bottom">
                <field name="product_tmpl_id" required="1" readonly="id"/>
                <field name="attribute_id" readonly="id"/>
                <field name="value_ids" widget="many2many_tags" options="{'no_create_edit': True}" context="{'default_attribute_id': attribute_id, 'show_attribute': False}"/>
            </tree>
        </field>
    </record>

</odoo>
