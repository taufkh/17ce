        <record id="daily_work_report_visible_rule" model="ir.rule">
            <field name="name">Daily Work Report: Own Report</field>
            <field name="model_id" ref="model_hr_daily_work_report"/>
            <field name="groups" eval="[(4, ref('hr_timesheet.group_hr_timesheet_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <field name="domain_force">['|', ('employee_id', 'in', user.employee_ids.ids), ('employee_id.timesheet_company_ids', 'in', user.timesheet_company_ids.ids)]</field>
        </record>

        <record id="daily_work_report_manager" model="ir.rule">
            <field name="name">Daily Work Report: Manager</field>
            <field name="model_id" ref="model_hr_daily_work_report"/>
            <field name="groups" eval="[(4, ref('hr_timesheet.group_hr_timesheet_approver'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
            <field name="domain_force">['|', ('employee_id', 'in', user.employee_ids.ids), ('employee_id.timesheet_company_ids', 'in', user.timesheet_company_ids.ids)]</field>
        </record>

        <record id="daily_work_report_admin" model="ir.rule">
            <field name="name">Daily Work Report: Administrator</field>
            <field name="model_id" ref="model_hr_daily_work_report"/>
            <field name="groups" eval="[(4, ref('hr_timesheet.group_timesheet_manager'))]"/>
            <field name="perm_read" eval="1"/>
