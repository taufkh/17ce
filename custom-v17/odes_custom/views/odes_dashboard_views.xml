<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="odes_dashboard" model="ir.actions.client">
            <field name="name">CRM Dashboard</field>
            <field name="tag">odes_dashboard</field>
        </record>

        <record id="odes_dashboard_second" model="ir.actions.client">
            <field name="name">ODES Dashboard</field>
            <field name="tag">odes_dashboard_second</field>
        </record>

        <record id="ir_actions_crm_dashboard" model="ir.actions.server">
            <field name="name">CRM Dashboard</field>
            <field name="model_id" ref="model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">action = model.action_dashboard_redirect()</field>
        </record>

        <record id="ir_actions_crm_dashboard_2" model="ir.actions.server">
            <field name="name">CRM Dashboard</field>
            <field name="model_id" ref="model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">action = model.env.ref('odes_custom.odes_dashboard').sudo().read()[0]</field>
        </record>

        <record id="ir_actions_crm_dashboard_2_second" model="ir.actions.server">
            <field name="name">ODES Dashboard</field>
            <field name="model_id" ref="model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">action = model.env.ref('odes_custom.odes_dashboard_second').sudo().read()[0]</field>
        </record>

        <menuitem id="menu_crm_dashboard_2" parent="crm.crm_menu_root"
            sequence="0" name="Dashboard"/>

        <menuitem id="submenu_crm_dashboard_2" parent="menu_crm_dashboard_2" groups="odes_custom.group_mccoy_company"
            sequence="5" name="CRM Dashboard"
            action="ir_actions_crm_dashboard_2"/>

        <menuitem id="submenu_crm_dashboard_2_second" parent="menu_crm_dashboard_2" groups="odes_custom.group_odes_company"
            sequence="1" name="ODES Dashboard"
            action="ir_actions_crm_dashboard_2_second"/>


