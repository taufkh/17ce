<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="odes_view_expense_form_inherit" model="ir.ui.view">
        <field name="name">odes.hr.expense.form.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <!-- <field name="currency_id" position="after">
                <field name="odes_currency_id"/>
            </field> -->
            <field name="currency_id" position="attributes">
                <!-- <attribute name="domain">[('id', '=', 37)]</attribute> -->
                <attribute name="options">{'no_open': 1, 'no_create': 1}</attribute>
            </field>
        </field>
    </record>

    <!-- v16: hr_expense_actions_my_unsubmitted was removed in v16; record update omitted -->

    <record id="hr_expense.hr_expense_actions_my_all" model="ir.actions.act_window">
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No expense found. Let's create one!
            </p><p>
                Once you have created your expense, submit it to your manager who will validate it.
            </p>
        </field>
    </record>

    <record id="odes_custom_view_hr_expense_sheet_tree_inherit" model="ir.ui.view">
        <field name="name">odes.hr.expense.sheet.tree.inherit</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_tree"/>
        <field name="arch" type="xml">
            <field name="total_amount" position="before">
                <field name="sgd_currency_id" invisible="1"/>
                <field name="sgd_total" widget="monetary" options="{'currency_field': 'sgd_currency_id'}" sum="total"/>
            </field>
        </field>
    </record>

    <record id="odes_custom_hr_expense_sheet_view_search_inherit" model="ir.ui.view">
        <field name="name">odes.hr.expense.sheet.search.inherit</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_sheet_view_search"/>
        <field name="arch" type="xml">
            <filter name="my_reports" position="before">
                <filter string="Waiting My Approval" name="my_to_approve" domain="[('user_id', '=', uid), ('state', '=', 'submit')]"/>
            </filter>
            <filter name="employee" position="before">
                <filter string="Approver" name="approver" domain="[]" context="{'group_by': 'user_id'}"/>
            </filter>
        </field>
    </record>

    <record id="odes_custom_view_hr_expense_sheet_form_inherit" model="ir.ui.view">
        <field name="name">odes.hr.expense.sheet.form.inherit</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <group name="employee_details" position="after">
                <group>
                    <field name="is_manager" readonly="1"/>
                    <field name="is_finance" readonly="1"/>
                    <field name="is_director" readonly="1"/>
                </group>
            </group>
            <field name="user_id" position="attributes">
                <attribute name="string">Approver</attribute>
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </field>
            <field name="employee_id" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </field>
            <field name="amount_residual" position="before">
                <field name="sgd_currency_id" invisible="1"/>
                <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                    <label for="sgd_total"/>
                </div>
                <field name="sgd_total" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'sgd_currency_id'}"/>
                <div class="oe_subtotal_footer_separator oe_inline o_td_label" invisible="(line_currency_id in (currency_id, sgd_currency_id)) or not line_currency_id">
                    <div class="o_row o_form_label"><field name="line_currency_id" options="{'no_open': 1}"/> Total Amount</div>
                </div>
                <field name="line_total" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'line_currency_id'}" invisible="(line_currency_id in (currency_id, sgd_currency_id)) or not line_currency_id"/>
            </field>
            <xpath expr="//field[@name='expense_line_ids']//tree//button[@name='action_get_attachment_view']" position="replace">
                <button name="action_attachment_report_view"  string="View Attachments" type="object" icon="fa-paperclip"/>
            </xpath>
        </field>
    </record>

    <record id="odes_custom_hr_expense_view_form_inherit" model="ir.ui.view">
        <field name="name">odes.hr.expense.form.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
            </field>
            <field name="product_id" position="attributes">
                <attribute name="options">{'no_open': 1, 'no_create': 1}</attribute>
            </field>
            <field name="currency_id" position="after">
                <field name="sgd_currency_id" invisible="1"/>
            </field>
            <field name="total_amount" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="total_amount" position="after">
                <label for="total_amount"/>
                <div class="o_row">
                    <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_inline"/>
                    <field name="sgd_total" widget="monetary" options="{'currency_field': 'sgd_currency_id'}" class="oe_inline"/>
                </div>
            </field>
        </field>
    </record>

    <!-- v16: groups_id removed from inherited view; employee_id/product_id options now apply to all. -->
    <record id="odes_custom_hr_expense_view_form_full_inherit" model="ir.ui.view">
        <field name="name">odes.hr.expense.form.full.inherit</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="attributes">
                <attribute name="readonly">0</attribute>
            </field>
            <field name="product_id" position="attributes">
                <attribute name="options">{'no_open': 0, 'no_create': 0}</attribute>
            </field>
        </field>
    </record>

    <record id="odes_custom_action_hr_expense_sheet_to_approve" model="ir.actions.act_window">
        <field name="name">Expense Dashboard</field>
        <field name="res_model">hr.expense.sheet</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="hr_expense.hr_expense_sheet_view_search"/>
        <field name="domain">[]</field>
        <field name="context">{'search_default_my_to_approve': 1, 'create': 0, 'delete': 0}</field>
        <field name="view_id" ref="hr_expense.view_hr_expense_sheet_tree"/>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            No expense reports found
          </p><p>
            Approve the new expense reports submitted by the employees you manage.
          </p>
        </field>
    </record>
    <menuitem id="menu_hr_expense_sheet_to_approve_odes_custom"
      name="Dashboard" sequence="0" parent="hr_expense.menu_hr_expense_root"
      action="odes_custom_action_hr_expense_sheet_to_approve"
      groups="hr_expense.group_hr_expense_team_approver"/>

</odoo>