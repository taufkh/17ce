<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="odes_view_calendar_event_form_inherit" model="ir.ui.view">
        <field name="name">odes.calendar.event.view.form.inherit</field>
        <field name="model">calendar.event</field>
        <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page name="page_minutes_record" string="Minutes Record" autofocus="autofocus">
                    <div>
                        <field name="minutes_record" widget="html"/>
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>