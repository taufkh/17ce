<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_tree2_inherit" model="ir.ui.view">
        <field name="name">project.task.tree</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="task_progressbar" widget="progressbar"/>
            </xpath>
        </field>
    </record>

    <record id="view_task_form2_inherit" model="ir.ui.view">
        <field name="name">project.task.form.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_schedule_meeting" type="object"
                    class="oe_stat_button" icon="fa-calendar">
                    <div class="o_stat_info">
                        <field name="meeting_count" class="o_stat_value"/>
                        <span class="o_stat_text" invisible="meeting_count &lt; 2"> Meetings</span>
                        <span class="o_stat_text" invisible="meeting_count &gt; 1"> Meeting</span>
                    </div>
                </button>
            </div>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="task_progress"/>
                
                <label for="task_progressbar" string=""/>
                <field name="task_progressbar" nolabel="1" widget="progressbar"/>

                <field name="task_color" invisible="1"/>
                <field name="task_color_sel" required="1"/>
                <label for="task_color_render" string=""/>
                <field name="task_color_render" widget="color" nolabel="1" readonly="1" force_save="1"/>
            </xpath>
            <page name="extra_info" position="after">
                <page name="page_minutes_record" string="Minutes Record">
                    <field name="event_ids" readonly="1">
                        <tree>
                            <field name="name" string="Subject" readonly="1"/>
                            <field name="allday" invisible="True"/>
                            <field name="start" string="Start Date"/>
                            <field name="stop" string="End Date"/>
                            <field name="duration" widget="float_time" readonly="1"/>
                            <button name="view_event" string="View" type="object"/>
                        </tree>
                    </field>
                </page>
            </page>
        </field>
    </record>

