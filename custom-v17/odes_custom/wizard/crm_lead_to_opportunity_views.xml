<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crm_lead2opportunity_partner" model="ir.ui.view">
        <field name="name">odes.crm.lead2opportunity.partner.inherit</field>
        <field name="model">crm.lead2opportunity.partner</field>
        <field name="inherit_id" ref="crm.view_crm_lead2opportunity_partner"/>
        <field name="arch" type="xml">
            <group name="name" position="attributes">
                <attribute name="invisible">1</attribute>
            </group>
            <field name="team_id" position="after">
                <field name="expected_revenue" required="1"/>
                <field name="currency_id" required="1" widget="selection"/>
                <field name="possibility" required="1"/>
            </field>

            <group name="action" position="after">
                <group name="project" string="Project" invisible="1">
                    <field name="company_id" invisible="1"/>
                    <field name="is_odes" invisible="1"/>
                    <group>
                        <field name="project_name"/>
                        <field name="application"/>
                        <field name="end_partner_id"/>
                        <field name="end_product_id"/>
                        <field name="contract_site"/>
                        <field name="design_location"/>
                        <field name="annual_qty"/>
                        <field name="mass_schedule_date"/>
                    </group>
                    <group>
                        <field name="pilot_qty"/>
                        <field name="pilot_schedule_date"/>
                        <field name="project_status"/>
                        <field name="project_lifespan"/>
                        <field name="estimated_closing_date"/>
                    </group>
                    <separator string="Competitor Information"/>
                    <field name="odes_competitor_ids">
                        <tree editable="bottom">
                            <field name="name" required="1"/>
                            <field name="manufacture" required="1"/>
                            <field name="price" required="1"/>
                        </tree>
                    </field>
                    <separator string="Part Information"/>
                    <field name="odes_part_ids">
                        <tree editable="bottom">
                            <field name="name" required="1"/>
                            <field name="manufacture" required="1"/>
                            <field name="price" required="1"/>
                        </tree>
                    </field>
                </group>
            </group>
        </field>
    </record>

</odoo>