<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- PROJECT TASK -->
        <!-- Note: is_closed removed — field not available in this Odoo 16 Community version -->
        <record id="project_task_type_requirement" model="project.task.type">
            <field name="name">Requirement</field>
            <field name="sequence">1</field>
        </record>

        <record id="project_task_type_prototyping" model="project.task.type">
            <field name="name">Prototyping</field>
            <field name="sequence">2</field>
        </record>

        <record id="project_task_type_lock_requirements" model="project.task.type">
            <field name="name">Lock Requirements</field>
            <field name="sequence">3</field>
        </record>

        <record id="project_task_type_development" model="project.task.type">
            <field name="name">Development</field>
            <field name="sequence">4</field>
        </record>

        <record id="project_task_type_uat" model="project.task.type">
            <field name="name">UAT</field>
            <field name="sequence">5</field>
        </record>

        <record id="project_task_type_deployment" model="project.task.type">
            <field name="name">Deployment</field>
            <field name="sequence">6</field>
        </record>

        <!-- CRM STAGE -->
        <record id="crm_stage_prospect" model="crm.stage">
            <field name="name">Prospect</field>
            <field name="sequence">10</field>
            <field name="is_need_so">False</field>
            <field name="is_confirm_so">False</field>
            <field name="is_revenue">False</field>
        </record>

        <record id="crm_stage_opportunity" model="crm.stage">
            <field name="name">Opportunity</field>
            <field name="sequence">11</field>
            <field name="is_need_so">False</field>
            <field name="is_confirm_so">False</field>
            <field name="is_revenue">True</field>
        </record>

        <record id="crm_stage_report" model="crm.stage">
            <field name="name">Report</field>
            <field name="sequence">12</field>
            <field name="is_need_so">False</field>
            <field name="is_confirm_so">False</field>
            <field name="is_revenue">True</field>
        </record>

        <record id="crm_stage_pending" model="crm.stage">
            <field name="name">Pending</field>
            <field name="sequence">13</field>
            <field name="is_need_so">False</field>
            <field name="is_confirm_so">False</field>
            <field name="is_revenue">True</field>
        </record>

        <record id="crm_stage_won" model="crm.stage">
            <field name="name">Won</field>
            <field name="sequence">14</field>
            <field name="is_need_so">False</field>
            <field name="is_confirm_so">False</field>
            <field name="is_revenue">True</field>
            <field name="is_won">True</field>
        </record>


        <!-- Email template for recruitment -->
        <record id="mail_template_hr_apply_job" model="mail.template">
            <field name="name">Apply Job</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
            <field name="subject">${object.name} on ${object.job_id.name}</field>
            <field name="email_from">"${object.company_id.name | safe}" &lt;${(object.company_id.email or user.email) | safe}&gt;</field>
            <field name="body_html" type="html">
<table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;"><tr><td align="center">
<table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 16px; background-color: white; color: #454748; border-collapse:separate;">
<tbody>
    <!-- HEADER -->
    <tr>
        <td align="center" style="min-width: 590px;">
            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                <tr><td valign="middle">
                    <span style="font-size: 10px;">${object.job_id.name}</span><br/>
                    <span style="font-size: 20px; font-weight: bold;">
                        ${object.name}
                    </span>
                </td><td valign="middle" align="right">
                    <img src="/odes_design/static/src/img/ODES-logo.png" style="padding:0px;margin: 0px; height: auto; width: 80px;" alt="${object.company_id.name}"/>
                </td></tr>
                <tr><td colspan="2" style="text-align:center;">
                  <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                </td></tr>
            </table>
        </td>
    </tr>
    <!-- CONTENT -->
    <tr>
        <td align="center" style="min-width: 590px;">
            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                <tr><td valign="top" style="font-size: 13px;">
                    <div>
                        Dear User,<br/><br/>
                        We have a new applicant for <strong>${object.job_id.name}</strong>,<br/>
                        <strong>Name:</strong> ${object.partner_name}<br/>
                        <strong>Email:</strong> ${object.email_from}<br/>
                        <strong>Phone:</strong> ${object.partner_phone}<br/>
                        You can use the following link to open the details:
                        <div style="margin: 16px 0px 16px 0px;">
                            <a href="${object.applicant_url}"
                                style="background-color: #1B66B7; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;">
                                Go to Applications
                            </a>
                        </div>
                        Thank you
                    </div>
                </td></tr>
                <tr><td style="text-align:center;">
                  <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                </td></tr>
            </table>
        </td>
    </tr>
    <!-- FOOTER -->
    <tr>
        <td align="center" style="min-width: 590px;">
            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;">
                <tr><td valign="middle" align="left">
                    ${object.company_id.name}
                </td></tr>
                <tr><td valign="middle" align="left" style="opacity: 0.7;">
                    ${object.company_id.phone}
                    % if object.company_id.website
                        | <a href="'%s' % ${object.company_id.website}" style="text-decoration:none; color: #1B66B7;">
                        ${object.company_id.website}
                    </a>
                    % endif
                </td></tr>
            </table>
        </td>
    </tr>
</tbody>
</table>
</td></tr>
<!-- POWERED BY -->
<tr><td align="center" style="min-width: 590px;">
    <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: #F1F1F1; color: #454748; padding: 8px; border-collapse:separate;">
      <tr><td style="text-align: center; font-size: 13px;">
        Powered by <a target="_blank" href="https://www.odes.com.sg" style="color: #1B66B7;">ODES</a>
      </td></tr>
    </table>
</td></tr>
</table></field>
            <field name="lang">${object.lang}</field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>