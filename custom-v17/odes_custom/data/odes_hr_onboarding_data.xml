<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_hr_employee_onboarding" model="mail.template">
            <field name="name">Employee Onboarding</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="email_from">{{ object.company_id.email or user.email }}</field>
            <field name="email_to">{{ object.work_email or object.private_email }}</field>
            <field name="subject">Welcome to {{ object.company_id.name }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <![CDATA[
                <div style="font-family: Arial, sans-serif; color: #333333;">
                    <p>Hello <t t-out="object.name"/>,</p>
                    <p>Welcome to <t t-out="object.company_id.name"/>.</p>
                    <p>Your onboarding process for the role of <strong><t t-out="object.job_id.name or '-'"/></strong> is ready. Please follow the next instructions from HR and your manager.</p>
                    <p>We are looking forward to working with you.</p>
                </div>
                ]]>
            </field>
        </record>
    </data>
</odoo>
