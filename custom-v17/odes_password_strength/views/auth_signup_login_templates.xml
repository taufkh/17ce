        <template id="odes_password_strength_fields" inherit_id="auth_signup.fields"
              name="Odes Auth Signup/ResetPassword form fields">
                    <xpath expr="//input[@name='password']" position="replace">
                        <!--<input t-att-minlength="password_minimum_length" onkeyup="CheckPasswordStrength(this.value)"  type="password" name="password" id="password" class="form-control form-control-sm" required="required" t-att-autofocus="'autofocus' if only_passwords else None"/>-->
                        <div>
                            <input onkeyup="CheckPasswordStrength(this.value)"  type="password" name="password" id="password" class="form-control form-control-sm" required="required" t-att-autofocus="'autofocus' if only_passwords else None"/>
                            <div class="varpassword_strength" minlength="1"></div>
                              <!-- odestooltip block -->
                            <div class="odestooltip" data-direction="left">
                              <div class="odestooltip__initiator">
                                <!-- element with odestooltip hover call -->
                                <i class="fa fa-info-circle"> Info</i>
                              </div>
                              <div class="odestooltip__item">
                                  <span>Passwords must contain:<br/></span> 
                                  <span>at least 8 characters in length, but can be longer and</span>
                                  <span>a minimum of 1 lower case letter [a-z] and</span>
                                  <span>a minimum of 1 numeric character [0-9] and</span>
                                  <span>a minimum of 1 special character: ~`!@#$%^*()-_+={}[]|\:",./?</span>
                                  
                              </div>
                            </div>
  
                            <!--<div class="description"> Password minimum length 8 characters and must combination letter, number and symbol </div>-->
                        </div>
                        
                    
                    </xpath>
                    <xpath expr="//input[@name='confirm_password']" position="replace">
                        <div>
                            <input onkeyup="CheckPassword(password.value, this.value)" type="password" name="confirm_password" id="confirm_password" class="form-control form-control-sm" required="required"/>
                            <div class="varpassword_confirm_strength" minlength="1"></div>
                        </div>
                        
                    
                    </xpath>
                    
                    
                    
                    
        </template>


</odoo>
