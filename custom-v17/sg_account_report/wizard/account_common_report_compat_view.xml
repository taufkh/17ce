<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_common_report_view_compat" model="ir.ui.view">
        <field name="name">account.common.report.compat.form</field>
        <field name="model">account.common.report</field>
        <field name="arch" type="xml">
            <form string="Report Options">
                <group col="4">
                    <field name="company_id"/>
                    <field name="chart_account_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="journal_ids" widget="many2many_tags"/>
                    <field name="target_move" widget="radio"/>
                </group>
                <footer>
                    <button name="check_report" string="Print" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="alias_account_common_report_view" model="ir.model.data">
        <field name="module">account</field>
        <field name="name">account_common_report_view</field>
        <field name="model">ir.ui.view</field>
        <field name="res_id" eval="ref('sg_account_report.account_common_report_view_compat')"/>
        <field name="noupdate" eval="True"/>
    </record>
</odoo>
