                                  <strong class="mr16">Subtotal</strong>
                                  SG$
                                  <span t-esc="sgd_subtotal"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" />
                                </td>
                              </tr>
                            </t>
                          </t>
                        </tbody>
                      </table>
                    </div>
                    <div class="col-auto">

                      <table class="table"
                        style="  font-size: 12px; font-weight : 700; width:40%; float : right; border:1px solid #000;">
                        <tr class="border-black o_total" style="border-bottom: 1px solid #000 !important;">
                          <td
                            style="padding: 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                            <strong style="padding-left : 8px;">SUBTOTAL</strong></td>
                          <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                            <!-- <strong>SG$ 
                                                    <span t-esc="o.get_sgd_value(o.amount_untaxed)" t-options='{"widget": "float", "precision": 2}'/></strong> -->
                            <strong>SG$ <span t-esc="sgd_subtotal"
                                t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" /></strong>
                          </td>
                        </tr>
                        <t t-foreach="o.taxes()" t-as="tx">
                            <t t-if="tx['amount'] * (tx['tax']/100) != 0">
                              <tr style="">
                                <td
                                  style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                                  <strong style="padding-left : 8px;">GST <span t-esc="int(tx['tax'])" />%</strong>
                                </td>
                                <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                  <strong>SG$
                                    <t t-esc="o.get_sgd_value(tx['amount'] * (tx['tax']/100))"
                                          t-options="{'widget': 'float', 'precision': 2}" />
                                  </strong>
                                </td>
                              </tr>
                            </t>
                          </t>
                        <tr style="">
                          <td
                            style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                            <strong style="padding-left : 8px;">Total Amount</strong></td>
                          <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                            <strong>SG$ <span class="text-nowrap" t-esc="o.get_sgd_value(o.amount_total)" t-options='{"widget": "float", "precision": 2}'/></strong>
                          </td>
                        </tr>

                      </table>
                      <br />
