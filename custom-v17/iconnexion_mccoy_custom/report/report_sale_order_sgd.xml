                    <span style="padding-left: 20px; text-align:left; font-size: 12px;"> We are pleased to submit our
                      quotation for the following products : </span>
                    <div style="min-height : 100px">
                      <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                        <thead style="font-size: 12px;">
                          <tr style="background-color: lightgrey;">
                            <th name="th_description" class="text-center"><span>Brand</span></th>
                            <th width="40%" name="th_desc" class="text-left"><span>Product Description</span></th>
                            <th name="th_mpn" class="text-left"><span>MPN</span></th>
                            <th name="th_qty" class="text-center"><span>Qty</span></th>
                            <th name="th_qty" class="text-center"><span>MOQ</span></th>
                            <th name="th_qty" class="text-center"><span>SPQ</span></th>
                            <th name="th_unit_price" class="text-center"><span>U/Price</span></th>
                            <th name="th_total" class="text-center"><span> Total Price (SGD)</span></th>
                            <th name="th_total" class="text-center"><span> L/T (ARO)</span></th>

                          </tr>
                        </thead>
                        <tbody style="font-size: 12px;" class="invoice_tbody">
                          <t t-set="current_subtotal" t-value="0" />
                          <t t-set="line_count" t-value="0" />
                          <t t-set="sgd_subtotal" t-value="0" />
                          <t t-set="sgd_tax" t-value="0" />

                          <t t-set="lines" t-value="o.order_line" />

                          <t t-foreach="lines" t-as="line">
                            <t t-set="line_count" t-value="line_count + 1" />
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                              groups="account.group_show_line_subtotals_tax_excluded" />
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                              groups="account.group_show_line_subtotals_tax_included" />
                            <t t-if="line.tax_id">
                              <t t-set="sgd_tax"
                                t-value="sgd_tax+(o.get_sgd_total_value(line.price_unit, line.product_uom_qty)*0.07)" />
                            </t>

                            <tr
                              t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                              <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                <td name="account_invoice_line_name"><span
                                    t-field="line.product_id.product_brand_id.name" t-options="{'widget': 'text'}" />
                                </td>
                                <td class="text-left"><span t-field="line.product_id.name"
                                    t-options="{'widget': 'text'}" /></td>
                                <td class="text-left"><span t-field="line.product_id.default_code"
                                    t-options="{'widget': 'text'}" /></td>
                                <td class="text-center">
                                  <span class="text-nowrap" t-field="line.product_uom_qty"
                                    groups="account.group_show_line_subtotals_tax_excluded"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 0}" />
                                  <span class="text-nowrap" t-esc="o.get_sgd_value(line.price_total)"
                                    groups="account.group_show_line_subtotals_tax_included"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" />
                                </td>
                                <td class="text-center"><span t-field="line.moq" /></td>
                                <td class="text-center"><span t-field="line.spq" /></td>
                                <td class="text-center">
                                  <span class="text-nowrap" t-esc="o.get_sgd_value(line.price_unit)"
                                    groups="account.group_show_line_subtotals_tax_excluded"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" />
                                  <span class="text-nowrap" t-esc="o.get_sgd_value(line.price_total)"
                                    groups="account.group_show_line_subtotals_tax_included"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" />
                                </td>
                                <td class="text-center o_price_total">
                                  <span class="text-nowrap"
                                    t-esc="o.get_sgd_total_value(line.price_unit, line.product_uom_qty)"
                                    groups="account.group_show_line_subtotals_tax_excluded"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" />
                                  <span class="text-nowrap" t-esc="o.get_sgd_value(line.price_total)"
                                    groups="account.group_show_line_subtotals_tax_included"
                                    t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" />
                                  <t t-set="sgd_subtotal"
                                    t-value="sgd_subtotal+o.get_sgd_total_value(line.price_unit, line.product_uom_qty)" />
                                </td>
                                <td class="text-center o_lead_time">
                                  <span t-esc="int(line.customer_lead)" /> weeks
                                </td>
                              </t>
                              <t t-if="line.display_type == 'line_section'">
                                <td colspan="99">
                                  <span t-field="line.name" t-options="{'widget': 'text'}" />
                                </td>
                                <t t-set="current_section" t-value="line" />
                                <t t-set="current_subtotal" t-value="0" />
                              </t>
                              <t t-if="line.display_type == 'line_note'">
                                <td colspan="99">
                                  <span t-field="line.name" t-options="{'widget': 'text'}" />
                                </td>
                              </t>
                            </tr>

                            <t
                              t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                              <tr class="is-subtotal text-right">
                                <td colspan="99">
                                  <!-- <strong class="mr16">Subtotal</strong>
                                                  SG$ 
