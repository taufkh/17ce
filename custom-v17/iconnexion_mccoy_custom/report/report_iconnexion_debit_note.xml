<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="iconnexion_mccoy_report_iconnexion_debit_note_document_inherited"
      inherit_id="iconnexion_custom.report_iconnexion_debit_note_document">
      <xpath expr="." position="replace">
        <t t-foreach="docs" t-as="o">
          <t t-call="web.html_container">
            <t t-call="web.external_layout">
              <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)" />
              <div class="header">
                <div class="row mt32 mb32">
                  <div class="col-auto">
                  </div>
                  <t t-if="o.company_id.name in ['iConnexion Asia Pte Ltd']">
                    <div class="col-auto">
                      <img style="width : 100%; max-height:45mm; max-width:45mm;margin-left:-62.5mm;"
                        src="/iconnexion_custom/static/src/img/icon.png" />
                    </div>
                  </t>
                  <t t-if="o.company_id.name in ['McCoy Pte Ltd']">
                    <div class="col-auto">
                      <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                        style="max-height: 65px;margin-left:-62.5mm;" alt="Logo" />
                    </div>
                  </t>
                  <div class="col-auto">
                    <h2 style="text-align: right; color:#0068a6;">DEBIT NOTE</h2>
                  </div>
                </div>


                <div style="margin-top : 5px;" class="row mt32 mb32">
                  <div class="col-auto">
                    <div><span style="font-size : 15px; text-decoration: underline; font-weight: bold;"
                        t-field="o.company_id.name" /></div>
                    <div style="font-size : 12px;"><span t-field="o.company_id.street" /> </div>
                    <div style="font-size: 12px;"><span t-field="o.company_id.street2" /> </div>
                    <div style="font-size : 12px;"> <span t-field="o.company_id.country_id" /> <span
                        t-field="o.company_id.zip" /> </div>
                    <div style="font-size : 12px;">Tel : <span t-field="o.company_id.partner_id.phone" /></div>
                    <div style="font-size : 12px;">Fax : <span t-field="o.company_id.fax" /></div>


                  </div>
                  <div style="font-size : 12px;" class="col-auto">
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        COMPANY REG NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-esc="o.company_id.vat" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        GST REG NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-esc="o.company_id.company_registry" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        DATE :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-esc="o.date.strftime('%d.%m.%Y')" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        DEBIT NOTE NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-field="o.name" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        CUSTOMER PO NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-field="o.ref" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        QUOTATION NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-esc="o.get_quotation_no()" />
                      </div>

                    </div>

                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        PAYMENT TERMS :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-field="o.invoice_payment_term_id" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        FREIGHT TERMS :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-field="o.freight_terms_id.name" />
                      </div>

                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        ORDERED BY :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-field="o.contact_id.name" />
                      </div>

                    </div>


                  </div>
                </div>
              </div>


              <div class="page">

                <table style=" font-size : 14px; width:80%; border:1px solid #000;margin-top:-10mm;">
                  <tr>
                    <th style="border-right: 1px solid #000 !important;">
                      <div style="width:340px;height:150px;">
                        <br />
                        <div class="col-auto" t-if="o.partner_id">
                          <div class="row mt32 mb32">
                            <table style="margin-top:-20px;padding : 15px; width: 100%;">
                              <tr>
                                <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Bill to</td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <span t-field="o.partner_id" /><br />
                                  <span t-field="o.partner_id.street" />
                                  <span t-field="o.partner_id.street2" />
                                  <span t-field="o.partner_id.city" />
                                  <span t-field="o.partner_id.state_id" />
                                  <span t-field="o.partner_id.zip" />
                                  <span t-field="o.partner_id.country_id" />
                                </td>
                              </tr>
                              <tr>
                                <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">C.Person
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <t t-if="o.sale_order_no_id">
                                    <span t-field="o.sale_order_no_id.contact_id.name" />
                                  </t>
                                  <t t-else="">
                                    <span t-field="o.partner_id.name" />
                                  </t>
                                </td>
                              </tr>
                              <tr>
                                <td style="padding-left: 10px; text-align:left; font-size:12px; width:50px">Telephone
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <t t-if="o.sale_order_no_id">
                                    <span t-field="o.sale_order_no_id.contact_id.phone" />
                                  </t>
                                  <t t-else="">
                                    <span t-field="o.partner_id.phone" />
                                  </t>
                                </td>
                              </tr>
                            </table>

                          </div>

                        </div>
                      </div>
                    </th>
                    <th>
                      <div style="width:340px;height:120px;">
                        <br />
                        <div class="col-auto" t-if="o.partner_id">
                          <div class="row mt32 mb32">
                            <table style="margin-top:-20px;padding : 15px; width: 100%;">
                              <tr>
                                <td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">Deliver to
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <span t-field="o.partner_id" /><br />
                                  <span t-field="o.partner_id.street" />
                                  <span t-field="o.partner_id.street2" />
                                  <span t-field="o.partner_id.city" />
                                  <span t-field="o.partner_id.state_id" />
                                  <span t-field="o.partner_id.zip" />
                                  <span t-field="o.partner_id.country_id" />
                                </td>
                              </tr>
                              <tr>
                                <td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">C.Person
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <t t-if="o.sale_order_no_id">
                                    <span t-field="o.sale_order_no_id.partner_shipping_id.name" />
                                  </t>
                                  <t t-else="">
                                    <span t-field="o.partner_id.name" />
                                  </t>
                                </td>
                              </tr>
                              <tr>
                                <td style="padding-left: 10px; text-align:left; font-size:12px; width:80px">Telephone
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <t t-if="o.sale_order_no_id">
                                    <span t-field="o.sale_order_no_id.partner_shipping_id.phone" />
                                  </t>
                                  <t t-else="">
                                    <span t-field="o.partner_id.phone" />
                                  </t>
                                </td>
                              </tr>
                            </table>
                          </div>

                        </div>
                      </div>
                    </th>
                  </tr>
                </table>

                <div style="min-height : 185px">
                  <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                    <thead style="font-size : 12px;">
                      <tr style="background-color: lightgrey;">
                        <th width="20%" name="th_description" class="text-left"><span>Cust P/N</span></th>
                        <th width="20%" name="th_desc" class="text-left"><span>Description</span></th>
                        <th width="8%" name="th_desc" class="text-left"><span>COO</span></th>
                        <th width="13%" name="th_qty"
                          t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>Order Qty</span></th>
                        <th width="8%" name="th_qty"
                          t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>UOM</span></th>
                        <th width="16%" name="th_unit_price"
                          t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>Unit Price</span></th>
                        <th width="18%" name="th_total"
                          t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>Total Amount</span></th>

                      </tr>
                    </thead>
                    <tbody style="font-size : 12px;" class="invoice_tbody">
                      <t t-set="current_subtotal" t-value="0" />
                      <t t-set="line_count" t-value="0" />

                      <t t-set="lines"
                        t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)" />

                      <t t-foreach="lines" t-as="line">
                        <t t-set="line_count" t-value="line_count + 1" />
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                          groups="account.group_show_line_subtotals_tax_excluded" />
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                          groups="account.group_show_line_subtotals_tax_included" />

                        <tr style="padding : 3px;"
                          t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                          <t t-if="not line.display_type" name="account_invoice_line_accountable">
                            <td name="account_invoice_line_name"><span t-field="line.name"
                                t-options="{'widget': 'text'}" /></td>
                            <td name="account_invoice_line_name"><span t-field="line.product_id.name"
                                t-options="{'widget': 'text'}" /><br /><span t-field="line.product_id.description_mpn"
                                t-options="{'widget': 'text'}" /></td>
                            <td name="coo_column"><span t-field="line.product_id.product_tmpl_id.coo_id.name"
                                t-options="{'widget': 'text'}" /></td>
                            <td style="text-align: center;">
                              <span t-field="line.quantity" />
                            </td>
                            <td style="text-align: center;">
                              <span t-field="line.product_uom_id" />
                            </td>
                            <td style="text-align: center;">
                              <span class="text-nowrap" t-field="line.price_unit" />
                            </td>

                            <td class="text-right o_price_total">
                              <span class="text-nowrap" t-field="line.price_subtotal"
                                groups="account.group_show_line_subtotals_tax_excluded" />
                              <span class="text-nowrap" t-field="line.price_total"
                                groups="account.group_show_line_subtotals_tax_included" />
                            </td>
                          </t>
                          <t t-if="line.display_type == 'line_section'">
                            <td colspan="99">
                              <span t-field="line.name" t-options="{'widget': 'text'}" />
                            </td>
                            <t t-set="current_section" t-value="line" />
                            <t t-set="current_subtotal" t-value="0" />
                          </t>
                          <t t-if="line.display_type == 'line_note'">
                            <td colspan="99">
                              <span t-field="line.name" t-options="{'widget': 'text'}" />
                            </td>
                          </t>
                        </tr>

                        <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                          <tr class="is-subtotal text-right">
                            <td colspan="99">
                              <strong class="mr16">Subtotal</strong>
                              <span t-esc="current_subtotal"
                                t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}" />
                            </td>
                          </tr>
                        </t>
                      </t>
                    </tbody>
                  </table>
                  <div style="font-size : 12px;">
                    <span t-field="o.narration" />
                  </div>
                </div>


                <div class="block" style="page-break-inside: avoid;">

                  <t t-if="o.currency_id.name == 'USD'">
                    <div style="font-size : 9px;">
                      <table width="100%" style="margin-left:-35mm;">
                        <tr>
                          <td width="20%" />
                          <td colspan="3" class="text-left">
                            <u>GST SUMMARY REPORT</u>
                          </td>
                          <td width="40%" />
                        </tr>
                        <tr>
                          <td />
                          <td><span t-field="o.currency_id.name" /> 1.00 = </td>
                          <td>SGD</td>
                          <td><span t-esc="o.get_sgd_value(1)"
                              t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 6}" /></td>
                          <td />
                        </tr>
                        <tr>
                          <td />
                          <td>Subtotal = </td>
                          <td>SGD</td>
                          <td><span t-esc="o.get_sgd_value(o.amount_untaxed)"
                              t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" /></td>
                          <td />
                        </tr>
                        <t t-foreach="o.taxes()" t-as="tx">
                          <t t-if="tx['amount'] * (tx['tax']/100) != 0">
                            <tr style="">
                              <td/>
                              <td>GST <span t-esc="int(tx['tax'])"/>%</td>
                              <td>SGD</td>
                              <td> <t t-esc="o.get_sgd_value(tx['amount'] * (tx['tax']/100))" t-options="{'widget': 'float', 'precision': 2}"/></td>
                            </tr>
                          </t>
                        </t>
                        <tr>
                          <td />
                          <td>Total Amount</td>
                          <td>SGD</td>
                          <td><span t-esc="o.get_sgd_value(o.amount_total)"
                              t-options="{&quot;widget&quot;: &quot;float&quot;, &quot;precision&quot;: 2}" /></td>
                          <td />
                        </tr>
                      </table>
                    </div>
                  </t>
                  <div style="font-size : 12px; border-bottom: 1px solid black; position: absolute; width : 680px">
                    <br />
                    <i> <span t-field="o.company_id.remarks_header" /></i>
                  </div>
                  <br />


                  <div class="row mt32 mb32">

                    <div class="col-auto">

                      <div style="margin-left : -15px" class="col-auto">
                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Beneficiary</td>
                              <td width="10px">:</td>
                              <td>
                                <span t-field="o.company_id.name" />

                              </td>
                            </tr>
                          </table>


                        </div>
                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Beneficiary Address</td>
                              <td width="10px">:</td>
                              <td>

                                <div><span t-field="o.company_id.street" /> </div>
                                <div><span t-field="o.company_id.street2" /> </div>
                                <div><span t-field="o.company_id.country_id" /> <span t-field="o.company_id.zip" />
                                </div>

                              </td>
                            </tr>
                          </table>


                        </div>

                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Name of Bank</td>
                              <td width="10px">:</td>
                              <td>
                                <span>Oversea-Chinese Banking Corporation Limited</span>

                              </td>
                            </tr>
                          </table>



                        </div>
                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Address of Bank</td>
                              <td width="10px">:</td>
                              <td>
                                <span>65 Chulia Street OCBC Centre Singapore 049513</span>

                              </td>
                            </tr>
                          </table>


                        </div>

                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Bank Account No</td>
                              <td width="10px">:</td>
                              <td>
                                <t t-if="o.currency_id.name == 'USD'">
                                  <span> 503-008591-301 (<span t-field="o.currency_id.name" />)</span>
                                </t>
                                <t t-if="o.currency_id.name == 'SGD'">
                                  <span> 581-322104-001 (<span t-field="o.currency_id.name" />)</span>
                                </t>
                              </td>
                            </tr>
                          </table>


                        </div>
                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">SWIFT Code</td>
                              <td width="10px">:</td>
                              <td>
                                <span>OCBCSGSG</span>

                              </td>
                            </tr>
                          </table>


                        </div>

                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Remarks</td>
                              <td width="10px">:</td>
                              <td>
                                <span>All Bank commission as well as bank charges are to be borne by payer</span>

                              </td>
                            </tr>
                          </table>


                        </div>


                      </div>
                      <br />
                      <div style="margin-left : -15px" class="col-auto">
                        <div><span style=" font-size : 9px; text-decoration: underline;"> Pay Now Transaction </span>
                        </div>

                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Company UEN</td>
                              <td width="10px">:</td>
                              <td>
                                <span>200718664Z</span>

                              </td>
                            </tr>
                          </table>


                        </div>
                        <div class="row mt32 mb32">
                          <table style="font-size : 9px; width: 100%;">
                            <tr>
                              <td style="padding-left: 15px" width="100px">Company Name</td>
                              <td width="10px">:</td>
                              <td>
                                <span t-field="o.company_id.name" />

                              </td>
                            </tr>
                          </table>


                        </div>

                      </div>
                    </div>
                    <div class="col-auto" style="margin-top : 10px">

                      <table class="table"
                        style="  font-size : 12px; font-weight : 800; width:80%; float : right; border:1px solid #000;">
                        <tr class="border-black o_total" style="border-bottom: 1px solid #000 !important;">
                          <td
                            style="padding: 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                            <strong style="padding-left : 8px;">SUBTOTAL</strong></td>
                          <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                            <strong><span t-field="o.amount_untaxed" /></strong>
                          </td>
                        </tr>
                        <tr style="">
                          <td
                            style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                            <strong style="padding-left : 8px;">DISCOUNT</strong></td>
                          <td class="padding : 5px; text-right"
                            style="padding : 1px; border-bottom: 1px solid #000 !important;">
                          </td>
                        </tr>
                        <t t-foreach="o.taxes()" t-as="tx">
                          <t t-if="tx['amount'] * (tx['tax']/100) != 0">
                            <tr style="">
                              <td
                                style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                                <strong style="padding-left : 8px;">GST <span t-esc="int(tx['tax'])" />%</strong></td>
                              <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                                <strong>
                                  <span>
                                    <t t-esc="o.currency_id.symbol" />
                                    <t t-esc="tx['amount'] * (tx['tax']/100)"
                                      t-options="{'widget': 'float', 'precision': 2}" />

                                  </span>
                                </strong>
                              </td>
                            </tr>
                          </t>
                        </t>
                        <tr style="">
                          <td
                            style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                            <strong style="padding-left : 8px;">Total Amount</strong></td>
                          <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                            <strong><span class="text-nowrap" t-field="o.amount_total" /></strong>
                          </td>
                        </tr>
                        <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()" />
                        <t t-foreach="payments_vals" t-as="payment_vals">
                          <tr style="">
                            <td
                              style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
