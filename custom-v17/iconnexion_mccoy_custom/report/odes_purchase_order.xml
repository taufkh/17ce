<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="iconnexion_mccoy_report_odes_purchase_order_doc_inherited"
      inherit_id="odes_accounting.report_odes_purchase_order_doc">
      <xpath expr="." position="replace">
        <t t-foreach="docs" t-as="o">
          <t t-call="web.html_container">
            <t t-call="web.external_layout">
              <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)" />
              <div class="page">
                <div class="row mt32 mb32">
                  <div class="col-auto">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                      style="max-height: 65px;" alt="Logo" />
                    <!--                                <t t-if="o.journal_id.logo_journal">
                                  <img t-if="o.journal_id.logo_journal" t-att-src="image_data_uri(o.journal_id.logo_journal)" style="max-height: 65px;" alt="Logo"/>


                                </t>
                                <t t-if="not o.journal_id.logo_journal">
                                  <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 65px;" alt="Logo"/>
                                </t> -->
                  </div>

                  <div class="col-auto">
                    <h2 style="text-align: right;">PURCHASE ORDER</h2>
                    <br />
                    <div style="position:relative;width:100%;">
                      <img
                        t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;quite=0' % ('Code128', o.name, 400, 100)"
                        style="width:100%;height:35px;opacity:0" alt=" Barcode for layout only" />

                      <div class="main-image-barcode text-right" style="position:absolute; top:0; right:-72px;">
                        <img
                          t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;quite=0' % ('Code128', o.name, 400, 100)"
                          style="width:300px; height:35px;" alt="Barcode" />
                      </div>
                    </div>
                  </div>

                </div>
                <br />
                <div class="row mt32 mb32">
                  <div class="col-auto">
                    <div><span style="font-size : 15px; text-decoration: underline; font-weight: bold;"
                        t-field="o.company_id.name" /></div>
                    <div style="font-size : 12px;"><span t-field="o.company_id.house_no"/> </div>
                    <div style="font-size : 12px;"><span t-field="o.company_id.unit_no"/> </div>
                    <div style="font-size : 12px;"><span t-field="o.company_id.street"/> </div>
                    <div style="font-size : 12px;"><span t-field="o.company_id.street2"/> </div>
                    <div style="font-size : 12px;"><span t-field="o.company_id.city"/> <span t-field="o.company_id.state_id"/></div>
                    <div style="font-size : 12px;"> <span t-field="o.company_id.country_id"/> <span t-field="o.company_id.zip"/> </div>
                    <div style="font-size : 12px;">Tel : <span t-field="o.company_id.partner_id.phone"/></div>
                    <div style="font-size : 12px;">Fax : <span t-field="o.company_id.fax"/></div>
                  </div>
                  <div style="font-size : 12px;" class="col-auto">
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        COMPANY REG NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-field="o.company_id.vat" />
                      </div>
                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        GST REG NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-field="o.company_id.company_registry" />
                      </div>
                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        P.O DATE :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-esc="o.date_order.strftime('%d.%m.%Y')" />
                      </div>
                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        P.O NO :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span class="text-uppercase" t-field="o.name" />
                      </div>
                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        PAYMENT TERMS :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-field="o.payment_term_id" />
                      </div>
                    </div>
                    <div class="row mt32 mb32">
                      <div class="col-auto" style="text-align : right;">
                        FREIGHT TERMS :
                      </div>
                      <div class="col-auto" style="text-align : right;">
                        <span t-field="o.purchase_freight_terms_id.name" />
                      </div>
                    </div>
                  </div>
                </div>
                <br />
                <table style=" font-size : 14px; width:100%; border:1px solid #000;">
                  <tr>
                    <th style="border-right: 1px solid #000 !important;">
                      <div style="width:320px;height:200px;">
                        <br />
                        <div class="col-auto" t-if="o.partner_id">
                          <div class="row mt32 mb32">
                            <table style="padding : 5px; width: 100%;">
                              <tr>
                                <td style="padding-left: 15px; text-align:left; font-size:12px;" width="50px">Bill to
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <span style="padding-left: 10px; text-align:left; font-size:12px;"
                                    t-if="o.partner_id.parent_id" t-field="o.partner_id.parent_id"
                                    t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}" />
                                  <span style="padding-left: 10px; text-align:left; font-size:12px;" t-else=""
                                    t-field="o.partner_id"
                                    t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}" />
                                </td>
                              </tr>
                              <tr>
                                <td style="padding-left: 15px; text-align:left; font-size:12px;" width="50px">C.Person
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <span t-field="o.partner_id.name" />
                                </td>
                              </tr>
                              <tr>
                                <td style="padding-left: 15px; text-align:left; font-size:12px;" width="50px">Phone</td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <span t-field="o.partner_id.phone" />
                                </td>
                              </tr>
                            </table>
                          </div>
                        </div>
                      </div>
                    </th>
                    <th>
                      <div style="width:350px;height:200px;">
                        <br />
                        <div class="col-auto" t-if="o.company_id">
                          <div class="row mt32 mb32">
                            <table style="padding : 15px; width: 100%;">
                              <tr>
                                <td style="padding-left: 15px; text-align:left; font-size:12px;" width="50px">Deliver to
                                </td>
                                <td style="font-size:12px; padding-left: 5px;">:</td>
                                <td style="padding-left: 10px; text-align:left; font-size:12px;">
                                  <span style="padding-left: 10px; text-align:left; font-size:12px;"
                                    t-if="o.picking_type_id.warehouse_id.partner_id"
                                    t-field="o.picking_type_id.warehouse_id.partner_id"
                                    t-options="{'widget': 'contact', 'fields': ['name', 'address'], 'no_marker': True}" />
                                </td>
                              </tr>
                            </table>
                          </div>
                        </div>
                      </div>
                    </th>
                  </tr>
                </table>
                <!--
                          <br/> -->
                <div style="min-height : 280px">
                  <table style=" margin-top : 8px;" class="table table-sm o_main_table" name="invoice_line_table">
                    <thead style="font-size : 12px;">
                      <tr style="background-color: lightgrey;">
                        <th name="th_description" class="text-left"><span>Part No</span></th>
                        <th name="th_desc" class="text-left"><span>CPN</span></th>
                        <th name="th_req_date" class="text-center"><span>Delivery Date</span></th>
                        <th name="th_unit_price"
                          t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>Unit Price</span></th>
                        <th name="th_qty"
                          t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>Order Qty</span></th>
                        <th name="th_total"
                          t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                          <span>Total Price</span></th>
                      </tr>
                    </thead>
                    <tbody style="font-size : 12px;" class="invoice_tbody">
                      <t t-set="current_subtotal" t-value="0" />
                      <t t-set="line_count" t-value="0" />
                      <t t-set="lines" t-value="o.order_line" />
                      <t t-foreach="lines" t-as="line">
                        <t t-set="line_count" t-value="line_count + 1" />
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                          groups="account.group_show_line_subtotals_tax_excluded" />
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                          groups="account.group_show_line_subtotals_tax_included" />
                        <tr
                          t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                          <t t-if="not line.display_type" name="account_invoice_line_accountable">
                            <td name="account_invoice_line_name"><span t-field="line.product_id.default_code"
                                t-options="{'widget': 'text'}" /></td>
                            <td class="text-left"><span t-field="line.name" t-options="{'widget': 'text'}" /></td>
                            <td class="text-center"><span
                                t-esc="context_timestamp(line.date_planned).strftime('%d.%m.%Y')" /></td>
                            <td class="text-right">
                              <span class="text-nowrap" t-field="line.price_unit"
                                groups="account.group_show_line_subtotals_tax_excluded" />
                              <span class="text-nowrap" t-field="line.price_total"
                                groups="account.group_show_line_subtotals_tax_included" />
                            </td>
                            <td class="text-right">
                              <span class="text-nowrap" t-esc="'%.d'%line.product_uom_qty"
                                groups="account.group_show_line_subtotals_tax_excluded" />
                            </td>
                            <td class="text-right o_price_total">
                              <span class="text-nowrap" t-field="line.price_subtotal"
                                groups="account.group_show_line_subtotals_tax_excluded" />
                              <span class="text-nowrap" t-field="line.price_total"
                                groups="account.group_show_line_subtotals_tax_included" />
                            </td>
                          </t>
                          <t t-if="line.display_type == 'line_section'">
                            <td colspan="99">
                              <span t-field="line.name" t-options="{'widget': 'text'}" />
                            </td>
                            <t t-set="current_section" t-value="line" />
                            <t t-set="current_subtotal" t-value="0" />
                          </t>
                          <t t-if="line.display_type == 'line_note'">
                            <td colspan="99">
                              <span t-field="line.name" t-options="{'widget': 'text'}" />
                            </td>
                          </t>
                        </tr>
                        <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                          <tr class="is-subtotal text-right">
                            <td colspan="99">
                              <strong class="mr16">Subtotal</strong>
                              <span t-esc="current_subtotal"
                                t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}" />
                            </td>
                          </tr>
                        </t>
                      </t>
                    </tbody>
                  </table>
                </div>
                <!-- <div style="font-size : 12px" class="text-center; col-auto">Remarks: </div>
                          <div style="min-height: 280px; font-size : 12px" class="text-center; col-auto">1) Special Pricing Approval # MC2017004 <br/>
                          2) Ship by FEDEX Int'l Economy a/c # 3164-3714-1 <br/>
                          3) End Customer - Secure Meters Ltd <br/>
                          Address: RIICO Bhamashah Industrial Area, Kaladwas, Udaipur, RJ 313003</div> -->
                <div style="font-size : 12px; border-bottom: 1px solid black; position: absolute; width : 720px">
                  <i> <span t-field="o.notes" /></i>
                </div>
                <br />
                <div style="font-size : 11px" />
                <t t-if="line_count &lt;= 5">
                </t>
                <br />
                <br />
                <br />
                <br />
                <div class="row mt32 mb32">
                  <div class="col-auto" style="margin-top: -95px;">
                    <div class="signature">
                      <t t-if="o.user_confirm_id.sign_signature and o.state in ['to approve', 'purchase', 'done'] ">
                        <!-- <div style="background-image: url(https://miro.medium.com/max/72/1*QCA8qoD19bxZOsSt0MWRoA.png)">
                                                 <img  style="margin-left: -75px;" t-att-src="'data:image/png;base64,%s' % to_text(o.user_confirm_id.sign_signature)"/>
                                              </div> -->
                        <!-- <div style="background-image: url(/odes_sign/static/src/img/stamp_mccoy-removebg.png);  background-repeat: no-repeat; background-size:60%; margin-top : 25px;">
                                                 <img style="margin-left: -75px;" t-att-src="'data:image/png;base64,%s' % to_text(o.user_confirm_id.sign_signature)"/>
                                              </div> -->
                        <br />
                        <br />
                        <div class="row mt16 mb16">
                          <div class="col-auto">
                            <img style="height : 100px; margin-left: -65px; "
                              t-att-src="'data:image/png;base64,%s' % to_text(o.user_confirm_id.sign_signature)" />
                          </div>
                          <t t-if="current_subtotal &lt; 5000">
                            <div class="col-auto">
                              <img style="width : 100%; margin-left: 0px;"
                                src="/odes_sign/static/src/img/stamp_mccoy-removebg.png" />
                            </div>
                          </t>

                        </div>
                      </t>
                      <!-- <t t-if="o.company_id.company_chop">
                                             <img  style="width:80%; height:25px; margin-left: -75px;" t-att-src="'data:image/png;base64,%s' % to_text()" />
                                           </t> -->
                      <t
                        t-if="not o.user_confirm_id.sign_signature or o.state not in ['to approve', 'purchase', 'done']">
                        <br />
                        <br />
                        <br />
                        <br />
                        <br />
                        <br />
                        <br />
                      </t>
                      <div>____________________________</div>
                      <!-- <div style="margin-left: 60px; font-weight : 100;">KEITH</div> -->
                    </div>
                  </div>
                  <div class="col-auto" style="margin-top: -95px;">
                    <t t-if="current_subtotal &gt; 5000">
                      <div class="signature">
                        <t t-if="o.user_approve_id.sign_signature and o.state in ['purchase', 'done'] ">

                          <br />
                          <br />
                          <div class="row mt16 mb16">
                            <div class="col-auto">
                              <img style="height : 100px; margin-left: -65px; "
                                t-att-src="'data:image/png;base64,%s' % to_text(o.user_approve_id.sign_signature)" />
                            </div>
                            <div class="col-auto">
                              <img style="width : 100%; margin-left: 0px;"
                                src="/odes_sign/static/src/img/stamp_mccoy-removebg.png" />
                            </div>
                          </div>
                        </t>
                        <!-- <t t-if="o.company_id.company_chop">
                                             <img  style="width:80%; height:25px; margin-left: -75px;" t-att-src="'data:image/png;base64,%s' % to_text()" />
                                           </t> -->
                        <t t-if="not o.user_approve_id.sign_signature or o.state not in ['purchase', 'done']">
                          <br />
                          <br />
                          <br />
                          <br />
                          <br />
                          <br />
                          <br />
                        </t>
                        <div>____________________________</div>
                        <!-- <div style="margin-left: 60px; font-weight : 100;">MIKE</div> -->
                      </div>
                    </t>
                  </div>
                  <div class="col-auto">
                    <table class="table"
                      style=" margin-top : -35px; font-size : 12px; font-weight : 700; width:70%; float : right; border:1px solid #000;">
                      <tr class="border-black o_total" style="border-bottom: 1px solid #000 !important;">
                        <td
                          style="padding: 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                          <strong style="padding-left : 8px;">SUBTOTAL</strong></td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <strong><span t-field="o.amount_untaxed" /></strong>
                        </td>
                      </tr>
                      <t t-foreach="o.taxes()" t-as="tx">
                        <t t-if="tx['amount'] * (tx['tax']/100) != 0">
                          <tr style="">
                            <td
                              style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important;">
                              <strong style="padding-left : 8px;">GST <span t-esc="int(tx['tax'])" />%</strong>
                            </td>
                            <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                              <strong><span t-if="o.currency_id" t-field="o.currency_id.symbol" />
                                <t t-esc="tx['amount'] * (tx['tax']/100)"
                                      t-options="{'widget': 'float', 'precision': 2}" />
                              </strong>
                            </td>
                          </tr>
                        </t>
                      </t>
                      <tr style="">
                        <td
                          style="padding : 5px; border-bottom: 1px solid #000 !important; border-right: 1px solid #000 !important; ">
                          <strong style="padding-left : 8px;">Total Amount</strong></td>
                        <td style="padding : 5px; border-bottom: 1px solid #000 !important;" class="text-right">
                          <strong><span class="text-nowrap" t-field="o.amount_total" /></strong>
                        </td>
                      </tr>
                    </table>
                    <br />
                  </div>
                </div>
              </div>
            </t>
          </t>
        </t>
      </xpath>
    </template>

  </data>
</odoo>