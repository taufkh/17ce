                <br />
                <table style=" font-size : 14px; width:100%; border:1px solid #000;">
                  <tr>
                    <th style="border-right: 1px solid #000 !important;padding-bottom:30px;">
                      <div style="width:340px;height:130px;">
                        <br />
                        <div class="col-auto">
                          <div class="row mt32 mb32">
                            <table style="margin-top:-20px;padding:15px;width: 100%;">
