    <record id="view_iconnexion_account_payment_form_inherit" model="ir.ui.view">
        <field name="name">iconnexion.account.payment.form.inherit</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account_accountant.view_account_payment_form_inherit_account_accountant"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_manual_reconciliation_widget']" position="replace">
                <field name="sale_id" invisible="1"/>
                <button name="action_open_manual_reconciliation_widget" type="object" string="Payment Matching" class="oe_stat_button" icon="fa-dollar" groups="account.group_account_user" invisible="(is_reconciled or state != 'posted') or sale_id"/>
            </xpath>
        </field>
    </record>
    	

    <record id="view_invoice_tax_tree" model="ir.ui.view">
        <field name="name">account.invoice.tax.tree</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <tree string="Invoices">
                <field name="name" decoration-bf="1"/>
                <field name="partner_id" invisible="1"/>
                <field name="invoice_partner_display_name" string="Customer" />
                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}" optional="show"/>
                <field name="invoice_date" string="Invoice Date"/>
                <field name="activity_ids" widget="list_activity" optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_currency_id" invisible="1"/>
                <field name="tax_rate"/>
                <field name="amount_untaxed_signed" string="Tax Excluded" sum="Total" optional="hide"/>
                <field name="amount_total_signed" string="Total" sum="Total" decoration-bf="1" optional="hide"/>
                <field name="tax_amount" decoration-bf="1" optional="show"/>
                <field name="paid_amount" string="Amount" decoration-bf="1" optional="show"/>
                <field name="currency_sgd_id" invisible="1"/>
                <field name="amount_untaxed_signed_sgd" optional="hide"/>
                <field name="amount_total_signed_sgd" decoration-bf="1" optional="hide"/>
                <field name="tax_amount_sgd" decoration-bf="1" optional="show"/>
                <field name="paid_amount_sgd" string="Amount (SGD)" decoration-bf="1" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" optional="show"/>
                <field name="payment_state" widget="badge" decoration-danger="payment_state == 'not_paid'" decoration-warning="payment_state in ('partial', 'in_payment')" decoration-success="payment_state in ('paid', 'reversed')" invisible="payment_state in 'invoicing_legacy'"/>

            </tree>
        </field>
    </record>

    <record id="action_iconnexion_mccoy_moves_all_tree" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.move</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="view_id" ref="iconnexion_mccoy_custom.view_invoice_tax_tree"/>
    </record>

    <record id="view_iconn_mccoy_account_move_form_inherit_view_odes_account_move_form" model="ir.ui.view">
        <field name="name">iconn.mccoy.account.move.form.inherit.view.odes.account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="odes_accounting.view_odes_account_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='delivery_terms']" position="replace">
                <field name="is_mccoy" invisible="1"/>
                <field name="is_odes" invisible="1"/>
                <field name="is_iconnexion" invisible="1"/>
                <field name="is_income" invisible="1" />
                <field name="delivery_terms" invisible="is_mccoy or is_iconnexion"/>
            </xpath>
            <xpath expr="//field[@name='freight_terms']" position="replace">
                <field name="freight_terms" invisible="is_mccoy or is_iconnexion"/>
            </xpath>
            <xpath expr="//field[@name='delivery_terms']" position="after">
                <field name="delivery_method_id" invisible="is_odes" domain="[('is_delivery_method', '=', True),('company_id','=',allowed_company_ids)]" options="{'no_create_edit': True, 'no_create':True, 'no_open':True}"/>
            </xpath>
            <xpath expr="//field[@name='freight_terms']" position="after">
                <field name="freight_terms_id" invisible="is_odes" domain="[('is_delivery_method', '=', False),('company_id','=',allowed_company_ids)]" options="{'no_create_edit': True, 'no_create':True, 'no_open':True}"/>
            </xpath>
            
        </field>
    </record>


    <record id="view_iconn_mccoy_account_move_form_inherit_iconnexion_custom_view_move_form_inherit" model="ir.ui.view">
        <field name="name">iconn.mccoy.account.move.form.inherit.iconnexion.custom.view.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="iconnexion_custom.view_move_form_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_rate']" position="replace">
                <field name="currency_rate" string="Currency Rate" digits="[12,12]" invisible="move_type == 'entry'"/>
            </xpath>
            <xpath expr="//field[@name='sale_order_no_id']" position="after">
                <field name="delivery_order_id" invisible="move_type != 'out_invoice'" readonly="1"/>
                <field name="receipt_id" invisible="move_type != 'in_invoice'" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='sale_order_no_id']" position="attributes">
                <attribute name="attrs">{'invisible': [('move_type', '!=', 'out_invoice')]}</attribute>
            </xpath>
            <xpath expr="//field[@name='sale_quotation_no_id']" position="attributes">
                <attribute name="attrs">{'invisible': [('move_type', '!=', 'out_invoice')]}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_iconn_mccoy_tax_report_line_tree" model="ir.ui.view">
        <field name="name">account.invoice.line.tax.report.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <!-- <tree>
                <field name="account_id"/>
                <field name="name" string="Tax %"/>
                <field name="move_id" string="Doc. No." widget="many2onebutton" type="many2one" options="{'always_reload': True}" context="{'form_view_ref': 'account.view_move_form'}"/>
                <field name="date" string="Document Date"/>
                <field name="company_currency_id" string="Currency" optional="hide"/>
                <field name="tax_base_amount"/>
                <field name="tax_amount"/>
                <field name="currency_sgd_id" string="Currency" optional="hide"/>
                <field name="currency_tax_base_amount" string="Base Amount SC"/>
                <field name="currency_tax_amount" string="Tax Amount SC"/>
            </tree> -->
            <tree create='false' edit='false' delete='false' expand="1">
                <field name="move_id" string="Doc. No." widget="many2onebutton" type="many2one" options="{'always_reload': True}" context="{'form_view_ref': 'account.view_move_form'}"/>
                <field name="partner_id" string="Partner" invisible="0"/>
                <field name="date" string="Document Date"/>
                <field name="name" string="Label"/>
                <field name="amount_total_company_currency" sum="Total" string="Base Amount (USD)"/>
                <field name="usd_tax_amount" sum="Total" string="Tax (USD)"/>
                <field name="amount_total_sgd" sum="Total" string="Base Amount (SGD)"/>
                <field name="sgd_tax_amount" sum="Total" string="Tax (SGD)"/>
                <field name="currency_id" invisible="1"/>
                <field name="sgd_currency_id" invisible="1"/>
                <field name="company_currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Community-safe: ssp_account_payment_multi extension is skipped. -->

    <record id="view_iconn_mccoy_account_move_form_inherit_odes_sign_view_move_form_inherit" model="ir.ui.view">
        <field name="name">iconn.mccoy.account.move.form.inherit.odes.sign.view.move.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="odes_sign.view_move_form_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_balance_id']" position="replace">
                <field name="account_balance_id" invisible="not is_expense and not is_income" required="is_expense or is_income" options="{'no_create': True}" domain="[('deprecated', '=', False)]"/>
            </xpath>
        </field>
    </record>

    <record id="view_iconn_mccoy_account_move_form_inherit_account_view_move_form" model="ir.ui.view">
        <field name="name">iconn.mccoy.account.move.form.inherit.account.view.move.form"</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']//field[@name='account_id']" position="after">
                <field name="is_account_balance_line" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="pay_to" invisible="not is_expense"/>
            </xpath>
            <xpath expr="//field[@name='ref']" position="after">
                <field name="remarks" invisible="not is_expense"/>
                <field name="journal_remarks" invisible="not is_expense"/>
                <field name="amount_text" invisible="1"/>
            </xpath>
            <xpath expr="//header" position="inside">
               <button string="Print Expense Report" type="object" class="oe_highlight" icon="fa-print" name="action_print_expense_report" invisible="not is_expense or payment_state not in ('paid', 'in_payment')"/>
            </xpath>
        </field>
    </record>

    <record id="action_move_out_receipt_type_income_input" model="ir.actions.act_window">
        <field name="name">Income Input</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_id" ref="account.view_invoice_tree"/>
        <field name="search_view_id" ref="account.view_account_invoice_filter"/>
        <field name="domain">[('move_type', '=', 'out_receipt'), ('is_income', '=', True)]</field>
        <field name="context">{'default_move_type': 'out_receipt', 'default_is_income': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            Create a new income
            </p>
        </field>
    </record>

    <record id="account.action_move_out_receipt_type" model="ir.actions.act_window">
            <field name="name">Receipts</field>
            <field name="res_model">account.move</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="view_id" ref="account.view_invoice_tree"/>
            <field name="search_view_id" ref="account.view_account_invoice_filter"/>
            <field name="domain">[('move_type', '=', 'out_receipt'), ('is_income', '=', False)]</field>
            <field name="context">{'default_move_type': 'out_receipt'}</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create a new sales receipt
              </p><p>
                When the sale receipt is confirmed, you can record the customer
                payment related to this sales receipt.
              </p>
            </field>
        </record>

    <menuitem id="menu_iconnexion_income_input" action="action_move_out_receipt_type_income_input"
        parent="account.menu_finance_receivables" />
</odoo>
