<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_icon_stock_move_line_tree_inherit" model="ir.ui.view">
        <field name="name">icon.stock.move.line.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>        
        <field name="arch" type="xml">            
            <xpath expr="//field[@name='date']" position="replace">
                <field name="origin" optional="show"/>  
                <field name="serial_numbers" optional="show"/>
                <field name="write_date" optional="show" string="Scan Date"/>
                <field name="icon_factory_reschedule_date" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='quantity']" position="after">
                <field name="stock_used" optional="show"/>
                <field name="buffer_stocks" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='reference']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='location_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='location_dest_id']" position="attributes">
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>
    <record id="stock_valuation_layer_form" model="ir.ui.view">
        <field name="name">icon.stock.valuation.layer.inherit</field>
        <field name="model">stock.valuation.layer</field>
        <field name="inherit_id" ref="stock_account.stock_valuation_layer_form"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='create_date']" position="replace">
                <field name="date_cogs"/>  
            </xpath>
        </field>
    </record>
    <record id="stock_valuation_layer_tree" model="ir.ui.view">
        <field name="name">tree.stock.valuation.layer.inherit</field>
        <field name="model">stock.valuation.layer</field>
        <field name="inherit_id" ref="stock_account.stock_valuation_layer_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='create_date']" position="replace">
                <field name="date_cogs"/>  
            </xpath>
        </field>
    </record>
    <record id="iconn_warehouse_daily_receiving_tree" model="ir.ui.view">
        <field name="name">iconn.warehouse.daily.receiving.tree</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="iconnexion_custom.warehouse_daily_receiving_tree" />
        <field name="arch" type="html">
            <xpath expr="//field[@name='write_date']" position="replace">
                <field name="create_date"/>
                <field name="write_date" />
                <field name="date" string="Scan In Date"/>
                <!-- <field name="lot_id_domain_list" invisible="1"/> -->
            </xpath>
        </field>
    </record>

    <record id="view_icon_mccoy_stock_move_line_detailed_operation" model="ir.ui.view">
        <field name="name">icon.mccoy.stock.move.line.form.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>        
        <field name="arch" type="xml">        
            <xpath expr="//field[@name='product_id']" position="before">
                <field name="warehouse_label_code" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
