    <record id="view_iconn_mccoy_sale_order_line_tree_inherit_iconnexion_custom_view_icon_order_line_tree" model="ir.ui.view">
        <field name="name">iconn.mccoy.sale.order.line.tree.inherit.iconnexion.custom.view.icon.order.line.tree</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="iconnexion_custom.view_icon_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_partner_id']" position="after">
                <field name="contact_id" optional="show" />
            </xpath>
            <xpath expr="//field[@name='order_id']" position="before">
                <field name="serial_numbers" optional="show" />
            </xpath>
        </field>
    </record>

    <record id="iconnexion_custom.icon_sale_order_line_action" model="ir.actions.act_window">
        <field name="name">Sale Orders Line</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order.line</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="search_view_id" ref="iconnexion_custom.sale_order_line_view_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">

            </p>
            <p>

            </p>
        </field>
    </record>

    <record id="sale_order_lines_tree_view" model="ir.actions.act_window.view">
        <field eval="1" name="sequence" />
        <field name="view_mode">tree</field>
        <field name="view_id" ref="iconnexion_custom.view_icon_order_line_tree" />
        <field name="act_window_id" ref="iconnexion_custom.icon_sale_order_line_action" />
    </record>

    <record id="sale_order_lines_form_view" model="ir.actions.act_window.view">
        <field eval="2" name="sequence" />
        <field name="view_mode">form</field>
        <field name="view_id" ref="iconn_sale_order_line_form_view" />
        <field name="act_window_id" ref="iconnexion_custom.icon_sale_order_line_action" />
    </record>

    <record id="iconn_mccoy_sale_order_search_inherit_sale_view_sales_order_filter" model="ir.ui.view">
        <field name="name">iconn.mccoy.sale.order.search.inherit.sale.view.sales.order.filter</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <field name="order_line" position="after">
                <field name="cpn"/>
            </field>
        </field>
    </record>
</odoo>
