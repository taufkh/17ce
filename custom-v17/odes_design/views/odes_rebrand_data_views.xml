<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	
        
        <record id="odes_rebrand_data_view_tree" model="ir.ui.view">
            <field name="name">odes.rebrand.data.view.tree</field>
            <field name="model">odes.rebrand.data</field>
            <field name="type">tree</field>
            <field name="priority">1</field>
            <field name="arch" type="xml"> 
                <tree create="false" edit="false" >
                    <field name="name"/> 
                    <field name="website_url"/> 
                    
                </tree>
            </field>
        </record>
        
        
        
        
        <record id="action_odes_rebrand_data_configuration" model="ir.actions.act_window">
            <field name="name">Rebrand Data</field>
            <field name="res_model">odes.rebrand.data</field>
            <field name="view_mode">tree</field>  
        </record>
        
        <menuitem id="menu_odes_rebrand_data_configuration"
            name="Rebrand Name"
            action="action_odes_rebrand_data_configuration"
            parent="odes_design.rebranding_config_parent_data"
            sequence="97"/>
        
        
        

</odoo>