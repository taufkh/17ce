<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <template id="auth_signup.login" inherit_id="web.login" name="Sign up - Reset Password">
            <xpath expr="//button[@type='submit']" position="after">
                <div class="justify-content-between mt-2 d-flex small">
                    <a t-if="signup_enabled" style="display: none;"  t-attf-href="/web/signup?{{ keep_query() }}">Don't have an accounts?</a>
                    <a t-if="reset_password_enabled"  t-attf-href="/web/reset_password?{{ keep_query() }}">Reset Passwords</a>
                </div>
            </xpath>
        </template>

        

        
</odoo>
