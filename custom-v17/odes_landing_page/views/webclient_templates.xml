            				<form style="background: #0664b899;border-radius: 5px;margin-top: 84px;" class="box_form_data" action="/intelligent-automation-temporary" method="post">
            					<div style="padding: 30px 10%;" class="text-center">
            						<p class="text-left" style="font-size: 20px;    margin-bottom: 10px;
"><strong>Are you on the right track?</strong></p>
	            					<p class="text-left" style="font-size: 20px;word-spacing: 6px;line-height: 20px;">Know where you stand on the digital landscape once you receive your results from our test.</p>
	            					<input type="text" placeholder="Name*"  name="name" style="width:100%;" required="1"/>
	            					<input type="text" placeholder="Phone Number*"  name="phone" style="width:100%;" required="1"/>
	            					<input type="email" placeholder="Email Address*"  name="email" style="width:100%;" required="1"/>
	            					<input type="text" placeholder="Company Name*"  name="companyname" style="width:100%;" required="1"/>

