<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="documents_upload_url_view" model="ir.ui.view">
        <field name="name">documents.upload.url.wizard.form</field>
        <field name="model">documents.upload.url.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload URL">
                <sheet>
                    <group>
                        <field name="url"/>
                        <field name="name"/>
                        <field name="folder_id"/>
                        <field name="tag_ids"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_add" type="object" class="btn-primary" string="Add"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="document_view_kanban" model="ir.ui.view">
        <field name="name">documents.document.kanban</field>
        <field name="model">documents.document</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div>
                            <strong><field name="name"/></strong>
                            <time class="oe_kanban_bottom_left"><field name="create_date"/></time>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="documents_view_tree" model="ir.ui.view">
        <field name="name">documents.document.tree</field>
        <field name="model">documents.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="url"/>
                <field name="owner_id"/>
                <field name="type"/>
            </tree>
        </field>
    </record>

    <record id="documents_view_list" model="ir.ui.view">
        <field name="name">documents.document.list</field>
        <field name="model">documents.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="url"/>
                <field name="owner_id"/>
                <field name="type"/>
            </tree>
        </field>
    </record>

    <record id="documents_action" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">documents.document</field>
        <field name="view_mode">tree,form,kanban</field>
    </record>

    <menuitem id="menu_documents_root" name="Documents" parent="base.menu_custom" sequence="30"/>
    <menuitem id="Config" name="Configuration" parent="menu_documents_root" sequence="40"/>
    <menuitem id="menu_documents" name="All Documents" parent="menu_documents_root" action="documents_action" sequence="10"/>
</odoo>
