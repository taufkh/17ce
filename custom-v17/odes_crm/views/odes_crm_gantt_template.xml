<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="assets_backend" inherit_id="web.assets_backend" name="Backend Assets">
        <xpath expr="//link[last()]" position="after">
            <link rel="stylesheet" type="text/scss" href="/odes_crm/static/src/scss/web_gantt.scss"/>
            <link rel="stylesheet" type="text/css" href="/odes_crm/static/src/css/ribbon.css"/>
        </xpath>
        <xpath expr="//script[last()]" position="after">
            <script type="text/javascript" src="/odes_crm/static/src/js/task_gantt_model.js"></script>
            <script type="text/javascript" src="/odes_crm/static/src/js/task_gantt_view.js"></script>
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_renderer.js"></script>
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_model.js"></script>
        </xpath>
        <xpath expr="//script[@src='/web_gantt/static/src/js/gantt_controller.js']" position="replace">
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_controller.js"></script>
        </xpath>
        <xpath expr="//script[@src='/odes_custom/static/src/js/gantt_row.js']" position="replace">
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_row.js"></script>
        </xpath>
        <xpath expr="//script[@src='/odes_custom/static/src/js/gantt_view.js']" position="replace">
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_view.js"></script>
        </xpath>
        <xpath expr="//script[@src='/web/static/src/js/views/kanban/kanban_column.js']" position="replace">
            <script type="text/javascript" src="/odes_crm/static/src/js/views/kanban/kanban_column.js"></script>
        </xpath>
        <!-- <xpath expr="//script[@src='/web_gantt/static/src/js/gantt_row.js']" position="replace">
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_row.js"></script>
        </xpath>
        <xpath expr="//script[@src='/web_gantt/static/src/js/gantt_view.js']" position="replace">
            <script type="text/javascript" src="/odes_crm/static/src/js/gantt_view.js"></script>
        </xpath> -->
    </template>
</odoo>