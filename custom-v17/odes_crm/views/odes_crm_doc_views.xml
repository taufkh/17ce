<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odes_crm_doc_tree" model="ir.ui.view">
        <field name="name">odes.crm.doc.tree</field>
        <field name="model">odes.crm.doc</field>
        <field name="arch" type="xml">
            <tree string="Documentations">
                <field name="sequence" widget="handle"/>
                <field name="name" invisible="1"/>
                <field name="title_id" string="Name" required="1" options="{'no_open': 1, 'no_create_edit': 1}" readonly="state == 'acknowledged'"/>
                <field name="attachment_ids" widget="many2many_binary" readonly="state == 'acknowledged'"/>
                <field name="upload_user_id" readonly="1" options="{'no_open': 1}" force_save="1"/>
                <field name="date" required="1" readonly="state == 'acknowledged'"/>
                <field name="date_acknowledge" readonly="1"/>
                <field name="acknowledge_user_id" readonly="1" options="{'no_open': 1}"/>
                <field name="state" readonly="1"/>
                <button type="object" name="action_acknowledge" string="Acknowledge" class="oe_highlight" invisible="state not in ('draft')" groups="sales_team.group_sale_manager,odes_crm.group_odes_c_level"/>
            </tree>
        </field>
    </record>

    <record id="view_odes_crm_doc_form" model="ir.ui.view">
        <field name="name">odes.crm.doc.form</field>
        <field name="model">odes.crm.doc</field>
        <field name="arch" type="xml">
            <form string="Documentations">
                <header>
                    <button type="object" name="action_acknowledge" string="Acknowledge" class="oe_highlight" invisible="state not in ('draft')" groups="sales_team.group_sale_manager,odes_crm.group_odes_c_level"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <field name="name" invisible="1"/>

                    <div class="oe_title">
                        <h1>
                            <field name="title_id" required="1" options="{'no_open': 1, 'no_create_edit': 1}" readonly="state == 'acknowledged'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" required="1" readonly="state == 'acknowledged'"/>
                            <field name="attachment_ids" widget="many2many_binary" readonly="state == 'acknowledged'"/>
                            <field name="date_acknowledge" readonly="1" invisible="state not in ('acknowledged')"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="upload_user_id" readonly="1" options="{'no_open': 1}" force_save="1"/>
                            <field name="acknowledge_user_id" readonly="1" invisible="state not in ('acknowledged')" options="{'no_open': 1}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>