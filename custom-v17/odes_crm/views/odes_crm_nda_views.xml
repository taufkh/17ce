<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odes_crm_nda_tree" model="ir.ui.view">
        <field name="name">odes.crm.nda.tree</field>
        <field name="model">odes.crm.nda</field>
        <field name="arch" type="xml">
            <tree string="NDA" create="0" edit="0">
                <field name="name"/>
                <field name="user_id" string="Customer"/>
                <field name="date_nda"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_odes_crm_nda_form" model="ir.ui.view">
        <field name="name">odes.crm.nda.form</field>
        <field name="model">odes.crm.nda</field>
        <field name="arch" type="xml">
            <form string="NDA" create="0">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="user_id" readonly="1" options="{'no_open': 1, 'no_create_edit': 1}" string="Customer"/>
                            <field name="date_nda" readonly="1"/>
                            <field name="date_confirm" readonly="1" invisible="state not in ('confirmed')"/>
                        </group>
                        <group>
                            <field name="partner_id" readonly="1" groups="base.group_no_one"/>
                            <field name="opportunity_id" readonly="1" groups="base.group_no_one"/>
                        </group>
                    </group>

                    <group string="Company Information">
                        <group>
                            <field name="company_name" readonly="state == 'confirmed'"/>
                            <field name="short_name" readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="uen" readonly="state == 'confirmed'"/>
                            <field name="registered_address" readonly="state == 'confirmed'"/>
                        </group>
                    </group>

                    <field name="nda_display" widget="html" nolabel="1" readonly="1"/>
                    <button type="object" name="action_confirm" class="oe_highlight" invisible="state not in ('draft')" string="Confirm NDA" groups="odes_crm.group_odes_customer,odes_crm.group_odes_c_level"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_odes_crm_nda" model="ir.actions.act_window">
        <field name="name">NDA</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">odes.crm.nda</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You don't have any NDA to confirm.
            </p>
        </field>
    </record>

    <menuitem id="menu_odes_crm_nda" parent="odes_crm.odes_crm_customer_portal" action="action_odes_crm_nda" sequence="1"/>
</odoo>