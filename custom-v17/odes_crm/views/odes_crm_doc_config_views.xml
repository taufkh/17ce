<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odes_crm_doc_config_tree" model="ir.ui.view">
        <field name="name">odes.crm.doc.config.tree</field>
        <field name="model">odes.crm.doc.config</field>
        <field name="arch" type="xml">
            <tree string="Documentation Configs">
                <field name="sequence" widget="handle"/>
                <field name="name" invisible="1"/>
                <field name="title_id" string="Name" required="1"/>
            </tree>
        </field>
    </record>

    <record id="view_odes_crm_doc_config_form" model="ir.ui.view">
        <field name="name">odes.crm.doc.config.form</field>
        <field name="model">odes.crm.doc.config</field>
        <field name="arch" type="xml">
            <form string="Documentation Configs">
                <sheet>
                    <group>
                        <field name="name" invisible="1"/>

                        <group>
                            <field name="title_id" string="Name" required="1"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>