<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <record id="mail_template_odes_crm_feedback_pm" model="mail.template">
            <field name="name">ODES CRM: Requirement Feedback</field>
            <field name="model_id" ref="odes_crm.model_odes_crm_requirement_feedback"/>
            <field name="subject">Project Requirement Feedback </field>
            <field name="email_from">"${object.requirement_id.company_id.name | safe}" &lt;${(object.requirement_id.company_id.email or user.email) | safe}&gt;</field>
            <field name="email_to">${object.requirement_id.get_pm_email() | safe}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0" style="padding-top:16px;background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;"><tbody><tr><td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="800" style="padding:16px;background-color: white; color: #454748; border-collapse:separate;">
                <tbody>
                    <!-- HEADER -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle">
                                            <img src="/odes_design/static/src/img/ODES-logo.png" style="padding:0px;margin: 0px; height: auto; width: 80px;" alt="${object.requirement_id.company_id.name}"/>
                                        </td
                                        <td valign="middle"></td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="text-align:center;">
                                            <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <!-- CONTENT -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody><tr><td valign="top" style="font-size:13px;">
                                    <div>
                                        <p>Dear PM,</p>
                                        <p>There's new feedback attached at the system in the <strong>${object.requirement_id.number}</strong></p>  
                                        <p>Please kindly check on this update</p>
                                    </div>
                                </td></tr>
                                <tr><td style="text-align:center;">
                                    <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                </td></tr>
                            </tbody></table>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle" align="left">
                                            ${object.requirement_id.company_id.name}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td valign="middle" align="left" style="opacity:0.7;">
                                            <a href="https://odes.com.sg/" style="text-decoration:none;background-color: rgb(255, 255, 255); font-family: &quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px;"><span style="font-weight:bolder;">https://odes.com.sg</span></a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </tbody>
                </table>
                </td></tr>
                <!-- POWERED BY -->
                <tr>
                    <td align="center" style="min-width:800px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: #F1F1F1; color: #454748; padding: 8px; border-collapse:separate;">
                            <tbody>
                                <tr>
                                    <td style="text-align:center;font-size: 13px;">
                                        Powered by <a target="_blank" href="https://www.odes.com.sg?utm_source=db&amp;utm_medium=auth" style="color:#1B66B7;">ODES</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                </tbody>
                </table>
            </field>
        </record>

        <record id="mail_template_odes_crm_feedback_dev" model="mail.template">
            <field name="name">ODES CRM: Requirement Feedback</field>
            <field name="model_id" ref="odes_crm.model_odes_crm_requirement_feedback"/>
            <field name="subject">Project Requirement Feedback </field>
            <field name="email_from">"${object.requirement_id.company_id.name | safe}" &lt;${(object.requirement_id.company_id.email or user.email) | safe}&gt;</field>
            <field name="email_to">${object.requirement_id.get_dev_email() | safe}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0" style="padding-top:16px;background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;"><tbody><tr><td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="800" style="padding:16px;background-color: white; color: #454748; border-collapse:separate;">
                <tbody>
                    <!-- HEADER -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle">
                                            <img src="/odes_design/static/src/img/ODES-logo.png" style="padding:0px;margin: 0px; height: auto; width: 80px;" alt="${object.requirement_id.company_id.name}"/>
                                        </td>
                                        <td valign="middle"></td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="text-align:center;">
                                            <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <!-- CONTENT -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody><tr><td valign="top" style="font-size:13px;">
                                    <div>
                                        <p>Dear Developers,</p>
                                        <p>There's new feedback attached at the system in the <strong>${object.requirement_id.number}</strong></p>
                                        <p>Please kindly check on this update</p>
                                    </div>
                                </td></tr>
                                <tr><td style="text-align:center;">
                                    <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                </td></tr>
                            </tbody></table>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle" align="left">
                                            ${object.requirement_id.company_id.name}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td valign="middle" align="left" style="opacity:0.7;">
                                            <a href="https://odes.com.sg/" style="text-decoration:none;background-color: rgb(255, 255, 255); font-family: &quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px;"><span style="font-weight:bolder;">https://odes.com.sg</span></a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </tbody>
                </table>
                </td></tr>
                <!-- POWERED BY -->
                <tr>
                    <td align="center" style="min-width:800px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: #F1F1F1; color: #454748; padding: 8px; border-collapse:separate;">
                            <tbody>
                                <tr>
                                    <td style="text-align:center;font-size: 13px;">
                                        Powered by <a target="_blank" href="https://www.odes.com.sg?utm_source=db&amp;utm_medium=auth" style="color:#1B66B7;">ODES</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                </tbody>
                </table>
            </field>
        </record>

        
        <record id="mail_template_odes_crm_platform_account_created" model="mail.template">
            <field name="name">ODES CRM: Platform Account Created</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="subject">ODES Platform Account Created</field>
            <field name="email_from">"${object.company_id.name | safe}" &lt;${(object.company_id.email or user.email) | safe}&gt;</field>
            <field name="email_to">${object.email_from | safe}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0" style="padding-top:16px;background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;"><tbody><tr><td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="590" style="padding:16px;background-color: white; color: #454748; border-collapse:separate;">
                <tbody>
                    <!-- HEADER -->
                    <tr>
                        <td align="center" style="min-width:590px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width:590px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle">
                                            <span style="font-size:10px;">Your Account</span><br/>
                                            <span style="font-size:20px;font-weight: bold;">
                                                ${object.name}
                                            </span>
                                        </td>
                                        <td valign="middle" align="right">
                                            <img src="/odes_design/static/src/img/ODES-logo.png" style="padding:0px;margin: 0px; height: auto; width: 80px;" alt="${object.company_id.name}"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="text-align:center;">
                                            <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <!-- CONTENT -->
                    <tr>
                        <td align="center" style="min-width:590px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width:590px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="top" style="font-size:13px;">
                                            <div>
                                                <p>Dear Sir/Mdm,</p>
                                                <p>We are pleased to inform you that your user login into the ODES Platform has been created. Kindly login in with your registered email address in order to access the NDA and complete the acknowledgement.</p>
                                                <p>This will then allow the progress of your enquiry to proceed to the next steps. For any clarifications, kindly send an email to <a href="mailto:info@mccoy.com.sg">info@mccoy.com.sg</a> and we will be most pleased to assist you.</p>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:center;">
                                            <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    <tr>
                        <td align="center" style="min-width:590px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width:590px;background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle" align="left">
                                            ${object.company_id.name}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td valign="middle" align="left" style="opacity:0.7;">
                                            <a href="https://odes.com.sg/" style="text-decoration:none;background-color: rgb(255, 255, 255); font-family: &quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px;"><span style="font-weight:bolder;">https://odes.com.sg</span></a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </tbody>
                </table>
                </td></tr>
                <!-- POWERED BY -->
                <tr>
                    <td align="center" style="min-width:590px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width:590px;background-color: #F1F1F1; color: #454748; padding: 8px; border-collapse:separate;">
                            <tbody>
                                <tr>
                                    <td style="text-align:center;font-size: 13px;">
                                        Powered by <a target="_blank" href="https://www.odes.com.sg?utm_source=db&amp;utm_medium=auth" style="color:#1B66B7;">ODES</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                </tbody>
                </table>
            </field>
        </record>

