        <record id="mail_template_odes_crm_notify_client" model="mail.template">
            <field name="name">ODES CRM: Notify Client</field>
            <field name="model_id" ref="odes_crm.model_odes_crm_requirement"/>
            <field name="subject">ODES Project Requirement(s) Attention</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <table border="0" cellpadding="0" cellspacing="0" style="padding-top:16px;background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;"><tbody><tr><td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="800" style="padding:16px;background-color: white; color: #454748; border-collapse:separate;">
                <tbody>
                    <!-- HEADER -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle">
                                            <img src="/odes_design/static/src/img/ODES-logo.png" style="padding:0px;margin: 0px; height: auto; width: 80px;" alt="${object.company_id.name}"/>
                                        </td>
                                        <td valign="middle"></td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" style="text-align:center;">
                                            <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                    <!-- CONTENT -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody><tr><td valign="top" style="font-size:13px;">
                                    <div>
                                        <p>Dear Sir/Mdm,</p>
                                        <p>There are few requirement(s) that need your attention below:</p>
                                        <div style="border: 1px solid black; width:100%;">
                                            <div name="rTable" style="display: table; width: 100%;">
                                                <div name="rTableRow" style="display: table-header-group; background-color: #ddd; font-weight: bold;">
                                                    <div name="rTableHead" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 45%;">
                                                        Requirement
                                                    </div>
                                                    <div name="rTableHead" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 12%;">
                                                        Date
                                                    </div>
                                                    <div name="rTableHead" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 23%;">
                                                        Status
                                                    </div>
                                                    <div name="rTableHead" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 20%;">
                                                    </div>
                                                </div>
                                            </div>

                                            % for requirement in ctx['requirements']:
                                            <div name="rTable" style="display: table; width: 100%;">
                                                <div name="rTableRow" style="display: table-header-group">
                                                    <div name="rTableCell" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 45%;">
                                                       ${requirement.name}
                                                    </div>
                                                    <div name="rTableCell" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 12%;">
                                                        ${format_date(requirement.date)}
                                                    </div>
                                                    <div name="rTableCell" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 23%;">
                                                        ${ctx['state'].get(requirement.state)}
                                                    </div>
                                                    <div name="rTableCell" style="display: table-cell; padding: 8px 10px; border: 1px solid #999999; width: 20%;">
                                                        <a href="${requirement.requirement_url}" style="background-color:#1B66B7;padding: 4px 10px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px; margin: 3px 0;">
                                                           View Requirement
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>

                                            % endfor
                                        </div>
                                    </div>
                                </td></tr>
                                <tr><td style="text-align:center;">
                                  <hr width="100%" style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                </td></tr>
                            </tbody></table>
                        </td>
                    </tr>
                    <!-- FOOTER -->
                    <tr>
                        <td align="center" style="min-width:800px;">
                            <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                <tbody>
                                    <tr>
                                        <td valign="middle" align="left">
                                            ${object.company_id.name}
                                        </td>
                                    </tr>
                                    <tr>
                                        <td valign="middle" align="left" style="opacity:0.7;">
                                            <a href="https://odes.com.sg/" style="text-decoration:none;background-color: rgb(255, 255, 255); font-family: &quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px;"><span style="font-weight:bolder;">https://odes.com.sg</span></a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </td>
                    </tr>
                </tbody>
                </table>
                </td></tr>
                <!-- POWERED BY -->
                <tr>
                    <td align="center" style="min-width:800px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="800" style="min-width:800px;background-color: #F1F1F1; color: #454748; padding: 8px; border-collapse:separate;">
                            <tbody>
                                <tr>
                                    <td style="text-align:center;font-size: 13px;">
                                        Powered by <a target="_blank" href="https://www.odes.com.sg?utm_source=db&amp;utm_medium=auth" style="color:#1B66B7;">ODES</a>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
                </tbody>
                </table>
            </field>
        </record>

