<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odes_crm_create_customer_user" model="ir.ui.view">
        <field name="name">odes.crm.create.customer.user.wizard</field>
        <field name="model">odes.crm.create.customer.user.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Customer User">
                <p class="oe_grey">
                    Please fill in the information below to create a new user for client to login.
                </p>
                <group>
                    <field name="name" required="1"/>
                    <field name="email" required="1"/>
                    <field name="company_id" invisible="1"/>
                </group>

                <footer>
                    <button type="object" name="action_confirm" class="oe_highlight" string="Confirm"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_odes_crm_create_customer_user" model="ir.actions.act_window">
        <field name="name">Create Customer User</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">odes.crm.create.customer.user.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="project.model_project_project"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>