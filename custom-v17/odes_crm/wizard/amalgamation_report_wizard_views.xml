<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_wizard_amalgamation_report" model="ir.actions.act_window">
        <field name="name">Amalgamation Report</field>
        <field name="res_model">amalgamation.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="amalgamation_report_wizard_form" model="ir.ui.view">
        <field name="name">amalgamation.report.wizard.form</field>
        <field name="model">amalgamation.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Amalgamation Report">
                <group>
                    <group>
                        <field name="is_c_level" string="Is C Level" invisible="1"/>
                        <field name="user_id" string="Project Manager" widget="many2one_avatar_user" required="not is_c_level" domain="[('share', '=', False)]" options='{"no_open": True, "no_create": True}'/>
                    </group>
                </group>
                <footer>
                    <!-- Regular User Button -->
                    <button name="action_view_amalgamation_report" string="View Report" type="object" class="btn-primary"/>
                    <!-- C Level Button -->
                    <!-- <button name="action_view_full_amalgamation_report" string="View Report (Full Amalgamated)" invisible="not is_c_level" type="object" class="btn-primary"/>
                    <button name="action_view_amalgamation_report" string="View Report" invisible="not is_c_level" type="object" class="btn-secondary"/> -->

                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>