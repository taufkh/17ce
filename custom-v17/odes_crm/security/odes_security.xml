<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="group_odes_customer" model="res.groups">
            <field name="name">ODES - Customer</field>
        </record>

        <record id="group_odes_c_level" model="res.groups">
            <field name="name">ODES - C-Level</field>
        </record>

        <record id="group_odes_coo" model="res.groups">
            <field name="name">ODES - COO</field>
        </record>

        <record id="group_odes_superuser" model="res.groups">
            <field name="name">ODES - Superuser</field>
        </record>

        <record id="group_odes_reporting_officer" model="res.groups">
            <field name="name">ODES - Reporting Officer</field>
        </record>
    </data>

    <data noupdate="1">
        <record id="rule_odes_crm_nda_customer" model="ir.rule">
            <field name="name">Customer: Own NDA Only</field>
            <field name="model_id" ref="model_odes_crm_nda"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('odes_crm.group_odes_customer'))]"/>
        </record>

        <record id="rule_odes_crm_quotation_customer" model="ir.rule">
            <field name="name">Customer: Own Quotations Only</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('odes_crm.group_odes_customer'))]"/>
        </record>

        <record id="rule_odes_crm_requirement_customer" model="ir.rule">
            <field name="name">Customer: Own Requirements Only</field>
            <field name="model_id" ref="model_odes_crm_requirement"/>
            <!-- v16: allowed_portal_user_ids removed from project.project in Community; simplified domain -->
            <field name="domain_force">['&amp;', '|', ('order_id.partner_id', '=', user.partner_id.id), ('project_id.customer_user_ids.partner_id', 'in', [user.partner_id.id]), ('is_internal_only', '=', False)]</field>
            <field name="groups" eval="[(4, ref('odes_crm.group_odes_customer'))]"/>
        </record>

        <record id="base.res_partner_rule" model="ir.rule">
            <field name="groups" eval="[(4, ref('odes_crm.group_odes_customer'))]"/>
        </record>
    </data>
</odoo>
