<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="act_hr2_custom_contract_action" model="ir.actions.act_window">
            <field name="name">Contracts</field>
            <field name="res_model">hr.contract</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="domain">[('employee_id.user_id', '=', uid)]</field>
            <field name="context">{
                'search_default_employee_id': [active_id],
                'default_employee_id': active_id,
                'search_default_group_by_state': 1
            }</field>
        </record>

    <record id="hr2_custom_contract_views_inherit" model="ir.ui.view">
        <field name="name">hr2.custom.contract.views.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="%(act_hr2_custom_contract_action)d"
                    class="oe_stat_button"
                    icon="fa-book"
                    type="action">
                    Contract
                </button>
            </div>
        </field>
    </record>
</odoo>