<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="sg_hr_report.payslip_inherit_report" active="False">
    <xpath expr="//span[@t-foreach='o.worked_days_line_ids']" position="replace">
            <span t-foreach="o.worked_days_line_ids" t-as="worked_days">
                <t t-if="worked_days.code != 'OUT' and worked_days.amount != 0">
                    <tr style="color:none">
                        <td>
                            <span t-field="worked_days.name"/>
                        </td>
                        <td><span t-field="worked_days.number_of_hours"/></td>
                        <td><span t-field="worked_days.number_of_days"/></td>
                        <td><span t-esc="worked_days.amount" digits="[42, 2]"
                                t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/></td>
                    </tr>
                </t>
            </span>
        </xpath>
        <xpath expr="//span[@t-foreach='o.line_ids.filtered(lambda line: line.appears_on_payslip)']" position="replace">
            <span t-foreach="o.line_ids.filtered(lambda line: line.appears_on_payslip)" t-as="line">
                <t t-if="line.total != 0">
                    <t t-set="line_style"/>
                    <t t-set="line_class"/>
                    <t t-if="line.code == 'NET'">
                        <t t-set="line_style" t-value="'color:#875A7B;'"/>
                        <t t-set="line_class" t-value="'o_total o_border_bottom'"/>
                    </t>
                    <t t-if="(line.code == 'BASIC') or (line.code == 'GROSS')">
                        <t t-set="line_style" t-value="'color:#00A09D;'"/>
                        <t t-set="line_class" t-value="'o_subtotal o_border_bottom'"/>
                    </t>
                    <tr t-att-class="line_class" t-att-style="line_style">
                        <td><span t-field="line.name"/></td>
                        <td></td>
                        <td><span t-if="line.quantity > 1" t-esc="line.quantity"/></td>
                        <td><span t-esc="line.total"
                                t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/></td>
                    </tr>
                </t>
            </span>
        </xpath>
</template>
<template id="hr_payroll.report_payslip">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <style>
                    .table-noborder, .table-noborder td{
                        border: 0px !important;
                        background-color: white !important;
                    }
                </style>
                <div class="page">
                    <center><h2 t-field="o.name"/></center>
                    
                    <table name="employee-infos" style="width:100%" class="table table-sm table-noborder">
                        <tr>
                            <td class="w-10"><strong>Name :</strong></td>
                            <td class="w-30"><span t-field="o.employee_id.name"/></td>
                            <td class="w-20"></td>
                            <td class="w-10"><strong>Employee ID :</strong></td>
                            <td class="w-30"><span t-field="o.employee_id.registration_number"/></td>
                        </tr>
                        <tr>
                            <td><strong>Company :</strong></td>
                            <td><span t-field="o.company_id.name"/></td>
                            <td></td>
                            <td><strong>Position :</strong></td>
                            <td><span t-field="o.employee_id.job_title"/></td>
                        </tr>
                        <tr>
                            <td><strong>Department :</strong></td>
                            <td><span t-field="o.employee_id.department_id.name"/></td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                    </table>
                    <br/>

                    <table class="table table-sm">
                        <tr>
                            <td class="w-25"><strong>Basic Salary :</strong></td>
                            <td style="color:#875A7B" class="w-25">
                                <span t-esc="o.line_ids.filtered(lambda line: line.code == 'BASIC').total"
                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                            <td class="w-25"></td>
                            <td class="w-25"></td>
                        </tr>
                    </table>
                    <div id="total">
                        <table class="table table-sm">
                            <thead class="o_black_border">
                                <tr>
                                    <th>Name</th>
                                    <th>Number of Hours</th>
                                    <th>Number of Days</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <span t-foreach="o.worked_days_line_ids.filtered(lambda line: line.amount)" t-as="worked_days">
                                    <t t-if="worked_days.code != 'OUT'">
                                        <tr style="color:none">
                                            <td>
                                                <span t-field="worked_days.name"/>
                                            </td>
                                            <td><span t-field="worked_days.number_of_hours"/></td>
                                            <td><span t-field="worked_days.number_of_days"/></td>
                                            <td><span t-esc="worked_days.amount" digits="[42, 2]"
                                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                        </tr>
                                    </t>
                                </span>
                                <span t-foreach="o.line_ids.filtered(lambda line: line.appears_on_payslip and line.amount)" t-as="line">
                                    <t t-set="line_style"/>
                                    <t t-set="line_class"/>
                                    <t t-if="line.code == 'NET'">
                                        <t t-set="line_style" t-value="'color:#875A7B;'"/>
                                        <t t-set="line_class" t-value="'o_total o_border_bottom'"/>
                                    </t>
                                    <t t-if="(line.code == 'BASIC') or (line.code == 'GROSS')">
                                        <t t-set="line_style" t-value="'color:#00A09D;'"/>
                                        <t t-set="line_class" t-value="'o_subtotal o_border_bottom'"/>
                                    </t>
                                    <tr t-att-class="line_class" t-att-style="line_style">
                                        <td><span t-field="line.name"/></td>
                                        <td></td>
                                        <td><span t-if="line.quantity > 1" t-esc="line.quantity"/></td>
                                        <td><span t-esc="line.total"
                                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                    </tr>
                                </span>
                            </tbody>
                        </table>
                    </div>
                    <p>Total to pay on <span t-field="o.employee_id.bank_account_id.bank_id.name"/> at <span t-field="o.date"/>, bank account of <span t-field="o.employee_id"/>: <span t-field="o.net_wage"/></p>

                    <table name="contract-infos" class="table table-sm table-bordered">
                        <tr>
                            <td class="w-25"><strong>Contract Start Date</strong></td>
                            <td class="w-25"><strong>Contract Type </strong></td>
                            <td class="w-25"><strong>Working Schedule</strong></td>
                            <td class="w-25" name="company-car-title"></td>
                        </tr>
                        <tr>
                            <td><span t-field="o.employee_id.first_contract_date"/></td>
                            <td><span t-field="o.employee_id.contract_id.contract_type"/></td>
                            <td><span t-field="o.employee_id.contract_id.hours_per_week"/></td>
                            <td class="w-25" name="company-car-model"></td>
                        </tr>
                    </table>
                    <!-- <p class="text-center">Made by Odoo</p> -->
                </div>
            </t>
        </t>
    </t>
</template>
</odoo>


