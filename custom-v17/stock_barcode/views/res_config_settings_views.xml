<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_stock_barcode" model="ir.ui.view">
        <field name="name">res.config.settings.stock.barcode.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='group_stock_multi_locations']" position="after">
                <setting id="stock_barcode_use_form_handler_setting"
                         string="Barcode Form Handler"
                         help="Use stock picking form action when opening from barcode route.">
                    <field name="stock_barcode_use_form_handler"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>

