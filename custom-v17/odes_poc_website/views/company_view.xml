<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="odes_poc_view_company_form_inherit" model="ir.ui.view">
        <field name="name">odes.poc.res.company.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="CRM" name="crm_settings">
                    <group>
                        <group name="group_left">
                            <field name="contact_user_ids" widget="many2many_tags" options="{'no_create': 1}"/>
                        </group>
                        <group name="group_right">
                            
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

</odoo>