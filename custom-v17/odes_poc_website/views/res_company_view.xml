<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="odes_poc_website_view_company_form" model="ir.ui.view">
        <field name="name">odes.poc.website.res.company.form</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="email_alternative" readonly="0" />
            </xpath>
        </field>
    </record>
</odoo>

