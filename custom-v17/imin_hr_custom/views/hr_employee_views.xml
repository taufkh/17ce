<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_employee_form_custom" model="ir.ui.view">
        <field name="name">hr.employee</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mobile_phone']" position="before">
                <field name="staff_id"/>
            </xpath>
            <xpath expr="//field[@name='department_id']" position="before">
                <field name="member_id"/>
            </xpath>
        </field>
    </record>

    <menuitem id="menu_imin_hr_employee_root" parent="hr.menu_hr_root" name="iMin" sequence="50"/>
    <menuitem id="menu_imin_hr_employee_master" parent="imin_hr_custom.menu_imin_hr_employee_root" name="Master Data" sequence="5"/>
    <menuitem id="menu_imin_hr_employee_api" parent="imin_hr_custom.menu_imin_hr_employee_root" name="Import API" sequence="10"/>
    <menuitem id="menu_imin_hr_attendance_root" parent="hr_attendance.menu_hr_attendance_root" name="iMin" sequence="50"/>
</odoo>