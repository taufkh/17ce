<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_imin_hr_webhook_log_form" model="ir.ui.view">
        <field name="name">imin.hr.webhook.log.form</field>
        <field name="model">imin.hr.webhook.log</field>
        <field name="arch" type="xml">
            <form string="Webhook Logs" create="0" edit="0" delete="0">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group col="4">
                        <field name="name"/>
                        <field name="member_id"/>
                        <field name="department"/>
                        <field name="device_name"/>
                        <field name="device_sn"/>
                        <field name="has_mask"/>
                        <field name="md_code"/>
                        <field name="recognize_mode"/>
                        <field name="record_time"/>
                        <field name="temperature"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_imin_hr_webhook_log_tree" model="ir.ui.view">
        <field name="name">imin.hr.webhook.log.tree</field>
        <field name="model">imin.hr.webhook.log</field>
        <field name="arch" type="xml">
            <tree string="Webhook Logs" create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="member_id"/>
                <field name="record_time"/>
                <field name="temperature"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_imin_hr_webhook_log" model="ir.actions.act_window">
        <field name="name">Webhook Logs</field>
        <field name="res_model">imin.hr.webhook.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_imin_hr_webhook_log" parent="imin_hr_custom.menu_imin_hr_attendance_root" action="action_imin_hr_webhook_log" sequence="10"/>
</odoo>
