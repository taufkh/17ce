<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_scheduler_autofill_checkout" model="ir.cron">
        <field name="name">Auto Fill Checkout</field>
        <field name="model_id" ref="imin_hr_custom.model_res_company" />
        <field name="state">code</field>
        <field name="code">model.auto_fill_check_out()</field>
        <field name="user_id" ref="base.user_root" />
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 15:55:00')" />
    </record>

</odoo>
