<odoo>
    <data>
        <!-- Ecommerce Header -->
        <template id="ecommerce_header_search" name="Ecommerce Header Search">
            <div class="header-search">
                <t t-if="category">
                    <t t-if="len(category) == 1">
                        <form t-att-action="keep('/shop'+ ('/category/'+slug(category)) if category else None, search=0)"
                              method="get" t-att-class="o_website_sale_search">
                            <t t-call="ecommerce_theme.ecommerce_product_search_count"/>
                        </form>
                    </t>
                    <t t-else="len(category) > 1">
                        <form action="/shop" method="get">
                            <t t-call="ecommerce_theme.ecommerce_product_search_count"/>
                        </form>
                    </t>
                </t>
                <t t-else="">
                    <form action="/shop" method="get">
                        <t t-call="ecommerce_theme.ecommerce_product_search_count"/>
                    </form>
                </t>
            </div>
        </template>

        <template id="ecommerce_frontend_layout" inherit_id="portal.frontend_layout" priority="17">
            <xpath expr="//header" position="replace">
                <header>
                    <nav class="custom_header">
                        <div class="container">
                            <div class="header-top-t">
                                <div class="navbar-header logo">
                                    <a href="/" class="navbar-brand logo">
                                        <span t-field="website.logo"
                                              t-options="{'widget': 'image'}"
                                              t-att-alt="'Logo of %s' % website.name"
                                              t-att-title="website.name"/>
                                    </a>
                                </div>
                                <t t-call="ecommerce_theme.ecommerce_header_search"/>
                                <div class="header-right">
                                    <ul id="ecommerce_cart">
                                        <li class="dropdown">
                                            <t t-if="website.user_id != user_id">
                                                <a href="#" class="dropdown-toggle"
                                                   data-toggle="dropdown">
                                                    <i class="fa fa-user"/>
                                                    <span t-esc="user_id.name[:23] + '...' if user_id.name and len(user_id.name) &gt; 25 else user_id.name"/>
                                                </a>
                                            </t>

                                            <t t-else="">
                                                <a t-attf-href="/web/login" class="dropdown-toggle"
                                                   id="dropdownMenu1"
                                                   data-toggle="dropdown" aria-haspopup="true"
                                                   aria-expanded="true">
                                                    <i class="fa fa-user"/>
                                                    Login/Register
                                                </a>
                                            </t>

                                            <ul class="dropdown-menu js_usermenu" role="menu">
                                                <li groups="base.group_public">
                                                    <a t-attf-href="/web/login">
                                                        Login
                                                    </a>
                                                </li>
                                                <li groups="base.group_public" t-if="signup_enabled">
                                                    <a t-attf-href="/web/signup">
                                                        Register
                                                    </a>
                                                </li>
                                                <t t-if="website.user_id != user_id">
                                                    <li>
                                                        <a id="o_logout" class="dropdown-item"
                                                           t-attf-href="/web/session/logout?redirect=/"
                                                           role="menuitem">
                                                            Logout
                                                        </a>
                                                    </li>
                                                </t>
                                            </ul>

                                        </li>

                                        <t t-set="website_sale_order"
                                           t-value="website.sale_get_order()"/>
                                        <li id="my_cart">
                                            <a href="/shop/cart" class="nav-link">
                                                <i class="fa fa-shopping-cart"/>
                                                My Cart
                                                <sup t-attf-class="my_cart_quantity badge badge-primary"
                                                     t-esc="website_sale_order and website_sale_order.cart_quantity or 0"/>
                                            </a>
                                        </li>
                                        <t t-set="wishcount" t-value="len(request.env['product.wishlist'].current())"/>
                                        <t t-set="show_wishes" t-value="True"/>
                                        <li t-attf-class="o_wsale_my_wish #{not show_wishes and 'd-none'} #{_item_class}">
                                            <a href="/shop/wishlist" t-attf-class="#{_link_class}">
                                                <i class="fa fa-heart"></i>
                                                <span>Wishlist</span>
                                                <sup t-esc="wishcount" t-attf-class="my_wish_quantity o_animate_blink badge badge-primary"/>
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <nav class="navbar navbar-expand-md">
                                <button type="button" class="navbar-toggler" data-toggle="collapse"
                                        data-target="#top_menu_collapse">
                                    <span class="navbar-toggler-icon fa fa-bars"/>
                                </button>
                                <div class="collapse navbar-collapse" id="top_menu_collapse">
                                    <ul class="nav navbar-nav" id="top_menu">
                                        <t t-foreach="website.menu_id.child_id" t-as="submenu">
                                            <t t-call="website.submenu">
                                                <t t-set="item_class" t-value="'nav-item'"/>
                                                <t t-set="link_class" t-value="'nav-link'"/>
                                            </t>
                                        </t>
                                    </ul>
                                </div>
                            </nav>
                        </div>
                    </nav>
                </header>
            </xpath>
        </template>

        <template id="ecommerce_product_search_count">
            <div class="input-group">
                <div class="oe_search">
                    <input type="text" name="search" class="search-query form-control oe_search_box"
                           placeholder="Search product..." t-att-value="search"/>
                </div>
                <span class="input-group-btn">
                    <button type="submit" class="btn btn-default oe_search_button">
                        <i class="fa fa-search"/>
                        <t t-if="request.env.ref('website_sale.search_count_box').sudo().active">
                            <span t-if='search and search_count_box' class='oe_search_found'>
                                <small>(
                                    <t t-esc="search_count_box"/>
                                    found)
                                </small>
                            </span>
                        </t>
                    </button>
                </span>
            </div>
        </template>

